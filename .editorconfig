root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{sh,bash,bats}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
# Markdown uses two trailing spaces for a hard line break; do not strip them.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
indent_size = 8
tab_width = 8
