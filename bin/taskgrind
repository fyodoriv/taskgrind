#!/bin/bash
# Autonomous multi-session grind — runs sequential AI coding sessions until deadline.
# Each session starts with full context. State lives in TASKS.md + git, so the
# next session picks up seamlessly. Sessions should exit BEFORE context fills —
# context exhaustion crashes the process and loses any uncommitted work.
#
# Usage: taskgrind                              → 10h grind (default)
#        taskgrind 10                          → 10h grind, current dir
#        taskgrind ~/apps/myrepo 10            → 10h grind in specific repo
#        taskgrind --model gpt-5-5-xhigh-priority 8 → 8h grind with specific model
#        taskgrind --model "gpt-5.5 XHigh thinking fast" 8
#                                               → quote multi-word model names
#        taskgrind --skill pipeline-ops ~/apps/bosun 10
#                                             → 10h run with a custom skill
#        taskgrind --backend claude-code 8     → 8h grind with Claude Code
#        taskgrind --rotate-backends devin,claude-code,codex 8
#                                             → override auto-detected backend rotation.
#        taskgrind --prompt "focus on test coverage" 8
#        taskgrind --target-repo ~/apps/frontend --target-repo ~/apps/backend ~/apps/control 8
#                                             → workspace mode: control repo holds TASKS.md,
#                                               agent has read/write access to target repo(s),
#                                               slot 0 also syncs and pushes each target.
#        taskgrind --from-prompt "8 hours on agentbrew with frontend and backend targets, focus on tests, use opus"
#                                             → translate a natural-language brief into config via the
#                                               configured AI backend, then launch. Explicit CLI flags
#                                               and TG_ env vars always win over translated values.
#        taskgrind --dry-run 8 ~/apps/myrepo  → print config without running
#        taskgrind --preflight ~/apps/myrepo  → run health checks only
#        taskgrind --resume ~/apps/myrepo     → resume an interrupted grind
#        taskgrind --no-push 8 ~/apps/myrepo  → commit locally, never auto-push to origin
#        taskgrind --no-pr-fallback 8 ~/apps/myrepo
#                                             → on protected-branch push rejection, skip the
#                                               auto-PR fallback and require manual recovery
#        taskgrind --help / -h                → show this help and exit
#        taskgrind --version / -V             → print version (commit hash + date)
#        TG_MODEL=sonnet taskgrind 8           → 8h grind, sonnet model
#        TG_BACKEND=codex taskgrind 8          → 8h grind with Codex
#        TG_MAX_INSTANCES=3 taskgrind ~/apps/myrepo 8
#                                             → allow three concurrent grinds per repo
#        TG_STATUS_FILE=/tmp/taskgrind-status.json taskgrind ~/apps/myrepo 8
#                                             → write machine-readable status snapshots
#        TG_TARGET_REPOS=~/apps/frontend:~/apps/backend taskgrind ~/apps/control 8
#                                             → workspace mode via env (colon-separated paths)
#
#        Args can appear in any order. Hours is any bare integer (1-24).
#
# Env:   TG_BACKEND     — AI backend: devin, claude-code, codex (default: devin)
#        TG_ROTATE_BACKENDS — comma-separated list overriding auto-detected
#                            mid-flight rotation.
#        TG_MODEL       — AI model (default: "gpt-5-5-xhigh-priority")
#        TG_COOL        — seconds between sessions (default: 5; short settle
#                         window for filesystem/git-hook cleanup)
#        TG_SKILL       — skill to run (default: next-task)
#        TG_PROMPT      — extra focus prompt prepended to every session
#        TG_LOG         — override log file path
#        TG_STATUS_FILE — write machine-readable runtime status JSON to this path
#        TG_NOTIFY      — desktop notification on completion (default: 1, set 0 to disable)
#        TG_MAX_SESSION — max seconds per session before timeout (default: 5400, was
#                        3600 before 2026-04-29). Bumped after pre-commit hook AIFN-720
#                        enforced "code commits via pipelines only" — sessions are now
#                        an orchestrator role (launch + monitor + merge), and pipelines
#                        take 20-45 min each. 90 min lets the agent batch 2-3 pipeline
#                        cycles per session vs ~1 in the old direct-edit model.
#        TG_SWEEP_MAX   — max seconds for a backlog-discovery sweep session,
#                         independent of max_session (default: 1800; splits
#                         runaway sweeps instead of inheriting the 90m cap)
#        TG_MAX_FAST    — max consecutive fast failures before bail out
#                         (default: 20; enough samples for diagnostics)
#        TG_MAX_ZERO_SHIP — max consecutive zero-ship sessions before bail
#                         (default: 6; follows the 5-session throughput window)
#        TG_SELF_INVESTIGATE_ZERO_SHIP_STREAK — consecutive zero-ship sessions
#                         before stall warnings and mid-run self-investigation
#                         (default: 3)
#        TG_BACKOFF_BASE — base seconds for fast-failure backoff (default: 15;
#                         slows crash loops without hiding recovery)
#        TG_BACKOFF_MAX — cap for fast-failure backoff (default: 120; keeps
#                         recovery checks at least every 2 min)
#        TG_NET_WAIT    — network polling interval in seconds (default: 30;
#                         responsive for Wi-Fi recovery without log spam)
#        TG_NET_MAX_WAIT — max time to wait for network in seconds (default:
#                         3600; one-hour local outage budget)
#        TG_NET_RETRIES — network check retry attempts before declaring down
#                         (default: 3; filters transient DNS/HTTP blips)
#        TG_NET_RETRY_DELAY — seconds between network check retries (default: 2)
#        TG_NET_CHECK_URL — override the fallback connectivity check URL
#        TG_MIN_SESSION — fast-failure threshold in seconds (default: 30;
#                         shorter sessions are usually startup/network faults)
#        TG_DEVIN_PATH  — override devin binary path (default: auto-detect from PATH)
#        TG_GIT_SYNC_TIMEOUT — max seconds for between-session git sync
#                         (default: 30; hangs need operator action)
#        TG_SYNC_INTERVAL — git sync every N sessions (default: 5, 0=every
#                         session; amortizes fetch/rebase overhead)
#        TG_EMPTY_QUEUE_WAIT — seconds to wait after an empty sweep (default: 600)
#        TG_SHUTDOWN_GRACE — seconds to wait for current session on exit (default: 120)
#        TG_SESSION_GRACE — seconds to wait after session SIGINT before SIGTERM (default: 15)
#        TG_EARLY_EXIT_ON_STALL — exit on the FIRST diminishing_returns trip
#                         (default: 0; backward-compat alias for TG_EXIT_ON_STALL)
#        TG_EXIT_ON_STALL — exit on the FIRST diminishing_returns trip
#                         (default: 0; default behavior is to exit on the
#                         SECOND consecutive trip without any flag set)
#        TG_NO_STALL_EXIT — never auto-exit on diminishing_returns; log
#                         advisory only (default: 0)
#        TG_MAX_INSTANCES — max concurrent instances per repo (default: 2;
#                         one sync owner plus one conflict-avoiding worker)
#        TG_NO_PUSH     — 1 = never auto-push commits to origin; agent prompt
#                         also forbids `git push` / `gh pr merge` (default: 0)
#        TG_NO_PR_FALLBACK — 1 = on `final_sync` push rejected by branch
#                         protection (GH006 / required-status-check), skip
#                         the auto-PR fallback (open a PR via `gh pr create`)
#                         and log `push_protected_branch_manual_recovery_needed`
#                         instead. Default 0: PR fallback runs when `gh` is on
#                         PATH, `TG_NO_PUSH` is not set, and
#                         `TG_PUBLIC_WRITE_TOKEN` is set.
#        TG_PUBLIC_WRITE_TOKEN — approval token for final_sync auto-PR creation.
#                         When set (any non-empty string, e.g. "session-2026-05-01"),
#                         taskgrind may push a feature branch and open a PR via
#                         `gh pr create` when the direct push is blocked by branch
#                         protection. When unset (default), auto-PR creation is
#                         blocked: taskgrind writes the draft PR body to a temp
#                         file, prints `Approval needed — draft body at <path>`,
#                         and falls through to
#                         `push_protected_branch_manual_recovery_needed`. This
#                         prevents unapproved public writes from agent sessions.
#                         Set once per grind run to authorize the specific PR.
#        TG_TARGET_REPOS — colon-separated workspace target repo paths. Same
#                         effect as repeating `--target-repo PATH`. The control
#                         repo (positional arg) holds TASKS.md and the slot
#                         lock; targets get `fetch` + `rebase` between sessions
#                         and a `push` from `final_sync` on slot 0.
#        TG_FROM_PROMPT  — natural-language brief that the configured AI backend
#                         translates into config (hours, repo, target_repos,
#                         model, backend, skill, focus, no_push). Explicit CLI
#                         flags and other TG_ env vars take precedence; the
#                         translation only fills in slots the user did not set.
#                         Same effect as passing `--from-prompt "<text>"`.
#        TG_BOSUN_HEARTBEAT_INTERVAL — seconds between `bosun grind heartbeat`
#                         posts during a Bosun-dependent grind (default: 60;
#                         well under bosun's 5-min disconnect timeout). Lower
#                         in tests to observe the loop; raise on bandwidth-
#                         constrained networks.
#
#        DVB_ prefix is supported as a backward-compatible alias for all TG_ vars.
#
# Network resilience: survives wifi drops for hours. When a session crashes
# in < 30s, taskgrind checks connectivity. If the network is down, it pauses
# the marathon timer and polls every 30s until connectivity returns, then
# extends the deadline by the wait duration. No sessions are wasted.
set -euo pipefail

resolve_script_path() {
  local source_path="$1"
  local source_dir target_path

  while [[ -L "$source_path" ]]; do
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    target_path="$(readlink "$source_path")" || break
    case "$target_path" in
      /*) source_path="$target_path" ;;
      *) source_path="$source_dir/$target_path" ;;
    esac
  done

  source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
  printf '%s/%s\n' "$source_dir" "$(basename "$source_path")"
}

TASKGRIND_SCRIPT_PATH="${TASKGRIND_SCRIPT_PATH:-$(resolve_script_path "$0")}"
TASKGRIND_REPO_DIR="${TASKGRIND_REPO_DIR:-$(cd "$(dirname "$TASKGRIND_SCRIPT_PATH")/.." && pwd)}"
TASKGRIND_DIR="${TASKGRIND_DIR:-$TASKGRIND_REPO_DIR}"
export TASKGRIND_SCRIPT_PATH TASKGRIND_REPO_DIR TASKGRIND_DIR

[[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { sed -n '/^#!/d; /^$/q; /^[^#]/q; /^# shellcheck/d; s/^# \{0,1\}//p' "$TASKGRIND_SCRIPT_PATH"; exit 0; }
[[ "${1:-}" == "--version" || "${1:-}" == "-V" ]] && { echo "taskgrind $(git -C "$TASKGRIND_REPO_DIR" log -1 --format='%h %ci' 2>/dev/null || echo 'unknown')"; exit 0; }

# Respect TMPDIR for all temp files (macOS default: /tmp)
_dvb_tmp="${TMPDIR:-/tmp}"
_dvb_tmp="${_dvb_tmp%/}"

# Self-copy protection: bash reads scripts lazily by byte offset. If a grind
# session modifies this script (e.g., grinding the taskgrind repo itself), the
# running process reads from shifted offsets and crashes. Copy to a temp file
# and re-exec from there so the running copy is never modified.
# Must run BEFORE sourcing relative paths — the copy lives in $TMPDIR so $0-based
# paths would resolve incorrectly instead of to the real repo dir.
if [[ -z "${_DVB_SELF_COPY:-}" ]]; then
  _dvb_copy=$(mktemp "$_dvb_tmp/taskgrind-exec.XXXXXX")
  cp "$TASKGRIND_SCRIPT_PATH" "$_dvb_copy"
  chmod +x "$_dvb_copy"
  export _DVB_SELF_COPY="$_dvb_copy"
  export TASKGRIND_SCRIPT_PATH
  export TASKGRIND_REPO_DIR
  export TASKGRIND_DIR
  exec "$_dvb_copy" "$@"
fi

# Ensure self-copy temp file is cleaned up even on early exits (validation, --dry-run).
# The full cleanup() trap replaces this later once all variables are initialized.
trap '[[ -n "${_DVB_SELF_COPY:-}" && -f "${_DVB_SELF_COPY}" ]] && rm -f "$_DVB_SELF_COPY"' EXIT

# Shared constants (model, devin path, caffeinate flags, format_duration)
# shellcheck source=../lib/constants.sh
source "$TASKGRIND_DIR/lib/constants.sh"
_dvb_is_tty="${_dvb_is_tty:-0}"

# ── TG_ prefix resolution ─────────────────────────────────────────────
# TG_ is the canonical prefix; DVB_ is kept for backward compat.
# If TG_X is set, it takes precedence over DVB_X. Internal/test-only vars
# (DVB_GRIND_CMD, DVB_DEADLINE, DVB_NET_FILE, DVB_CAFFEINATED) stay as DVB_.
for _tg_var in BACKEND BACKOFF_BASE BACKOFF_MAX COOL DEVIN_PATH \
               EARLY_EXIT_ON_STALL EMPTY_QUEUE_WAIT EXIT_ON_STALL FROM_PROMPT \
               GIT_SYNC_TIMEOUT LOG MAX_FAST MAX_INSTANCES \
               MAX_SESSION MAX_ZERO_SHIP MIN_SESSION MODEL NET_CHECK_URL NET_MAX_WAIT \
               NET_RETRIES NET_RETRY_DELAY NET_WAIT NO_PUSH NO_STALL_EXIT NOTIFY PROMPT \
               PUBLIC_WRITE_TOKEN \
               ROTATE_BACKENDS SELF_INVESTIGATE_ZERO_SHIP_STREAK SESSION_GRACE \
               SHUTDOWN_GRACE SKILL STATUS_FILE SWEEP_MAX SYNC_INTERVAL TARGET_REPOS; do
  _tg_ref="TG_${_tg_var}"
  if [[ -n "${!_tg_ref:-}" ]]; then
    export "DVB_${_tg_var}"="${!_tg_ref}"
  fi
done

unset _tg_var _tg_ref

# Save original args before parsing — caffeinate re-exec needs them intact
_orig_args=("$@")

# Parse all args in any order: hours (integer), --model NAME, --skill NAME, --backend NAME, --prompt TEXT, --dry-run, --preflight, repo path
hours="10"
repo="."
skill="${DVB_SKILL:-next-task}"
extra_prompt="${DVB_PROMPT:-}"
_cli_backend=""
_cli_rotate_backends=""
_cli_model=""
dry_run=0
preflight_only=0
resume_run=0
_cli_no_push=""  # tri-state: "" = unset, "0" / "1" = explicit CLI choice
_cli_no_pr_fallback=""  # tri-state: "" = unset, "0" / "1" = explicit CLI choice
# Slot-tracking flags — distinguish "user passed this on the CLI" from "still
# the default" so the --from-prompt translation can fill in only the slots the
# user did NOT set explicitly. The existing CLI parser doesn't separate "user
# typed --skill next-task" from "default kicked in"; these flags close that gap
# without changing the existing semantics.
_cli_hours_set=0
_cli_repo_set=0
_cli_skill_set=0
# Workspace mode — control repo + N target repos. Populated by repeated
# --target-repo CLI flags or the colon-separated TG_TARGET_REPOS env var.
# `target_repos` is the resolved, deduped, absolute-path list used by the
# rest of the script; the resolution happens after the CLI parser so the
# control repo path is known. Empty array = single-repo mode (the default).
target_repos=()
_cli_target_repos_set=0  # 1 if --target-repo appeared on the CLI
_cli_target_repos_raw=()
# Natural-language config translator — `--from-prompt "<text>"` (or
# `TG_FROM_PROMPT`). When set, taskgrind asks the configured AI backend to
# parse the brief into KEY=VALUE config lines and fills in the slots the user
# did not pass on the CLI / via env. Explicit user config always wins; the
# translation never overwrites it. Logged for auditability.
_from_prompt_text="${DVB_FROM_PROMPT:-}"
# Translation outputs — populated by translate_from_prompt() before slot merge.
_fp_hours=""
_fp_repo=""
_fp_targets=""  # colon-joined, same shape as TG_TARGET_REPOS
_fp_model=""
_fp_backend=""
_fp_skill=""
_fp_focus=""
_fp_no_push=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h) sed -n '/^#!/d; /^$/q; /^[^#]/q; /^# shellcheck/d; s/^# \{0,1\}//p' "$0"; exit 0 ;;
    --version|-V) echo "taskgrind $(git -C "$TASKGRIND_DIR" log -1 --format='%h %ci' 2>/dev/null || echo 'unknown')"; exit 0 ;;
    --dry-run) dry_run=1; shift ;;
    --preflight) preflight_only=1; shift ;;
    --resume) resume_run=1; shift ;;
    --no-push) _cli_no_push=1; shift ;;
    --no-pr-fallback) _cli_no_pr_fallback=1; shift ;;
    --model=*) _cli_model="${1#--model=}"; [[ -z "$_cli_model" ]] && { echo "Error: --model requires a non-empty name (example: --model gpt-5-5-xhigh-priority). See 'taskgrind --help'." >&2; exit 1; }; shift ;;
    --model)
      if [[ $# -lt 2 ]]; then
        echo "Error: --model requires a name (example: --model gpt-5-5-xhigh-priority). See 'taskgrind --help'." >&2; exit 1
      fi
      _cli_model="$2"
      [[ -z "$_cli_model" ]] && { echo "Error: --model requires a non-empty name (example: --model gpt-5-5-xhigh-priority). See 'taskgrind --help'." >&2; exit 1; }
      shift 2
      ;;
    --skill=*) skill="${1#--skill=}"; [[ -z "$skill" ]] && { echo "Error: --skill requires a non-empty name" >&2; exit 1; }; _cli_skill_set=1; shift ;;
    --skill)
      if [[ $# -lt 2 ]]; then
        echo "Error: --skill requires a name" >&2; exit 1
      fi
      skill="$2"
      [[ -z "$skill" ]] && { echo "Error: --skill requires a non-empty name" >&2; exit 1; }
      _cli_skill_set=1
      shift 2
      ;;
    --backend=*) _cli_backend="${1#--backend=}"; [[ -z "$_cli_backend" ]] && { echo "Error: --backend requires a name (devin, claude-code, codex)" >&2; exit 1; }; shift ;;
    --backend)
      if [[ $# -lt 2 ]]; then
        echo "Error: --backend requires a name (devin, claude-code, codex)" >&2; exit 1
      fi
      _cli_backend="$2"
      [[ -z "$_cli_backend" ]] && { echo "Error: --backend requires a name (devin, claude-code, codex)" >&2; exit 1; }
      shift 2
      ;;
    --rotate-backends=*) _cli_rotate_backends="${1#--rotate-backends=}"; [[ -z "$_cli_rotate_backends" ]] && { echo "Error: --rotate-backends requires comma-separated list (e.g. devin,claude-code,codex)" >&2; exit 1; }; shift ;;
    --rotate-backends)
      if [[ $# -lt 2 ]]; then
        echo "Error: --rotate-backends requires comma-separated list (e.g. devin,claude-code,codex)" >&2; exit 1
      fi
      _cli_rotate_backends="$2"
      [[ -z "$_cli_rotate_backends" ]] && { echo "Error: --rotate-backends requires comma-separated list" >&2; exit 1; }
      shift 2
      ;;
    --prompt=*) extra_prompt="${1#--prompt=}"; shift ;;
    --prompt)
      if [[ $# -lt 2 ]]; then
        echo "Error: --prompt requires a value" >&2; exit 1
      fi
      extra_prompt="$2"; shift 2
      ;;
    --target-repo=*)
      _tg_arg="${1#--target-repo=}"
      [[ -z "$_tg_arg" ]] && { echo "Error: --target-repo requires a path (example: --target-repo ~/apps/frontend). See 'taskgrind --help'." >&2; exit 1; }
      _cli_target_repos_raw+=("$_tg_arg")
      _cli_target_repos_set=1
      shift
      ;;
    --target-repo)
      if [[ $# -lt 2 ]]; then
        echo "Error: --target-repo requires a path (example: --target-repo ~/apps/frontend). See 'taskgrind --help'." >&2; exit 1
      fi
      [[ -z "$2" ]] && { echo "Error: --target-repo requires a non-empty path" >&2; exit 1; }
      _cli_target_repos_raw+=("$2")
      _cli_target_repos_set=1
      shift 2
      ;;
    --from-prompt=*)
      _from_prompt_text="${1#--from-prompt=}"
      [[ -z "$_from_prompt_text" ]] && { echo "Error: --from-prompt requires a non-empty text (example: --from-prompt \"8h on agentbrew with frontend backend, focus on tests\")." >&2; exit 1; }
      shift
      ;;
    --from-prompt)
      if [[ $# -lt 2 ]]; then
        echo "Error: --from-prompt requires a text argument (example: --from-prompt \"8h on agentbrew with frontend backend, focus on tests\")." >&2; exit 1
      fi
      _from_prompt_text="$2"
      [[ -z "$_from_prompt_text" ]] && { echo "Error: --from-prompt requires a non-empty text" >&2; exit 1; }
      shift 2
      ;;
    *)
      if [[ "$1" =~ ^[0-9]+$ ]] && [[ ! -d "$1" ]]; then
        hours="$1"
        _cli_hours_set=1
      else
        repo="$1"
        _cli_repo_set=1
      fi
      shift
      ;;
  esac
done

# ── --from-prompt translation ────────────────────────────────────────
# When `--from-prompt "<text>"` (or `TG_FROM_PROMPT`) is set, ask the
# configured AI backend to translate the natural-language brief into
# KEY=VALUE config lines. The translation runs BEFORE slot resolution so
# prompt-derived values can fill in slots the user did not set on the CLI
# or via env. Explicit user config always wins — this layer slots in
# between env vars and the static defaults.
#
# Test bypass: setting `DVB_FROM_PROMPT_RESPONSE` to a canned KEY=VALUE
# string skips the backend call so bats tests stay deterministic without
# requiring a real LLM. Production runs always call the backend.
translate_from_prompt() {
  # Pick the backend + model for the translator call: explicit CLI > env >
  # default. We deliberately do NOT use prompt-derived model/backend (that
  # would be circular — we are running this CALL to learn what they are).
  local _trans_model _trans_backend _trans_model_source
  _trans_backend="${_cli_backend:-${DVB_BACKEND:-devin}}"
  _trans_model_source="${_cli_model:-${DVB_MODEL:-}}"
  if [[ -n "$_trans_model_source" ]]; then
    _trans_model="$(dvb_resolve_model_alias "$_trans_model_source")"
  else
    _trans_model="$(dvb_default_model_for_backend "$_trans_backend")"
  fi

  local _home_path="${HOME:-/}"
  # Build the translation prompt with a quoted heredoc + manual placeholder
  # substitution. This pattern sidesteps a bash 3.2 parser bug where bare
  # apostrophes inside `$(cat <<EOF ... EOF)` are misread as the start of a
  # single-quoted string. Using `<<'EOF'` disables parameter expansion, so we
  # place __PLACEHOLDER__ tokens for the two variables and substitute them
  # afterward with `${var//pattern/replacement}` (bash 3.2 compatible).
  local _trans_input
  _trans_input=$(cat <<'EOF'
You are a config translator for taskgrind, an autonomous coding-agent runner.
Convert the request into KEY=VALUE configuration lines.
OUTPUT ONLY THOSE LINES. No prose, no markdown, no code fences, no JSON.

User request: __FROM_PROMPT_TEXT__

User home directory: __HOME_PATH__

Output format. One line per non-default field, exactly these keys, omit
lines for fields the request did not specify:
  hours=<integer 1-24>
  repo=<absolute path to control repo>
  target_repos=<colon-separated absolute paths to extra target repos>
  model=<opus | sonnet | haiku | swe | codex | gpt | full model id>
  backend=<devin | claude-code | codex>
  skill=<skill name; default is next-task>
  focus=<agent focus prompt — the residue of intent that is not config>
  no_push=<0 or 1>

Rules:
- Only emit lines for fields the request explicitly mentions. Omit the rest.
- Resolve project names (e.g. "agentbrew", "this repo") to absolute paths
  under __HOME_PATH__/apps/<name>.
- "use opus" or "with opus" or "opus model" -> model=opus.
- "via codex" or "codex backend" -> backend=codex. Bare "codex" -> model.
- "do not push" or "review only" or "no publish" -> no_push=1.
- "focus on X" or "prioritize Y" -> focus=X (or Y).
- The "focus" value is whatever remains of the request that is not config;
  omit the line entirely if no residue remains.
- DO NOT emit hours, repo, model, backend, skill, or no_push lines the
  request did not specify. Defaults handle those.

Example input: "8 hours on agentbrew with frontend and backend targets,
focus on test coverage, use opus"
Example output:
hours=8
repo=__HOME_PATH__/apps/agentbrew
target_repos=__HOME_PATH__/apps/frontend:__HOME_PATH__/apps/backend
model=opus
focus=focus on test coverage
EOF
  )
  _trans_input="${_trans_input//__FROM_PROMPT_TEXT__/$_from_prompt_text}"
  _trans_input="${_trans_input//__HOME_PATH__/$_home_path}"

  local response
  if [[ -n "${DVB_FROM_PROMPT_RESPONSE:-}" ]]; then
    # Test bypass — read canned response so bats tests don't need a real LLM.
    response="$DVB_FROM_PROMPT_RESPONSE"
  else
    # Real backend call. Resolve the binary inline so this function does not
    # depend on `resolve_test_backend_command` / `resolve_backend_binary`,
    # which are defined later in the script. Same precedence as the main
    # session resolver: DVB_GRIND_CMD (test override) > backend-specific
    # binary on PATH.
    local _trans_bin
    if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
      if [[ "$DVB_GRIND_CMD" =~ [[:space:]] ]]; then
        echo "Error: --from-prompt: DVB_GRIND_CMD must be a single executable path, not a command line: $DVB_GRIND_CMD" >&2
        exit 1
      fi
      if [[ "$DVB_GRIND_CMD" == */* ]]; then
        _trans_bin="$DVB_GRIND_CMD"
      else
        _trans_bin=$(type -P "$DVB_GRIND_CMD" 2>/dev/null || true)
      fi
      if [[ -z "$_trans_bin" || ! -x "$_trans_bin" ]]; then
        echo "Error: --from-prompt: DVB_GRIND_CMD test backend not executable: $DVB_GRIND_CMD" >&2
        exit 1
      fi
    else
      case "$_trans_backend" in
        devin) _trans_bin="$DVB_DEVIN_PATH" ;;
        claude-code) _trans_bin=$(command -v claude 2>/dev/null || echo "") ;;
        codex) _trans_bin=$(command -v codex 2>/dev/null || echo "") ;;
        *) echo "Error: --from-prompt translation: unknown backend '$_trans_backend'. Set --backend or TG_BACKEND to devin, claude-code, or codex." >&2; exit 1 ;;
      esac
      if [[ ! -x "$_trans_bin" ]]; then
        echo "Error: --from-prompt translation: backend binary not found ($_trans_backend): ${_trans_bin:-not in PATH}. Install the $_trans_backend CLI or pass config flags explicitly without --from-prompt." >&2
        exit 1
      fi
    fi

    local -a _trans_args=()
    case "$_trans_backend" in
      devin) _trans_args=(--model "$_trans_model" --permission-mode dangerous -p "$_trans_input") ;;
      claude-code) _trans_args=(--model "$_trans_model" --dangerously-skip-permissions -p "$_trans_input") ;;
      codex) _trans_args=(--model "$_trans_model" -q "$_trans_input") ;;
    esac

    local _trans_status=0
    if ! response=$("$_trans_bin" "${_trans_args[@]}" 2>&1); then
      _trans_status=$?
      echo "Error: --from-prompt translation failed via $_trans_backend (exit $_trans_status). First 500 chars of output:" >&2
      printf '%s\n' "$response" | head -c 500 >&2
      echo "" >&2
      exit 1
    fi
  fi

  # Parse KEY=VALUE lines. Unknown keys are ignored defensively (LLM may emit
  # extras). Values are taken verbatim — no shell expansion.
  local _seen_any=0
  local _key _value
  while IFS='=' read -r _key _value; do
    [[ -z "$_key" ]] && continue
    # Trim leading/trailing whitespace from key (defensive against LLM quirks)
    _key="${_key#"${_key%%[![:space:]]*}"}"
    _key="${_key%"${_key##*[![:space:]]}"}"
    # Trim trailing CR/LF from value (in case of \r\n line endings)
    _value="${_value%$'\r'}"
    case "$_key" in
      hours) _fp_hours="$_value"; _seen_any=1 ;;
      repo) _fp_repo="$_value"; _seen_any=1 ;;
      target_repos) _fp_targets="$_value"; _seen_any=1 ;;
      model) _fp_model="$_value"; _seen_any=1 ;;
      backend) _fp_backend="$_value"; _seen_any=1 ;;
      skill) _fp_skill="$_value"; _seen_any=1 ;;
      focus) _fp_focus="$_value"; _seen_any=1 ;;
      no_push) _fp_no_push="$_value"; _seen_any=1 ;;
      *) ;;
    esac
  done <<< "$response"

  if [[ "$_seen_any" -eq 0 ]]; then
    echo "Error: --from-prompt translation produced no parseable KEY=VALUE lines via $_trans_backend. Set flags explicitly or rewrite the prompt. First 500 chars of response:" >&2
    printf '%s\n' "$response" | head -c 500 >&2
    echo "" >&2
    exit 1
  fi
}

# Run translation now, before slot resolution. Reject --resume + --from-prompt:
# resume's source of truth is the saved .taskgrind-state, not a re-translated
# brief that could silently diverge from the original run's config.
if [[ -n "$_from_prompt_text" ]]; then
  if [[ "$resume_run" -eq 1 ]]; then
    echo "Error: --from-prompt is not compatible with --resume. Resume uses the saved .taskgrind-state; drop --from-prompt or start a fresh grind." >&2
    exit 1
  fi
  translate_from_prompt
fi

# ── Slot merge ────────────────────────────────────────────────────────
# Apply translated values to slots the user did not set explicitly.
# Precedence: explicit CLI flag > TG_/DVB_ env var > _fp_* (prompt) > default.
# `target_repos` and `no_push` resolution lives further down so the merge for
# those is applied at the existing site (see the workspace-resolution block
# and the no_push resolution block below).
if [[ "$_cli_hours_set" -eq 0 && -n "$_fp_hours" ]]; then
  hours="$_fp_hours"
fi
if [[ "$_cli_repo_set" -eq 0 && -n "$_fp_repo" ]]; then
  repo="$_fp_repo"
fi
if [[ "$_cli_skill_set" -eq 0 && -z "${DVB_SKILL:-}" && -n "$_fp_skill" ]]; then
  skill="$_fp_skill"
fi
if [[ -z "$extra_prompt" && -n "$_fp_focus" ]]; then
  extra_prompt="$_fp_focus"
fi

requested_backend="${_cli_backend:-${DVB_BACKEND:-${_fp_backend:-devin}}}"
_requested_model_source="${_cli_model:-${DVB_MODEL:-${_fp_model:-}}}"
if [[ -n "$_requested_model_source" ]]; then
  requested_model="$(dvb_resolve_model_alias "$_requested_model_source")"
else
  requested_model="$(dvb_default_model_for_backend "$requested_backend")"
fi
model="$requested_model"
backend="$requested_backend"

# ── Backend rotation list ────────────────────────────────────────────
# Mid-flight backend switching: taskgrind scans each session's output for
# rate-limit / quota patterns. On match, the next session is launched with
# the next backend in the auto-detected or user-configured list (cycling).
# Source priority: --rotate-backends CLI flag → DVB_ROTATE_BACKENDS env var
# (which mirrors TG_ROTATE_BACKENDS via the prefix-resolution loop above).
_rotation_backends=()
_current_rotation_index=0
_rotation_raw="${_cli_rotate_backends:-${DVB_ROTATE_BACKENDS:-}}"

# When --rotate-backends is NOT set, auto-detect which backend binaries are
# present on PATH and build the rotation list from whatever's installed.
# This makes auto-rotation the OUT-OF-BOX behaviour: a user who installs
# devin + claude + codex automatically gets graceful failover when one of
# them is rate-limited or unavailable, with no flag required.
#
# Empty list → single-backend mode (no rotation, equivalent to the old
# behaviour). 1-element list also no-ops (rotation needs ≥2 candidates).
# Skipped in test mode (DVB_GRIND_CMD set) so the bats suite stays
# independent of the real binaries on the runner's PATH.
if [[ -z "$_rotation_raw" && -z "${DVB_GRIND_CMD:-}" ]]; then
  _autodetected=()
  [[ -x "$DVB_DEVIN_PATH" ]] && _autodetected+=("devin")
  command -v claude >/dev/null 2>&1 && _autodetected+=("claude-code")
  command -v codex  >/dev/null 2>&1 && _autodetected+=("codex")
  if [[ ${#_autodetected[@]} -ge 2 ]]; then
    _rotation_raw=$(IFS=,; echo "${_autodetected[*]}")
    echo "   ↺ Auto-detected backends: ${_rotation_raw} — enabling rotation. Override with --rotate-backends or TG_ROTATE_BACKENDS." >&2
  fi
  unset _autodetected
fi

if [[ -n "$_rotation_raw" ]]; then
  IFS=',' read -ra _rotation_backends <<< "$_rotation_raw"
  # Trim whitespace from each entry — users naturally type "devin, claude-code".
  for ((_i = 0; _i < ${#_rotation_backends[@]}; _i++)); do
    _rotation_backends[_i]="${_rotation_backends[_i]// /}"
  done
  unset _i
  # If the configured starting backend is in the rotation list, start at its
  # index so the first failure correctly advances to the NEXT backend rather
  # than circling back to itself. Otherwise start at index 0 — the first
  # rotation will pick _rotation_backends[1].
  for ((_i = 0; _i < ${#_rotation_backends[@]}; _i++)); do
    if [[ "${_rotation_backends[_i]}" == "$backend" ]]; then
      _current_rotation_index=$_i
      break
    fi
  done
  unset _i
fi
unset _rotation_raw

_cli_prompt="$extra_prompt"
cooldown="${DVB_COOL:-$DVB_DEFAULT_COOL}"
max_hours=24
max_fast="${DVB_MAX_FAST:-$DVB_DEFAULT_MAX_FAST}"
max_session="${DVB_MAX_SESSION:-$DVB_DEFAULT_MAX_SESSION}"
# Sweep sessions get their own ceiling so a runaway sweep cannot inherit
# the productive-timeout-escalated grind cap (which can climb to 7200 s)
# and burn an entire chunk of the budget on backlog discovery. Default
# 1800 s matches the cheaper "healthy" sweep observed in the 2026-04-24
# run; a sweep that needs longer should be split into smaller audit
# passes rather than allowed to expand without bound.
sweep_max_session="${DVB_SWEEP_MAX:-$DVB_DEFAULT_SWEEP_MAX}"
max_zero_ship="${DVB_MAX_ZERO_SHIP:-$DVB_DEFAULT_MAX_ZERO_SHIP}"
sync_interval="${DVB_SYNC_INTERVAL:-$DVB_DEFAULT_SYNC_INTERVAL}"
max_instances="${DVB_MAX_INSTANCES:-$DVB_DEFAULT_MAX_INSTANCES}"
self_investigate_zero_ship_streak="${DVB_SELF_INVESTIGATE_ZERO_SHIP_STREAK:-$DVB_DEFAULT_SELF_INVESTIGATE_ZERO_SHIP_STREAK}"

# Validate numeric env vars
if ! [[ "$cooldown" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_COOL must be numeric (seconds between sessions, e.g. TG_COOL=5), got '$cooldown'. See 'taskgrind --help'." >&2; exit 1
fi
if ! [[ "$max_fast" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_MAX_FAST must be numeric, got '$max_fast'" >&2; exit 1
fi
if ! [[ "$max_session" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_MAX_SESSION must be numeric, got '$max_session'" >&2; exit 1
fi
if ! [[ "$sweep_max_session" =~ ^[0-9]+$ ]] || [[ "$sweep_max_session" -lt 1 ]]; then
  echo "Error: TG_SWEEP_MAX must be a positive integer (seconds), got '$sweep_max_session'" >&2; exit 1
fi
if ! [[ "$max_zero_ship" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_MAX_ZERO_SHIP must be numeric, got '$max_zero_ship'" >&2; exit 1
fi
if ! [[ "$self_investigate_zero_ship_streak" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_SELF_INVESTIGATE_ZERO_SHIP_STREAK must be numeric, got '$self_investigate_zero_ship_streak'" >&2; exit 1
fi
if ! [[ "$sync_interval" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_SYNC_INTERVAL must be numeric, got '$sync_interval'" >&2; exit 1
fi
if ! [[ "$max_instances" =~ ^[0-9]+$ ]] || [[ "$max_instances" -lt 1 ]]; then
  echo "Error: TG_MAX_INSTANCES must be a positive integer, got '$max_instances'" >&2; exit 1
fi
# Validate optional numeric env vars — these are used in arithmetic/sleep mid-loop
# and would crash with set -euo pipefail if non-numeric.
if [[ -n "${DVB_SHUTDOWN_GRACE:-}" ]] && ! [[ "${DVB_SHUTDOWN_GRACE}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_SHUTDOWN_GRACE must be numeric, got '${DVB_SHUTDOWN_GRACE}'" >&2; exit 1
fi
if [[ -n "${DVB_SESSION_GRACE:-}" ]] && ! [[ "${DVB_SESSION_GRACE}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_SESSION_GRACE must be numeric, got '${DVB_SESSION_GRACE}'" >&2; exit 1
fi
if [[ -n "${DVB_MIN_SESSION:-}" ]] && ! [[ "${DVB_MIN_SESSION}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_MIN_SESSION must be numeric, got '${DVB_MIN_SESSION}'" >&2; exit 1
fi
if [[ -n "${DVB_NET_WAIT:-}" ]] && ! [[ "${DVB_NET_WAIT}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_NET_WAIT must be numeric, got '${DVB_NET_WAIT}'" >&2; exit 1
fi
if [[ -n "${DVB_NET_MAX_WAIT:-}" ]] && ! [[ "${DVB_NET_MAX_WAIT}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_NET_MAX_WAIT must be numeric, got '${DVB_NET_MAX_WAIT}'" >&2; exit 1
fi
if [[ -n "${DVB_NET_RETRIES:-}" ]] && ! [[ "${DVB_NET_RETRIES}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_NET_RETRIES must be numeric, got '${DVB_NET_RETRIES}'" >&2; exit 1
fi
if [[ -n "${DVB_NET_RETRY_DELAY:-}" ]] && ! [[ "${DVB_NET_RETRY_DELAY}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_NET_RETRY_DELAY must be numeric, got '${DVB_NET_RETRY_DELAY}'" >&2; exit 1
fi
if [[ -n "${DVB_BACKOFF_BASE:-}" ]] && ! [[ "${DVB_BACKOFF_BASE}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_BACKOFF_BASE must be numeric, got '${DVB_BACKOFF_BASE}'" >&2; exit 1
fi
if [[ -n "${DVB_BACKOFF_MAX:-}" ]] && ! [[ "${DVB_BACKOFF_MAX}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_BACKOFF_MAX must be numeric, got '${DVB_BACKOFF_MAX}'" >&2; exit 1
fi
if [[ -n "${DVB_GIT_SYNC_TIMEOUT:-}" ]] && ! [[ "${DVB_GIT_SYNC_TIMEOUT}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_GIT_SYNC_TIMEOUT must be numeric, got '${DVB_GIT_SYNC_TIMEOUT}'" >&2; exit 1
fi
if [[ -n "${DVB_EMPTY_QUEUE_WAIT:-}" ]] && ! [[ "${DVB_EMPTY_QUEUE_WAIT}" =~ ^[0-9]+$ ]]; then
  echo "Error: TG_EMPTY_QUEUE_WAIT must be numeric, got '${DVB_EMPTY_QUEUE_WAIT}'" >&2; exit 1
fi
if [[ -n "${DVB_DEADLINE:-}" ]] && ! [[ "${DVB_DEADLINE}" =~ ^[0-9]+$ ]]; then
  echo "Error: DVB_DEADLINE must be a Unix epoch integer, got '${DVB_DEADLINE}'" >&2; exit 1
fi
# Validate boolean TG_* env vars — silent coercion ('yes', 'true', 'on') used
# to mean 'disabled' because only "1" was recognized. Reject anything that is
# not 0 or 1 up front so operators see the typo at startup.
if [[ -n "${DVB_EARLY_EXIT_ON_STALL:-}" ]] && ! [[ "${DVB_EARLY_EXIT_ON_STALL}" =~ ^[01]$ ]]; then
  echo "Error: TG_EARLY_EXIT_ON_STALL must be 0 or 1, got '${DVB_EARLY_EXIT_ON_STALL}'" >&2; exit 1
fi
if [[ -n "${DVB_EXIT_ON_STALL:-}" ]] && ! [[ "${DVB_EXIT_ON_STALL}" =~ ^[01]$ ]]; then
  echo "Error: TG_EXIT_ON_STALL must be 0 or 1, got '${DVB_EXIT_ON_STALL}'" >&2; exit 1
fi
if [[ -n "${DVB_NO_STALL_EXIT:-}" ]] && ! [[ "${DVB_NO_STALL_EXIT}" =~ ^[01]$ ]]; then
  echo "Error: TG_NO_STALL_EXIT must be 0 or 1, got '${DVB_NO_STALL_EXIT}'" >&2; exit 1
fi
if [[ -n "${DVB_NOTIFY:-}" ]] && ! [[ "${DVB_NOTIFY}" =~ ^[01]$ ]]; then
  echo "Error: TG_NOTIFY must be 0 or 1, got '${DVB_NOTIFY}'" >&2; exit 1
fi
if [[ -n "${DVB_NO_PUSH:-}" ]] && ! [[ "${DVB_NO_PUSH}" =~ ^[01]$ ]]; then
  echo "Error: TG_NO_PUSH must be 0 or 1, got '${DVB_NO_PUSH}'" >&2; exit 1
fi
if [[ -n "${TG_NO_PR_FALLBACK:-}" ]] && ! [[ "${TG_NO_PR_FALLBACK}" =~ ^[01]$ ]]; then
  echo "Error: TG_NO_PR_FALLBACK must be 0 or 1, got '${TG_NO_PR_FALLBACK}'" >&2; exit 1
fi
# Resolve no-push: CLI flag wins, then env var, then prompt-translated, default 0.
# When set, final_sync emits a `would_push` log line instead of pushing,
# and the session prompt's COMPLETION PROTOCOL forbids any publishing
# (no `git push`, no `gh pr create`, no `gh pr merge`). Operators review
# the local commits and push manually after the grind exits.
if [[ -n "$_cli_no_push" ]]; then
  no_push="$_cli_no_push"
elif [[ -n "${DVB_NO_PUSH:-}" ]]; then
  no_push="$DVB_NO_PUSH"
elif [[ -n "${_fp_no_push:-}" ]]; then
  no_push="$_fp_no_push"
else
  no_push="0"
fi
# Resolve no-pr-fallback: CLI flag wins, then env var, default 0 (PR fallback enabled).
# When 1, final_sync's protected-branch path skips the auto-PR step and falls through
# to manual recovery, matching today's behavior on push_failed but with an actionable
# error class. The PR fallback also requires `gh` on PATH and no_push != 1.
if [[ -n "$_cli_no_pr_fallback" ]]; then
  no_pr_fallback="$_cli_no_pr_fallback"
elif [[ -n "${TG_NO_PR_FALLBACK:-}" ]]; then
  no_pr_fallback="$TG_NO_PR_FALLBACK"
else
  no_pr_fallback="0"
fi

# Validate backend
case "$backend" in
  devin|claude-code|codex) ;;
  *) echo "Error: unknown backend '$backend'. Supported: devin, claude-code, codex (example: --backend devin or TG_BACKEND=claude-code). See 'taskgrind --help'." >&2; exit 1 ;;
esac

# Warn when codex backend uses a Claude model
if [[ "$backend" == "codex" && "$model" == *claude* ]]; then
  echo "Warning: TG_MODEL='$model' is an Anthropic model but backend is codex (OpenAI)." >&2
  echo "  Set TG_MODEL to an OpenAI model (e.g. o3, gpt-4o) or codex may reject it." >&2
fi

# Validate hours is a positive integer within range
if ! [[ "$hours" =~ ^[0-9]+$ ]] || [[ "$hours" -eq 0 ]]; then
  echo "Error: HOURS must be a positive integer" >&2; exit 1
fi
if [[ "$hours" -gt "$max_hours" ]]; then
  echo "Error: max $max_hours hours" >&2; exit 1
fi

# Validate repo exists
if [[ ! -d "$repo" ]]; then
  echo "Error: repo path does not exist: $repo. Pass a valid directory (example: 'taskgrind ~/apps/myrepo 8'). See 'taskgrind --help'." >&2; exit 1
fi

repo="$(cd "$repo" && pwd)"

# ── Workspace mode: resolve target repos ─────────────────────────────
# Precedence: explicit CLI flag > TG_/DVB_ env var > prompt-translated
# (`_fp_targets`) > empty (single-repo mode). Each path is resolved to an
# absolute path, deduped, and rejected if it equals the control repo.
_target_repos_raw=()
if [[ "$_cli_target_repos_set" -eq 1 ]]; then
  _target_repos_raw=("${_cli_target_repos_raw[@]}")
elif [[ -n "${DVB_TARGET_REPOS:-}" ]]; then
  IFS=':' read -r -a _target_repos_raw <<< "$DVB_TARGET_REPOS"
elif [[ -n "${_fp_targets:-}" ]]; then
  IFS=':' read -r -a _target_repos_raw <<< "$_fp_targets"
fi

# Note: ${arr[@]+"${arr[@]}"} (outer unquoted) is the bash 3.2-safe idiom for
# "expand the array, or nothing if it is empty/unset under set -u". Quoting
# the outer expansion would inject a phantom empty-string element into every
# for-loop on an empty array.
for _tg_path in ${_target_repos_raw[@]+"${_target_repos_raw[@]}"}; do
  [[ -z "$_tg_path" ]] && continue
  # Expand ~ manually — read -ra does not invoke shell tilde expansion.
  # shellcheck disable=SC2088  # tildes here are case-pattern literals, not paths
  case "$_tg_path" in
    "~") _tg_path="$HOME" ;;
    "~/"*) _tg_path="$HOME/${_tg_path#~/}" ;;
  esac
  if [[ ! -d "$_tg_path" ]]; then
    echo "Error: --target-repo path does not exist: $_tg_path. Pass a valid directory or remove the flag. See 'taskgrind --help'." >&2; exit 1
  fi
  _tg_abs="$(cd "$_tg_path" && pwd)"
  if [[ "$_tg_abs" == "$repo" ]]; then
    echo "Error: --target-repo $_tg_abs is the same as the control repo. Drop the redundant flag or run a single-repo grind. See 'taskgrind --help'." >&2; exit 1
  fi
  # Dedup — repeated entries (CLI typo or env-merge accidents) collapse so
  # downstream loops do not double-sync or double-push the same repo.
  _tg_seen=0
  for _tg_existing in ${target_repos[@]+"${target_repos[@]}"}; do
    if [[ "$_tg_existing" == "$_tg_abs" ]]; then
      _tg_seen=1
      break
    fi
  done
  if [[ "$_tg_seen" -eq 0 ]]; then
    target_repos+=("$_tg_abs")
  fi
done
unset _tg_path _tg_abs _tg_seen _tg_existing _target_repos_raw

# Joined `:`-delimited form used for env exports, status JSON, resume state,
# and log lines. Empty when there are no targets.
_targets_joined=""
for _tg in ${target_repos[@]+"${target_repos[@]}"}; do
  _targets_joined="${_targets_joined:+${_targets_joined}:}${_tg}"
done
unset _tg

state_file="${DVB_STATE_FILE:-$repo/$DVB_RESUME_STATE_BASENAME}"

state_deadline=""
state_session=""
state_tasks_shipped=""
state_sessions_zero_ship=""
state_consecutive_zero_ship=""
state_backend=""
state_skill=""
state_model=""
state_startup_model=""
state_startup_prompt=""
state_repo=""
state_status=""
state_version=""
state_no_push=""
state_targets=""
resume_loaded=0
resume_reason=""

load_resume_state() {
  [[ -f "$state_file" ]] || return 1
  while IFS='=' read -r key value; do
    case "$key" in
      version) state_version="$value" ;;
      repo) state_repo="$value" ;;
      status) state_status="$value" ;;
      deadline) state_deadline="$value" ;;
      session) state_session="$value" ;;
      tasks_shipped) state_tasks_shipped="$value" ;;
      sessions_zero_ship) state_sessions_zero_ship="$value" ;;
      consecutive_zero_ship) state_consecutive_zero_ship="$value" ;;
      backend) state_backend="$value" ;;
      skill) state_skill="$value" ;;
      model) state_model="$value" ;;
      startup_model) state_startup_model="$value" ;;
      startup_prompt) state_startup_prompt="$value" ;;
      no_push) state_no_push="$value" ;;
      targets) state_targets="$value" ;;
    esac
  done < "$state_file"
}

clear_resume_state() {
  rm -f "$state_file" 2>/dev/null || true
}

if [[ "$resume_run" -eq 1 ]]; then
  if ! load_resume_state; then
    echo "Error: no resume state found for $repo" >&2
    exit 1
  fi
  if [[ "$state_version" != "$DVB_RESUME_STATE_VERSION" ]]; then
    resume_reason="version mismatch"
  elif [[ "$state_repo" != "$repo" ]]; then
    resume_reason="repo mismatch"
  elif [[ "$state_status" != "running" ]]; then
    resume_reason="state is not resumable (status=$state_status)"
  elif ! [[ "$state_deadline" =~ ^[0-9]+$ && "$state_session" =~ ^[0-9]+$ && "$state_tasks_shipped" =~ ^[0-9]+$ && "$state_sessions_zero_ship" =~ ^[0-9]+$ && "$state_consecutive_zero_ship" =~ ^[0-9]+$ ]]; then
    resume_reason="state file is malformed"
  elif [[ "$state_deadline" -le "$(date +%s)" ]]; then
    resume_reason="deadline expired"
  elif [[ -n "$_cli_backend" && "$requested_backend" != "$state_backend" ]]; then
    resume_reason="backend override does not match saved state"
  elif [[ -n "$_cli_model" && "$requested_model" != "$state_model" ]]; then
    resume_reason="model override does not match saved state"
  elif [[ -n "$_cli_prompt" && "$_cli_prompt" != "$state_startup_prompt" ]]; then
    resume_reason="prompt override does not match saved state"
  elif [[ "$skill" != "$state_skill" ]]; then
    resume_reason="skill does not match saved state"
  fi
  # Workspace mode: target list must match. If the resume CLI passed --target-repo
  # explicitly, the resolved list (in $_targets_joined) must match the saved
  # state. If no --target-repo / TG_TARGET_REPOS was passed, we restore the
  # saved list. This mirrors the no_push restore semantics: explicit override
  # wins, otherwise saved value wins.
  if [[ -z "$resume_reason" ]] && [[ "$_cli_target_repos_set" -eq 1 || -n "${DVB_TARGET_REPOS:-}" ]]; then
    if [[ "$_targets_joined" != "$state_targets" ]]; then
      resume_reason="target repos do not match saved state (saved=$state_targets, requested=$_targets_joined)"
    fi
  fi
  if [[ -n "$resume_reason" ]]; then
    echo "Error: cannot resume $repo — saved state is incompatible: $resume_reason" >&2
    if [[ "$resume_reason" == "deadline expired" ]]; then
      echo "start a fresh grind instead: taskgrind $repo" >&2
    fi
    exit 1
  fi
  deadline="$state_deadline"
  model="$state_model"
  backend="$state_backend"
  skill="$state_skill"
  _startup_model="${state_startup_model:-$state_model}"
  _cli_prompt="$state_startup_prompt"
  # Preserve no-publish across resume. Explicit --no-push on the resume
  # CLI overrides; otherwise the saved value wins. Older state files
  # without a no_push field are treated as no_push=0 (the prior default).
  if [[ -z "$_cli_no_push" && "$state_no_push" =~ ^[01]$ ]]; then
    no_push="$state_no_push"
  fi
  # Restore target repos from saved state when the resume CLI did not supply
  # them. Saved targets are colon-separated absolute paths.
  if [[ "$_cli_target_repos_set" -eq 0 && -z "${DVB_TARGET_REPOS:-}" && -n "$state_targets" ]]; then
    target_repos=()
    IFS=':' read -r -a target_repos <<< "$state_targets"
    _targets_joined="$state_targets"
  fi
  resume_loaded=1
fi

# ── Dynamic prompt file ──────────────────────────────────────────────
# Users can create/edit $repo/.taskgrind-prompt while taskgrind runs.
# Content is re-read before each session and combined with --prompt.
_prompt_file="$repo/.taskgrind-prompt"

# Rebuild extra_prompt from CLI prompt + prompt file content.
# Call before each session to pick up live edits.
# Guards: skips files > 10KB (likely accidental), strips all trailing whitespace.
_prompt_file_max=10240  # 10KB — prompts should be short
_refresh_prompt() {
  local file_prompt=""
  if [[ -f "$_prompt_file" ]]; then
    local file_size
    file_prompt=$(cat "$_prompt_file" 2>/dev/null) || file_prompt=""
    file_size=$(printf '%s' "$file_prompt" | wc -c 2>/dev/null) || file_size=0
    file_size="${file_size## }"  # trim leading space (macOS wc)
    if [[ "$file_size" -gt "$_prompt_file_max" ]]; then
      echo "   ⚠ .taskgrind-prompt too large (${file_size}B > ${_prompt_file_max}B) — skipping" >&2
      file_prompt=""
    fi
    # Strip all trailing whitespace (newlines, spaces, tabs)
    while [[ "$file_prompt" =~ [[:space:]]$ ]]; do
      file_prompt="${file_prompt%?}"
    done
  fi
  if [[ -n "$_cli_prompt" && -n "$file_prompt" ]]; then
    extra_prompt="$_cli_prompt LIVE_PROMPT: $file_prompt"
  elif [[ -n "$file_prompt" ]]; then
    extra_prompt="$file_prompt"
  else
    extra_prompt="$_cli_prompt"
  fi
}
_refresh_prompt

# ── Dynamic model file ───────────────────────────────────────────────
# Users can create/edit $repo/.taskgrind-model while taskgrind runs.
# Content is re-read before each session and overrides --model / TG_MODEL.
# Deleting the file reverts to the original startup model.
_model_file="$repo/.taskgrind-model"
if [[ "$resume_loaded" -ne 1 ]]; then
  _startup_model="$model"  # preserve original for revert on file deletion
fi

# Re-read model from file. Call before each session to pick up live edits.
# Guards: skips files > 1KB (likely accidental), strips trailing whitespace.
_model_file_max=1024  # 1KB — model names are short
_model_alias=""
_refresh_model() {
  local file_model=""
  _model_alias=""
  if [[ -f "$_model_file" ]]; then
    local file_size
    file_size=$(wc -c < "$_model_file" 2>/dev/null) || file_size=0
    file_size="${file_size## }"  # trim leading space (macOS wc)
    if [[ "$file_size" -gt "$_model_file_max" ]]; then
      echo "   ⚠ .taskgrind-model too large (${file_size}B > ${_model_file_max}B) — skipping" >&2
    else
      file_model=$(cat "$_model_file" 2>/dev/null) || true
    fi
    # Strip all trailing whitespace (newlines, spaces, tabs)
    while [[ "$file_model" =~ [[:space:]]$ ]]; do
      file_model="${file_model%?}"
    done
  fi
  if [[ -n "$file_model" ]]; then
    model="$(dvb_resolve_model_alias "$file_model")"
    if [[ "$model" != "$file_model" ]]; then
      _model_alias="$file_model"
    fi
  else
    model="$_startup_model"
  fi
}
_refresh_model

model_context_profile() {
  case "$model" in
    *opus-4-7*|*opus-4.7*|*opus*1m*|*opus*1M*) printf '%s' "large" ;;
    *) printf '%s' "standard" ;;
  esac
}

fleet_context_guard() {
  local profile
  case "$skill" in
    fleet-grind) ;;
    *) return 0 ;;
  esac
  profile="$(model_context_profile)"
  if [[ "$profile" == "large" ]]; then
    printf '%s' "CONTEXT_BUDGET: Model profile large. You have more headroom than the GPT-5.5 standard profile, but still checkpoint via commits and notes before broadening scope; prefer a clean session boundary over filling context."
  else
    printf '%s' "CONTEXT_BUDGET: Model profile standard. Keep this fleet-grind session to one merge/fill/fix cycle and at most one narrow sweep. Avoid broad history reads unless required. Commit notes/TASKS changes before expanding scope. Exit cleanly before context grows instead of trying to finish every phase."
  fi
}

net_check_url="${DVB_NET_CHECK_URL:-https://connectivitycheck.gstatic.com/generate_204}"

# ── Network check functions ──────────────────────────────────────────
# Defined early so preflight_check() can reuse them (instead of a bare curl).

_check_network_once() {
  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    # Test mode: network state controlled by sentinel file. Optional counter
    # mode (`DVB_NET_FLIP_AFTER=N` + `DVB_NET_FILE=<path>`) returns false for
    # the first N calls and true on every call after, with the call counter
    # persisted in `$DVB_NET_FILE`. Counter mode lets recovery tests drive
    # `wait_for_network` deterministically without a wall-clock race against
    # parallel-load test setup overhead — under 8 bats workers, a `nohup
    # sleep 2 && touch` would routinely fire before taskgrind even reached
    # the first network check, leaving `wait_for_network` unentered.
    if [[ -n "${DVB_NET_FLIP_AFTER:-}" && -n "${DVB_NET_FILE:-}" ]]; then
      local _net_count
      _net_count=$(cat "$DVB_NET_FILE" 2>/dev/null || echo 0)
      _net_count=$((_net_count + 1))
      echo "$_net_count" > "$DVB_NET_FILE"
      [[ "$_net_count" -gt "$DVB_NET_FLIP_AFTER" ]]
    else
      [[ -f "${DVB_NET_FILE:-/dev/null}" ]]
    fi
  elif command -v network-watchdog >/dev/null 2>&1; then
    network-watchdog --check-only >/dev/null 2>&1
  else
    # Fallback: lightweight connectivity test when network-watchdog is missing
    curl -sf --max-time 5 "$net_check_url" >/dev/null 2>&1
  fi
}

# Retry wrapper — a single transient DNS hiccup should not pause the marathon.
# Checks up to 3 times with 2s delays before declaring network down.
# Test mode skips retries (instant pass/fail from sentinel file).
check_network() {
  local retries="${DVB_NET_RETRIES:-$DVB_DEFAULT_NET_RETRIES}"
  local delay="${DVB_NET_RETRY_DELAY:-$DVB_DEFAULT_NET_RETRY_DELAY}"
  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    _check_network_once; return $?
  fi
  local attempt
  for (( attempt=1; attempt<=retries; attempt++ )); do
    _check_network_once && return 0
    [[ $attempt -lt $retries ]] && sleep "$delay"
  done
  return 1
}

# ── Backend session args builder ──────────────────────────────────────
# Builds the CLI argument array for the configured backend.
# Sets the global _session_args array.
# Usage: build_session_args "$prompt"; "${devin_cmd[@]}" "${_session_args[@]}"
_session_args=()
build_session_args() {
  local prompt="$1"
  case "$backend" in
    devin)
      _session_args=(--model "$model" --permission-mode dangerous -p "$prompt")
      ;;
    claude-code)
      _session_args=(--model "$model" --dangerously-skip-permissions -p "$prompt")
      ;;
    codex)
      _session_args=(--model "$model" -q "$prompt")
      ;;
  esac
}

backend_binary_name() {
  case "$1" in
    devin) printf '%s' "devin" ;;
    claude-code) printf '%s' "claude" ;;
    codex) printf '%s' "codex" ;;
    *) printf '%s' "$1" ;;
  esac
}

backend_install_hint() {
  case "$1" in
    devin)
      printf '%s' "Install the Devin CLI, ensure 'devin' is executable and on PATH, or set TG_DEVIN_PATH to an executable custom path. See README.md 'Install' for setup steps."
      ;;
    claude-code)
      printf '%s' "Install Claude Code with 'npm install -g @anthropic-ai/claude-code', then ensure the 'claude' binary is executable and on PATH. See README.md 'Install' for setup steps."
      ;;
    codex)
      printf '%s' "Install Codex with 'npm install -g @openai/codex', then ensure the 'codex' binary is executable and on PATH. See README.md 'Install' for setup steps."
      ;;
    *)
      printf '%s' "Install the selected backend CLI and ensure it is executable and on PATH."
      ;;
  esac
}

backend_binary_error() {
  local binary_name hint
  binary_name="$(backend_binary_name "$backend")"
  hint="$(backend_install_hint "$backend")"
  if [[ -n "${_backend_binary:-}" && -e "$_backend_binary" && ! -x "$_backend_binary" ]]; then
    printf 'Backend binary is not executable (%s): %s. %s' "$backend" "$_backend_binary" "$hint"
  elif [[ -n "${_backend_binary:-}" ]]; then
    printf "Backend binary not found (%s): expected '%s' on PATH; looked at %s. %s" "$backend" "$binary_name" "$_backend_binary" "$hint"
  else
    printf "Backend binary not found (%s): expected '%s' on PATH. %s" "$backend" "$binary_name" "$hint"
  fi
}

backend_model_hint() {
  case "$1" in
    devin)
      printf '%s' "Check the model name with 'devin --model <name> --help' for this Devin install."
      ;;
    claude-code)
      printf '%s' "Check that the Claude model is available to this Claude Code install and account with 'claude --model <name> --help'."
      ;;
    codex)
      printf '%s' "Check the OpenAI model name with 'codex --model <name> --help'; Codex usually expects models such as o3 or gpt-5.5."
      ;;
    *)
      printf '%s' "Check the selected model with the backend CLI before retrying."
      ;;
  esac
}

backend_probe_hint() {
  case "$1" in
    devin)
      printf '%s' "reinstall or roll back the Devin CLI before starting another grind."
      ;;
    claude-code)
      printf '%s' "Reinstall Claude Code with 'npm install -g @anthropic-ai/claude-code' and confirm 'claude --version' prints output before retrying."
      ;;
    codex)
      printf '%s' "Reinstall Codex with 'npm install -g @openai/codex' and confirm 'codex --version' prints output before retrying."
      ;;
    *)
      printf '%s' "Reinstall or roll back the backend CLI before starting another grind."
      ;;
  esac
}

_backend_probe_error=""
_backend_probe_summary=""

run_backend_probe() {
  local probe_start probe_output probe_status probe_elapsed probe_output_clean

  _backend_probe_error=""
  _backend_probe_summary=""

  probe_start=$(date +%s)
  probe_output=$("${devin_cmd[@]}" --version 2>&1) || probe_status=$?
  probe_status=${probe_status:-0}
  probe_elapsed=$(( $(date +%s) - probe_start ))
  probe_output_clean=$(printf '%s\n' "$probe_output" | sed '/^[[:space:]]*$/d')

  # Stub detection: exit=0 with no output on --version means the binary
  # is a no-op shim (the previous "… and probe took <1s" heuristic was
  # removed because it produced false negatives under load — a genuinely
  # broken stub can still take >=1s to start when the system is busy,
  # making parallel-suite runs silently accept broken backends).
  if [[ "$probe_status" -eq 0 && -z "$probe_output_clean" ]]; then
    _backend_probe_summary="backend_probe_failed exit=$probe_status duration=${probe_elapsed}s backend=$backend"
    _backend_probe_error="backend binary may be a stub or broken: '$backend' exited in ${probe_elapsed}s with no output when running --version. $(backend_probe_hint "$backend")"
    return 1
  fi

  _backend_probe_summary="backend_probe_ok exit=$probe_status duration=${probe_elapsed}s backend=$backend"
  return 0
}

_model_validation_error=""
_test_backend_error=""
_resolved_test_backend_cmd=()

resolve_test_backend_command() {
  local requested_cmd="${DVB_GRIND_CMD:-}"
  local resolved_cmd=""
  local fallback_name=""

  _test_backend_error=""
  _resolved_test_backend_cmd=()

  if [[ -z "$requested_cmd" ]]; then
    _test_backend_error="Test backend command is empty"
    return 1
  fi

  if [[ "$requested_cmd" =~ [[:space:]] ]]; then
    _test_backend_error="Test backend command must be a single executable path; wrap complex commands in a helper script: $requested_cmd"
    return 1
  fi

  if [[ "$requested_cmd" == */* ]]; then
    if [[ -x "$requested_cmd" ]]; then
      resolved_cmd="$requested_cmd"
    else
      fallback_name="${requested_cmd##*/}"
      resolved_cmd=$(type -P "$fallback_name" 2>/dev/null || true)
    fi
  else
    resolved_cmd=$(type -P "$requested_cmd" 2>/dev/null || true)
  fi

  if [[ -z "$resolved_cmd" || ! -x "$resolved_cmd" ]]; then
    _test_backend_error="Test backend command is not executable: $requested_cmd"
    return 1
  fi

  _resolved_test_backend_cmd=("$resolved_cmd")
}

validate_model() {
  local validation_cmd=()
  local validation_output=""
  local validation_status=0

  _model_validation_error=""
  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    if ! resolve_test_backend_command; then
      _model_validation_error="$_test_backend_error"
      return 1
    fi
    validation_cmd=("${_resolved_test_backend_cmd[@]}")
  else
    resolve_backend_binary
    validation_cmd=("$_backend_binary")
  fi

  validation_output=$("${validation_cmd[@]}" --model "$model" --help 2>&1) || validation_status=$?
  if [[ "$validation_status" -eq 0 ]]; then
    return 0
  fi

  _model_validation_error=$(printf '%s\n' "$validation_output" | sed '/^[[:space:]]*$/d' | head -5)
  return 1
}

# Resolve the backend binary path for the configured backend.
# Returns the path in _backend_binary. Used by preflight and binary resolution.
_backend_binary=""
resolve_backend_binary() {
  case "$backend" in
    devin) _backend_binary="$DVB_DEVIN_PATH" ;;
    claude-code) _backend_binary=$(command -v claude 2>/dev/null || echo "") ;;
    codex) _backend_binary=$(command -v codex 2>/dev/null || echo "") ;;
  esac
}

# ── Mid-flight backend rotation ──────────────────────────────────────
# Scan the just-completed session's output for rate-limit / quota / throttle
# patterns. If a pattern matches, advance the rotation cursor to the next
# backend in the list and re-resolve `devin_cmd` so the next session launches
# with a different backend. Patterns mirror the bosun BackendHealthService
# RATE_LIMIT_PATTERNS list (kept in sync — if bosun adds a pattern we want to
# react here too).
#
# Idempotent: when the rotation list is empty this is a no-op.
# Safe: if the next backend's binary cannot be found, reverts to the previous
# backend and logs a warning — never leaves the run in an unrunnable state.
# (`_rotation_backends` array + `_current_rotation_index` are initialized
# above at the same place backend/model are resolved from CLI/env.)
_maybe_rotate_backend() {
  local session_output_path="$1"
  local trigger_reason="${2:-rate_limit}"
  if [[ ${#_rotation_backends[@]} -le 1 ]]; then
    return 0
  fi
  # Pattern-based triggers (rate_limit) require an output file to scan.
  # Structural triggers (zero_ship_streak, …) skip the pattern check —
  # they fire on accumulated state, not on session-output content.
  if [[ "$trigger_reason" == "rate_limit" ]]; then
    if [[ ! -s "$session_output_path" ]]; then
      return 0
    fi
    if ! grep -qiE 'rate.?limit|429|too many requests|hit your limit|limit . resets|quota.?exceed|throttl|usage limit|out of usage' "$session_output_path" 2>/dev/null; then
      return 0
    fi
  fi

  local prev_backend="$backend"
  local prev_index="$_current_rotation_index"
  local next_index=$(( (_current_rotation_index + 1) % ${#_rotation_backends[@]} ))
  local next_backend="${_rotation_backends[$next_index]}"

  if [[ "$next_backend" == "$prev_backend" ]]; then
    # Single-element rotation list (or all entries identical) — nothing to swap to.
    return 0
  fi

  backend="$next_backend"
  resolve_backend_binary
  if [[ -z "$_backend_binary" || ! -x "$_backend_binary" ]]; then
    echo "   ⚠ Backend rotation $prev_backend → $next_backend skipped: binary not executable. Staying on $prev_backend."
    log_write "[$(date '+%H:%M')] backend_rotation_skipped from=$prev_backend to=$next_backend reason=binary_missing"
    backend="$prev_backend"
    _current_rotation_index="$prev_index"
    return 1
  fi

  devin_cmd=("$_backend_binary")
  _current_rotation_index="$next_index"
  echo "   ⤷ Backend rotated: $prev_backend → $next_backend (reason: $trigger_reason)"
  log_write "[$(date '+%H:%M')] backend_rotated from=$prev_backend to=$next_backend reason=$trigger_reason index=$next_index"
  return 0
}

# ── Self-investigation hook ──────────────────────────────────────────
# After each session, look for "things are off" patterns that warrant action
# beyond the rate-limit detector. The user's framing: bosun+taskgrind should
# investigate their own issues mid-run and fix on the way. Patterns we surface
# so far:
#
#   1. consecutive_zero_ship >= TG_SELF_INVESTIGATE_ZERO_SHIP_STREAK (default 3)
#      — the active backend is producing output but not shipping. May not
#      contain a rate-limit phrase, but it is structurally stuck. If a
#      rotation list is available, rotate. Otherwise just log.
#   2. session_exit non-zero AND the last 3 sessions also had non-zero exits
#      — backend is crashing systematically. Same response: rotate if possible.
#
# Logs every detection (whether or not it acts) so an external observer
# (bosun grind dashboard, post-mortem scripts) can see what was tried.
_maybe_self_investigate() {
  local _zero_ship_streak_threshold="$self_investigate_zero_ship_streak"

  if [[ "$consecutive_zero_ship" -ge "$_zero_ship_streak_threshold" ]]; then
    log_write "[$(date '+%H:%M')] self_investigate anomaly=zero_ship_streak streak=$consecutive_zero_ship threshold=$_zero_ship_streak_threshold backend=$backend"
    if [[ ${#_rotation_backends[@]} -gt 1 ]]; then
      echo "   ↺ Self-investigation: $consecutive_zero_ship sessions shipped 0 — trying backend rotation."
      _maybe_rotate_backend "" "zero_ship_streak" || true
    else
      echo "   ⚠ Self-investigation: $consecutive_zero_ship sessions shipped 0 — no rotation list available (install another backend or set TG_ROTATE_BACKENDS)."
    fi
  fi
}

# ── Preflight health checks ──────────────────────────────────────────
# Validates the runtime environment before entering the main loop.
# Returns 0 if all checks pass (or only warns), 1 if any check fails.
# Output follows the dotfiles-doctor pattern: ✓ pass / ⚠ warn / ✗ fail.
_pf_pass=0
_pf_warn=0
_pf_fail=0

preflight_pass()  { echo "  ✓ $1"; _pf_pass=$((_pf_pass + 1)); }
preflight_warn()  { echo "  ⚠ $1"; _pf_warn=$((_pf_warn + 1)); }
preflight_fail()  { echo "  ✗ $1"; _pf_fail=$((_pf_fail + 1)); }

# _preflight_check_remote_reachable <repo> <unreachable_warning_text>
#
# Probe `git ls-remote origin HEAD` for <repo> with a 10-second cap and
# emit a preflight pass/warn line. Uses git's own
# GIT_HTTP_LOW_SPEED_LIMIT / GIT_HTTP_LOW_SPEED_TIME knobs so the timeout
# is enforced inside git itself — no shell-level watchdog.
#
# Why no shell watchdog: the previous implementation forked a sleep
# subshell and `wait`ed on it as a sibling pid, which works on bash 4+
# (Linux) but returns 127 immediately on macOS /bin/bash 3.2 (which
# refuses `wait` on non-children). The watchdog then SIGTERMed
# git ls-remote milliseconds after fork and the outer wait returned
# 143, firing the "Git remote unreachable" warning unconditionally on
# every macOS run regardless of actual network state. The repo's
# bash 3.2 compatibility guard is deliberate (see AGENTS.md), so the
# fix is to drop the broken pattern and let git enforce the timeout.
_preflight_check_remote_reachable() {
  local repo="$1" unreachable_msg="$2"
  if GIT_HTTP_LOW_SPEED_LIMIT=1 GIT_HTTP_LOW_SPEED_TIME=10 \
      git -C "$repo" ls-remote origin HEAD >/dev/null 2>&1; then
    dvb_spinner_stop; preflight_pass "Git remote reachable"
  else
    dvb_spinner_stop; preflight_warn "$unreachable_msg"
  fi
}

# ── Bosun-server preflight ─────────────────────────────────────────────
# When the configured skill drives bosun pipelines (fleet-grind, pipeline-ops,
# rescue-pipeline, …), the agent will fail every session if the bosun server
# isn't reachable: it can launch zero pipelines, so it falls into either direct
# commits (now blocked by the pre-commit hook AIFN-720) or zero-ship streaks.
# Cheaper to fail fast at preflight than to burn an hour of agent compute
# discovering bosun is dead.
#
# Detects "bosun-dependent" by skill name pattern. Conservative — adds known
# skills from `skill-plugins/orchestrator/` and the user's repo workflow. New
# bosun-dependent skills should be added here when introduced.
_skill_needs_bosun() {
  # Skills that REQUIRE bosun pipelines to do meaningful work. Agent inside
  # the session calls `POST /api/v1/pipelines/...` and observes the result.
  # Skills not in this list (next-task, audit-error-handling, refactor, …)
  # work the agent directly on files; they don't need bosun running.
  case "$skill" in
    fleet-grind|full-sweep|bosun|bosun-revive|inspect-and-heal-pipelines|\
    pipeline-ops|rescue-pipeline|run-healthy-pipelines)
      return 0 ;;
    pipeline-*|*-pipeline-ops|*bosun*)
      return 0 ;;
    *)
      return 1 ;;
  esac
}

_skill_search_paths=()
_skill_validation_path=""
_skill_validation_error=""

_add_skill_search_path() {
  local path="$1"
  local existing
  [[ -n "$path" ]] || return 0
  for existing in ${_skill_search_paths[@]+"${_skill_search_paths[@]}"}; do
    [[ "$existing" == "$path" ]] && return 0
  done
  _skill_search_paths+=("$path")
}

_build_skill_search_paths() {
  local channel_dir
  _skill_search_paths=()
  case "$backend" in
    devin)
      _add_skill_search_path "$repo/.agents/skills"
      _add_skill_search_path "$repo/.devin/skills"
      _add_skill_search_path "$repo/.windsurf/skills"
      if [[ -n "${HOME:-}" ]]; then
        _add_skill_search_path "$HOME/.agents/skills"
        _add_skill_search_path "$HOME/.config/devin/skills"
        _add_skill_search_path "$HOME/.codeium/windsurf/skills"
        _add_skill_search_path "$HOME/.codeium/windsurf-next/skills"
        _add_skill_search_path "$HOME/.codeium/windsurf-insiders/skills"
        for channel_dir in "$HOME"/.codeium/*/skills; do
          [[ -d "$channel_dir" ]] && _add_skill_search_path "$channel_dir"
        done
      fi
      ;;
    claude-code)
      _add_skill_search_path "$repo/.agents/skills"
      _add_skill_search_path "$repo/.claude/skills"
      if [[ -n "${HOME:-}" ]]; then
        _add_skill_search_path "$HOME/.agents/skills"
        _add_skill_search_path "$HOME/.claude/skills"
      fi
      ;;
    codex)
      _add_skill_search_path "$repo/.agents/skills"
      _add_skill_search_path "$repo/.codex/skills"
      if [[ -n "${HOME:-}" ]]; then
        _add_skill_search_path "$HOME/.agents/skills"
        _add_skill_search_path "$HOME/.codex/skills"
      fi
      ;;
  esac
}

_validate_skill_available() {
  local root checked
  _skill_validation_path=""
  _skill_validation_error=""
  _build_skill_search_paths
  for root in ${_skill_search_paths[@]+"${_skill_search_paths[@]}"}; do
    if [[ -f "$root/$skill/SKILL.md" ]]; then
      _skill_validation_path="$root/$skill/SKILL.md"
      return 0
    fi
  done
  checked=""
  for root in ${_skill_search_paths[@]+"${_skill_search_paths[@]}"}; do
    checked="${checked}${checked:+, }$root/$skill/SKILL.md"
  done
  _skill_validation_error="Requested skill '$skill' is not visible to backend '$backend'. Install or sync it before starting (for example: agentbrew sync), or add $skill/SKILL.md under a backend skill root. Checked: $checked"
  return 1
}

# Probe `${BOSUN_API_BASE}/api/v1/ready` (no auth required for readiness).
# Sets `_bosun_health_status` to one of: ready | not-ready | unreachable.
# Sets `_bosun_health_detail` to a human-readable explanation for warnings.
_bosun_health_status=""
_bosun_health_detail=""
_check_bosun_health() {
  _bosun_health_status="unreachable"
  _bosun_health_detail=""
  local base="${BOSUN_API_BASE:-http://localhost:9746}"
  base="${base%/}"
  local body http_status
  if ! body=$(curl -sf --max-time 5 -o - -w '\n%{http_code}' "${base}/api/v1/ready" 2>/dev/null); then
    _bosun_health_detail="${base}/api/v1/ready not reachable (curl exit ${?:-?})"
    return 1
  fi
  http_status="${body##*$'\n'}"
  body="${body%$'\n'*}"
  if [[ "$http_status" != "200" ]]; then
    _bosun_health_status="not-ready"
    _bosun_health_detail="HTTP $http_status from ${base}/api/v1/ready"
    return 1
  fi
  if echo "$body" | grep -q '"ready":true'; then
    _bosun_health_status="ready"
    return 0
  fi
  _bosun_health_status="not-ready"
  _bosun_health_detail="response did not contain 'ready:true' — body: $(echo "$body" | head -c 120)"
  return 1
}

# Verify the target repo enforces Bosun's Iron Rule 7 pre-commit gate.
#
# Bosun-dependent skills (fleet-grind, pipeline-ops, …) rely on the target
# repo's hooks/pre-commit to block direct non-markdown commits while a
# fleet-grind session is active. Two failure shapes silently disable that:
#   1. core.hooksPath = /dev/null in the target repo's local config — Git
#      skips hooks entirely. This is the May 2026 readiness-inspection shape:
#      a stray test command leaked /dev/null into the bosun checkout's
#      .git/config and `git hook run pre-commit` reported "cannot find a hook
#      named pre-commit" even though hooks/pre-commit existed.
#   2. core.hooksPath points at a sibling dir (e.g. ~/apps/dotfiles/git-hooks)
#      that does not carry Iron Rule 7 logic — hooks fire but the rule does not.
# Both shapes leave taskgrind's end-of-session anomaly detection as the only
# layer of defence; that's a reactive gate, not a preventive one. Detect at
# preflight and fail with an actionable fix message.
#
# Conditional: only enforced when the target repo SHIPS Iron Rule 7 (i.e.
# hooks/pre-commit exists with a BOSUN_GRIND_SESSION_ID marker). Other repos
# may legitimately not carry the hook.
_bosun_hook_enforcement_status=""
_bosun_hook_enforcement_detail=""
_check_bosun_pipeline_only_enforcement() {
  local target="${1:-$repo}"
  _bosun_hook_enforcement_status=""
  _bosun_hook_enforcement_detail=""

  if ! git -C "$target" rev-parse --git-dir >/dev/null 2>&1; then
    _bosun_hook_enforcement_status="not-applicable"
    return 0
  fi

  local bosun_hook="$target/hooks/pre-commit"
  if [[ ! -f "$bosun_hook" ]] || ! grep -q 'BOSUN_GRIND_SESSION_ID' "$bosun_hook" 2>/dev/null; then
    _bosun_hook_enforcement_status="not-applicable"
    return 0
  fi

  local effective
  effective=$(git -C "$target" config --get core.hooksPath 2>/dev/null || true)
  local fix_hint="Run: git -C \"$target\" config core.hooksPath hooks  (or run bosun's bin/doctor --fix from the bosun repo)."

  if [[ "$effective" == "/dev/null" ]]; then
    _bosun_hook_enforcement_status="disabled"
    _bosun_hook_enforcement_detail="core.hooksPath in $target resolves to /dev/null — Iron Rule 7 will not fire. ${fix_hint}"
    return 1
  fi

  local hook_run_output
  hook_run_output=$(cd "$target" && git hook run pre-commit 2>&1) || true
  if printf '%s' "$hook_run_output" | grep -q 'cannot find a hook named pre-commit'; then
    _bosun_hook_enforcement_status="missing"
    _bosun_hook_enforcement_detail="git hook run pre-commit in $target reports the hook is missing — Iron Rule 7 will not fire. ${fix_hint}"
    return 1
  fi

  local resolved_hook
  if [[ -n "$effective" ]]; then
    if [[ "$effective" = /* ]]; then
      resolved_hook="$effective/pre-commit"
    else
      resolved_hook="$target/$effective/pre-commit"
    fi
  else
    resolved_hook="$target/.git/hooks/pre-commit"
  fi
  if [[ ! -f "$resolved_hook" ]]; then
    _bosun_hook_enforcement_status="missing"
    _bosun_hook_enforcement_detail="effective pre-commit at $resolved_hook does not exist — Iron Rule 7 will not fire. ${fix_hint}"
    return 1
  fi
  # Direct match: the effective hook is Bosun's hook (carries the marker).
  # Indirect match: the effective hook is the simple-git-hooks stub that
  # delegates to ./hooks/pre-commit (which we've already verified carries
  # the marker via the bosun_hook check above).
  if grep -q 'BOSUN_GRIND_SESSION_ID' "$resolved_hook" 2>/dev/null \
      || grep -q 'hooks/pre-commit' "$resolved_hook" 2>/dev/null; then
    _bosun_hook_enforcement_status="active"
    return 0
  fi
  _bosun_hook_enforcement_status="bypassed"
  _bosun_hook_enforcement_detail="effective pre-commit at $resolved_hook does not invoke Bosun's hooks/pre-commit — Iron Rule 7 will not fire. ${fix_hint}"
  return 1
}

# Pipeline-rate cross-check (companion to bosun PR #1554/1555).
#
# The Apr 28-29 incident shape: agent direct-committed code in fleet-grind
# sessions instead of going through bosun pipelines. Bosun PRs #1548/1554/1555
# closed the bypass at commit-time / push-time inside the bosun repo, but
# taskgrind itself can also independently verify the relationship between
# "tasks shipped this session" and "pipelines completed in bosun" — if the
# numbers diverge, log the anomaly and file a task for investigation.
#
# Lifecycle:
#   - _capture_pipeline_baseline runs at preflight (when skill needs bosun
#     and bosun is healthy). Records pipeline count + start time to a temp
#     file scoped to the lock hash.
#   - _verify_pipeline_completion_rate runs at cleanup. Reads baseline,
#     queries current count, computes delta. Flags when tasks_shipped > 0
#     AND pipeline_delta == 0 (the Apr 28-29 shape).
#
# If the session ships tasks while Bosun reports zero pipeline delta, the
# verification files a diagnostic task and marks the grind failed. Curl/jq
# failures still degrade to count=0 so the suspicious shape hard-stops instead
# of becoming an advisory-only warning.
_pipeline_baseline_file=""
_pipeline_baseline_refs_file=""
_pipeline_verify_failed=0
_bosun_grind_error=""
# Lifecycle state for the Bosun grind session. _bosun_grind_owned=1 means
# THIS Taskgrind process called `bosun grind register` and is therefore
# responsible for posting heartbeats AND for `bosun grind done` on exit.
# Caller-provided sessions (BOSUN_GRIND_SESSION_ID already exported by the
# operator before invoking taskgrind) are heartbeated while we run, but
# we never deregister them — the caller owns the slot.
_bosun_grind_owned=0
_bosun_heartbeat_pid=0
_bosun_heartbeat_interval="${TG_BOSUN_HEARTBEAT_INTERVAL:-${DVB_BOSUN_HEARTBEAT_INTERVAL:-60}}"
_bosun_grind_done_called=0
# Default reason is "completed" — the signal handlers and the EXIT trap
# downgrade this to "aborted" before cleanup() reads it.
_bosun_grind_done_reason="completed"

_resolve_bosun_cli() {
  if [[ -n "${BOSUN_BIN:-}" && -x "$BOSUN_BIN" ]]; then
    echo "$BOSUN_BIN"
    return 0
  fi
  if command -v bosun >/dev/null 2>&1; then
    command -v bosun
    return 0
  fi
  if [[ -x "$repo/bin/bosun" ]]; then
    echo "$repo/bin/bosun"
    return 0
  fi
  if [[ -n "${HOME:-}" && -x "$HOME/apps/bosun/bin/bosun" ]]; then
    echo "$HOME/apps/bosun/bin/bosun"
    return 0
  fi
  return 1
}

_source_bosun_grind_env() {
  local env_file="$1"
  [[ -f "$env_file" ]] || return 1
  # shellcheck disable=SC1090
  . "$env_file"
  [[ -n "${BOSUN_GRIND_SESSION_ID:-}" ]] || return 1
  export BOSUN_GRIND_SESSION_ID
  export BOSUN_GRIND_PROJECT_ID="${BOSUN_GRIND_PROJECT_ID:-$repo}"
  export BOSUN_API_BASE="${BOSUN_API_BASE:-http://localhost:9746}"
  export BOSUN_URL="${BOSUN_URL:-$BOSUN_API_BASE}"
}

_ensure_bosun_grind_session() {
  _bosun_grind_error=""
  if ! _skill_needs_bosun 2>/dev/null; then
    return 0
  fi
  if [[ -n "${BOSUN_GRIND_SESSION_ID:-}" ]]; then
    export BOSUN_GRIND_SESSION_ID
    export BOSUN_GRIND_PROJECT_ID="${BOSUN_GRIND_PROJECT_ID:-$repo}"
    export BOSUN_API_BASE="${BOSUN_API_BASE:-http://localhost:9746}"
    export BOSUN_URL="${BOSUN_URL:-$BOSUN_API_BASE}"
    return 0
  fi
  if [[ -n "${DVB_GRIND_CMD:-}" && -z "${DVB_REGISTER_REAL_BOSUN_GRIND:-}" ]]; then
    export BOSUN_GRIND_SESSION_ID="taskgrind-test-${_lock_hash:-test}-$$"
    export BOSUN_GRIND_PROJECT_ID="$repo"
    export BOSUN_API_BASE="${BOSUN_API_BASE:-http://localhost:9746}"
    export BOSUN_URL="${BOSUN_URL:-$BOSUN_API_BASE}"
    return 0
  fi

  local bosun_bin session_id env_file register_output
  if ! bosun_bin=$(_resolve_bosun_cli); then
    _bosun_grind_error="Bosun-dependent skill '$skill' needs BOSUN_GRIND_SESSION_ID. Install/locate the bosun CLI or run: bosun grind register --project \"$repo\" --skill \"$skill\" --backend \"$backend\" --duration \"$hours\" && source ~/.orchestrator/grind-session-<id>.env"
    return 1
  fi
  if ! register_output=$("$bosun_bin" grind register --project "$repo" --skill "$skill" --backend "$backend" --duration "$hours" 2>&1); then
    _bosun_grind_error="Failed to register Bosun grind session with '$bosun_bin grind register': $register_output"
    return 1
  fi
  session_id=$(printf '%s\n' "$register_output" | tail -1 | tr -d '[:space:]')
  if [[ -z "$session_id" ]]; then
    _bosun_grind_error="Bosun grind register returned no session ID. Run manually: bosun grind register --project \"$repo\" --skill \"$skill\" --backend \"$backend\" --duration \"$hours\""
    return 1
  fi
  env_file="$HOME/.orchestrator/grind-session-${session_id}.env"
  if ! _source_bosun_grind_env "$env_file"; then
    _bosun_grind_error="Bosun grind session registered as '$session_id' but env file was not sourceable: $env_file. Run: source \"$env_file\""
    return 1
  fi
  # We registered the session, so we own its lifecycle: heartbeats while
  # we run + `bosun grind done` on exit. The caller-provided and test-stub
  # branches above leave _bosun_grind_owned at its default 0 so the
  # operator's slot is heartbeated but not deregistered.
  _bosun_grind_owned=1
}

# Body of the background heartbeat loop, spun off as its own function so
# `local` is legal under bash 3.2 (the runtime constraint guarded by
# tests/bash-compat.bats — `local` outside a function is a syntax error
# in older bash).
_bosun_heartbeat_loop_body() {
  local bosun_bin="$1"
  # Don't inherit traps from the parent — the loop should exit cleanly
  # on SIGTERM without re-running graceful_shutdown.
  local sleep_pid=""
  trap '[[ -n "${sleep_pid:-}" ]] && kill "$sleep_pid" 2>/dev/null || true; exit 0' TERM INT
  local hb_out hb_status
  while :; do
    sleep "$_bosun_heartbeat_interval" &
    sleep_pid=$!
    wait "$sleep_pid" || exit 0
    sleep_pid=""
    hb_out=$(
      "$bosun_bin" grind heartbeat \
        --session "$BOSUN_GRIND_SESSION_ID" \
        --cycle "${session:-1}" \
        --persona "taskgrind-driver" \
        --ships "${tasks_shipped:-0}" \
        2>&1
    ) && hb_status=0 || hb_status=$?
    if [[ "$hb_status" -eq 0 ]]; then
      log_write "[$(date '+%H:%M')] bosun_heartbeat session=${BOSUN_GRIND_SESSION_ID} cycle=${session:-1} ships=${tasks_shipped:-0}"
    else
      log_write "[$(date '+%H:%M')] bosun_heartbeat_failed session=${BOSUN_GRIND_SESSION_ID} status=$hb_status detail=$(printf '%s' "$hb_out" | head -1)"
    fi
  done
}

# Background heartbeat loop — keeps Bosun's `lastHeartbeatAt` advancing
# while a Taskgrind controller session is running. Without this, Bosun
# marks long-running grind sessions `disconnected` after its
# heartbeat-timeout (default 5 minutes), which made the 2026-04-30 canary
# end with status `disconnected` even though the controller was healthy.
#
# The loop fires regardless of who owns the session — caller-provided
# sessions also need their heartbeat pushed forward while we drive them.
# Only `_finalize_bosun_grind_session` checks `_bosun_grind_owned` to
# decide whether to deregister.
_start_bosun_heartbeat_loop() {
  [[ -n "${BOSUN_GRIND_SESSION_ID:-}" ]] || return 0
  # Test mode default: skip real heartbeats. Set DVB_BOSUN_HEARTBEAT_TEST=1
  # to opt-in for tests that exercise the loop end-to-end.
  if [[ -n "${DVB_GRIND_CMD:-}" && -z "${DVB_BOSUN_HEARTBEAT_TEST:-}" ]]; then
    return 0
  fi
  local bosun_bin
  if ! bosun_bin=$(_resolve_bosun_cli); then
    log_write "[$(date '+%H:%M')] bosun_heartbeat skipped reason=no_cli session=${BOSUN_GRIND_SESSION_ID}"
    return 0
  fi
  # The loop is intentionally simple: sleep, post, repeat. Each post is a
  # best-effort no-throw — heartbeat failures (e.g. transient bosun
  # restart, network blip) are logged as warnings and the loop keeps
  # running. Exit happens via SIGTERM from _stop_bosun_heartbeat_loop.
  _bosun_heartbeat_loop_body "$bosun_bin" &
  _bosun_heartbeat_pid=$!
  log_write "[$(date '+%H:%M')] bosun_heartbeat_started pid=$_bosun_heartbeat_pid interval=${_bosun_heartbeat_interval}s session=${BOSUN_GRIND_SESSION_ID}"
}

_stop_bosun_heartbeat_loop() {
  if [[ ${_bosun_heartbeat_pid:-0} -gt 0 ]] && kill -0 "$_bosun_heartbeat_pid" 2>/dev/null; then
    kill "$_bosun_heartbeat_pid" 2>/dev/null || true
    wait "$_bosun_heartbeat_pid" 2>/dev/null || true
    log_write "[$(date '+%H:%M')] bosun_heartbeat_stopped pid=$_bosun_heartbeat_pid"
  fi
  _bosun_heartbeat_pid=0
}

# Mark the Bosun grind session done (idempotent). Reason is "completed"
# on a normal grind exit and "aborted" on signal/error exit. Only the
# session WE registered gets deregistered — caller-provided sessions
# stay active so the operator's outer wrapper can keep using them.
_finalize_bosun_grind_session() {
  local reason="${1:-${_bosun_grind_done_reason:-completed}}"
  [[ "${_bosun_grind_done_called:-0}" -eq 1 ]] && return 0
  _bosun_grind_done_called=1
  [[ "${_bosun_grind_owned:-0}" -eq 1 ]] || return 0
  [[ -n "${BOSUN_GRIND_SESSION_ID:-}" ]] || return 0
  if [[ -n "${DVB_GRIND_CMD:-}" && -z "${DVB_BOSUN_HEARTBEAT_TEST:-}" ]]; then
    return 0
  fi
  local bosun_bin
  if ! bosun_bin=$(_resolve_bosun_cli); then
    log_write "[$(date '+%H:%M')] bosun_grind_done_skipped reason=no_cli session=${BOSUN_GRIND_SESSION_ID}"
    return 0
  fi
  local _done_out _done_status
  # shellcheck disable=SC1010 # `done` here is the `bosun grind` subcommand,
  # not a shell keyword — bosun's commander.js CLI accepts it as a literal.
  _done_out=$("$bosun_bin" grind "done" --session "$BOSUN_GRIND_SESSION_ID" --reason "$reason" 2>&1) \
    && _done_status=0 || _done_status=$?
  if [[ "$_done_status" -eq 0 ]]; then
    log_write "[$(date '+%H:%M')] bosun_grind_done session=${BOSUN_GRIND_SESSION_ID} reason=$reason"
  else
    log_write "[$(date '+%H:%M')] bosun_grind_done_failed session=${BOSUN_GRIND_SESSION_ID} reason=$reason status=$_done_status detail=$(printf '%s' "$_done_out" | head -1)"
  fi
}

_bosun_api_auth_args=()
_resolve_bosun_api_auth_args() {
  local token=""
  _bosun_api_auth_args=()
  if [[ -n "${BOSUN_TOKEN:-}" ]]; then
    token="$BOSUN_TOKEN"
  elif [[ -n "${HOME:-}" && -f "$HOME/.orchestrator/auth-token" ]]; then
    token=$(sed -n '1p' "$HOME/.orchestrator/auth-token" 2>/dev/null) || token=""
  fi
  if [[ -n "$token" ]]; then
    _bosun_api_auth_args=(-H "Authorization: Bearer $token")
  fi
}

_pipeline_count_via_api() {
  # Optional first arg: BOSUN_GRIND_SESSION_ID. When provided, the request
  # is scoped to pipelines tagged with that grind session via the Bosun
  # `?grindSessionId=` query filter. Without it, the count is fleet-wide
  # (used for debug context only — the verifier's primary signal is the
  # session-scoped delta so unrelated fleet pipelines cannot mask a
  # session-local bypass).
  local session_id="${1:-}"
  local base="${BOSUN_API_BASE:-http://localhost:9746}"
  base="${base%/}"
  local body count url
  _resolve_bosun_api_auth_args
  if [[ -n "$session_id" ]]; then
    url="${base}/api/v1/pipelines?grindSessionId=${session_id}&status=COMPLETED,WAITING_FOR_MERGE&limit=500"
  else
    url="${base}/api/v1/pipelines?status=COMPLETED,WAITING_FOR_MERGE&limit=500"
  fi
  local curl_stderr curl_exit_code
  curl_stderr=$(mktemp)
  body=$(curl -sf --max-time 5 ${_bosun_api_auth_args[@]+"${_bosun_api_auth_args[@]}"} "$url" 2>"$curl_stderr")
  curl_exit_code=$?
  if [[ $curl_exit_code -ne 0 ]]; then
    # Check for auth-specific failures
    if [[ $curl_exit_code -eq 22 || $(< "$curl_stderr") =~ (Authentication|Unauthorized|401) ]]; then
      log_write "[$(date '+%H:%M')] pipeline_verify AUTH_FAILURE curl_exit=$curl_exit_code stderr=$(head -1 "$curl_stderr")"
    fi
    rm -f "$curl_stderr"
    echo 0
    return 0
  fi
  rm -f "$curl_stderr"
  if command -v jq >/dev/null 2>&1; then
    count=$(echo "$body" | jq -r '(.pipelines // .) | map(select(.status == "COMPLETED" or .status == "WAITING_FOR_MERGE")) | length' 2>/dev/null) || count=0
  else
    count=$(echo "$body" | grep -Eo '"status"[[:space:]]*:[[:space:]]*"(COMPLETED|WAITING_FOR_MERGE)"' | wc -l | tr -d ' ') || count=0
  fi
  case "$count" in
    ""|*[!0-9]*) echo 0 ;;
    *) echo "$count" ;;
  esac
}

_capture_pipeline_baseline() {
  # Captures two counts so cleanup-time verification can compare:
  #   - scoped (BOSUN_GRIND_SESSION_ID-filtered) — primary signal: "did
  #     THIS Taskgrind grind session create/advance pipelines?"
  #   - global (fleet-wide) — debug-only context so operators can see
  #     whether other fleet activity moved while we were running.
  # When BOSUN_GRIND_SESSION_ID is unset (legacy / supervisor-style
  # runs), both counts collapse to the global value, preserving the
  # pre-session-scoped behavior.
  local session_id global_count scoped_count
  session_id="${BOSUN_GRIND_SESSION_ID:-}"
  global_count=$(_pipeline_count_via_api 2>/dev/null)
  if [[ -n "$session_id" ]]; then
    scoped_count=$(_pipeline_count_via_api "$session_id" 2>/dev/null)
  else
    scoped_count="$global_count"
  fi
  _pipeline_baseline_file="$_dvb_tmp/taskgrind-baseline-${_lock_hash}.json"
  _pipeline_baseline_refs_file="${_pipeline_baseline_file%.json}.refs"
  # `startCount` carries the primary (scoped) value so existing parsers that
  # extract `"startCount":N` keep reading the right delta. The fleet-wide
  # count is exposed alongside for debugging.
  printf '{"startCount":%d,"globalStartCount":%d,"sessionId":"%s","startTime":%d,"pid":%d}\n' \
    "$scoped_count" "$global_count" "$session_id" "$(date +%s)" "$$" > "$_pipeline_baseline_file"
  if [[ -n "${repo:-}" ]] && git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
    git -C "$repo" for-each-ref --format='%(objectname)' refs/heads > "$_pipeline_baseline_refs_file" 2>/dev/null || : > "$_pipeline_baseline_refs_file"
  else
    : > "$_pipeline_baseline_refs_file"
  fi
  if type log_write >/dev/null 2>&1; then
    if [[ -n "$session_id" ]]; then
      log_write "[$(date '+%H:%M')] pipeline_baseline scope=session=${session_id} count=$scoped_count global=$global_count file=$_pipeline_baseline_file"
    else
      log_write "[$(date '+%H:%M')] pipeline_baseline scope=global count=$scoped_count file=$_pipeline_baseline_file"
    fi
  fi
}

_pipeline_new_commits_since_baseline() {
  local start_time="$1"
  [[ -n "${repo:-}" ]] || return 0
  git -C "$repo" rev-parse --git-dir >/dev/null 2>&1 || return 0

  local refs_file="${_pipeline_baseline_refs_file:-${_pipeline_baseline_file%.json}.refs}"
  local not_args=()
  local ref
  if [[ -f "$refs_file" ]]; then
    while IFS= read -r ref; do
      [[ -n "$ref" ]] && not_args+=("$ref")
    done < "$refs_file"
  fi

  local git_stderr git_exit_code
  git_stderr=$(mktemp)
  if [[ ${#not_args[@]} -gt 0 ]]; then
    git -C "$repo" rev-list --branches --since="@$start_time" --not "${not_args[@]}" 2>"$git_stderr"
    git_exit_code=$?
  else
    git -C "$repo" rev-list --branches --since="@$start_time" 2>"$git_stderr"
    git_exit_code=$?
  fi
  if [[ $git_exit_code -ne 0 ]]; then
    # Log unexpected git errors for debugging, but allow expected cases
    if [[ ! $(< "$git_stderr") =~ (no such ref|bad object|unknown revision) ]]; then
      log_write "[$(date '+%H:%M')] pipeline_verify GIT_ERROR exit=$git_exit_code stderr=$(head -1 "$git_stderr")"
    fi
  fi
  rm -f "$git_stderr"
  # Return empty list on any error - preserve original behavior
  [[ $git_exit_code -eq 0 ]] || true
}

_pipeline_commit_touches_non_markdown() {
  local commit="$1"
  local file
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    case "$file" in
      *.md) : ;;
      *) return 0 ;;
    esac
  done < <(git -C "$repo" diff-tree --root --no-commit-id --name-only -r "$commit" 2>/dev/null)
  return 1
}

_pipeline_commit_has_bosun_provenance() {
  local commit="$1"
  git -C "$repo" log -1 --format=%B "$commit" 2>/dev/null \
    | grep -qE '^(Generated by Bosun pipeline-|Co-Authored-By: Bosun <bosun-pipelines@cognition\.ai>)'
}

_pipeline_bypass_commits_since_baseline() {
  local start_time="$1"
  local commit short subject first_code_file
  while IFS= read -r commit; do
    [[ -z "$commit" ]] && continue
    if _pipeline_commit_touches_non_markdown "$commit" && ! _pipeline_commit_has_bosun_provenance "$commit"; then
      short=$(git -C "$repo" rev-parse --short "$commit" 2>/dev/null || echo "$commit")
      subject=$(git -C "$repo" log -1 --format=%s "$commit" 2>/dev/null || echo "(subject unavailable)")
      first_code_file=$(
        git -C "$repo" diff-tree --root --no-commit-id --name-only -r "$commit" 2>/dev/null \
          | while IFS= read -r file; do
              [[ -z "$file" ]] && continue
              [[ "$file" == *.md ]] && continue
              echo "$file"
              break
            done
      )
      printf '%s file=%s subject=%s\n' "$short" "${first_code_file:-unknown}" "$subject"
    fi
  done < <(_pipeline_new_commits_since_baseline "$start_time")
}

_verify_pipeline_completion_rate() {
  # Pre-conditions: skill needs bosun, baseline file exists.
  if ! _skill_needs_bosun 2>/dev/null; then
    return 0
  fi
  if [[ -z "${_pipeline_baseline_file:-}" || ! -f "$_pipeline_baseline_file" ]]; then
    log_write "[$(date '+%H:%M')] pipeline_verify skipped reason=no_baseline"
    return 0
  fi

  local start_count
  start_count=$(grep -o '"startCount":[0-9]*' "$_pipeline_baseline_file" 2>/dev/null | head -1 | sed 's/.*://')
  [[ -z "$start_count" ]] && start_count=0
  local global_start_count
  global_start_count=$(grep -o '"globalStartCount":[0-9]*' "$_pipeline_baseline_file" 2>/dev/null | head -1 | sed 's/.*://')
  [[ -z "$global_start_count" ]] && global_start_count="$start_count"
  # Recover the recorded session ID. Use a sed pattern keyed to the
  # `"sessionId":"..."` field so we don't pick up other quoted strings.
  local session_id
  session_id=$(grep -o '"sessionId":"[^"]*"' "$_pipeline_baseline_file" 2>/dev/null | head -1 | sed 's/.*"sessionId":"\([^"]*\)".*/\1/')
  local start_time
  start_time=$(grep -o '"startTime":[0-9]*' "$_pipeline_baseline_file" 2>/dev/null | head -1 | sed 's/.*://')
  [[ -z "$start_time" ]] && start_time="${start_epoch:-0}"

  # Query global first so the baseline-vs-end ordering matches
  # _capture_pipeline_baseline (global, then optional scoped). Tests rely
  # on this order to feed deterministic counter sequences.
  local end_count global_end_count
  global_end_count=$(_pipeline_count_via_api 2>/dev/null)
  if [[ -n "$session_id" ]]; then
    end_count=$(_pipeline_count_via_api "$session_id" 2>/dev/null)
  else
    end_count="$global_end_count"
  fi
  local delta=$((end_count - start_count))
  local global_delta=$((global_end_count - global_start_count))
  local bypass_commits bypass_count
  bypass_commits=$(_pipeline_bypass_commits_since_baseline "$start_time")
  bypass_count=$(printf '%s\n' "$bypass_commits" | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' ')

  local scope="global"
  [[ -n "$session_id" ]] && scope="session=${session_id}"

  # The primary delta (start/end/delta) is session-scoped when a session
  # was registered; the global_* fields are debug context. Operators can
  # see at a glance whether the session moved (start→end) and whether the
  # surrounding fleet moved (global_start→global_end), then compare.
  log_write "[$(date '+%H:%M')] pipeline_verify scope=$scope start=$start_count end=$end_count delta=$delta global_start=$global_start_count global_end=$global_end_count global_delta=$global_delta tasks_shipped=$tasks_shipped direct_code_bypasses=$bypass_count"

  if [[ "$bypass_count" -gt 0 ]]; then
    _pipeline_verify_failed=1
    log_write "[$(date '+%H:%M')] pipeline_verify DIRECT_CODE_BYPASS count=$bypass_count skill=$skill"
    printf '%s\n' "$bypass_commits" | sed "s/^/[pid=$$] [$(date '+%H:%M')] pipeline_verify DIRECT_CODE_BYPASS commit=/" >> "$log_file" 2>/dev/null || true
    echo "" >&2
    echo "⚠ Pipeline provenance anomaly: ${bypass_count} direct code commit(s)" >&2
    echo "  touched non-markdown files without Bosun pipeline attribution." >&2
    echo "  This is the Apr 28-29 incident shape — code shipped outside" >&2
    echo "  the bosun pipeline path. Inspect:" >&2
    echo "    - Direct commits:" >&2
    printf '%s\n' "$bypass_commits" | sed 's/^/      /' >&2
    echo "    - Session log: $log_file" >&2
    _record_pipeline_anomaly_task "$tasks_shipped" "$start_count" "$end_count" "direct_code_bypass" "$bypass_commits"
    return 1
  fi

  # Anomaly: shipped tasks but zero new pipelines for THIS grind session.
  # Note: $delta is the session-scoped delta. Global movement is logged for
  # debugging but is NOT the pass condition — an unrelated fleet pipeline
  # finishing during our run must not mask a session-local bypass.
  if [[ "$tasks_shipped" -gt 0 && "$delta" -eq 0 ]]; then
    _pipeline_verify_failed=1
    log_write "[$(date '+%H:%M')] pipeline_verify ANOMALY tasks_shipped=$tasks_shipped pipeline_delta=0 scope=$scope global_delta=$global_delta skill=$skill"
    echo "" >&2
    echo "⚠ Pipeline-rate anomaly: ${tasks_shipped} task(s) shipped this session" >&2
    if [[ -n "$session_id" ]]; then
      echo "  but bosun saw zero new pipeline completions for grind session ${session_id}" >&2
      echo "  (scoped start=$start_count, end=$end_count; global delta=$global_delta — for context only)." >&2
    else
      echo "  but bosun saw zero new pipeline completions (start=$start_count, end=$end_count)." >&2
    fi
    echo "  This is the Apr 28-29 incident shape — agent shipped code without" >&2
    echo "  going through bosun pipelines. Inspect:" >&2
    echo "    - Recent commits: git -C \"$repo\" log --since=\"$(date -r "$start_epoch" '+%Y-%m-%d %H:%M' 2>/dev/null || echo recently)\" --oneline" >&2
    if [[ -n "$session_id" ]]; then
      echo "    - Bosun pipelines for session: ${BOSUN_API_BASE:-http://localhost:9746}/api/v1/pipelines?grindSessionId=${session_id}" >&2
    else
      echo "    - Bosun pipelines: ${BOSUN_API_BASE:-http://localhost:9746}/api/v1/pipelines" >&2
    fi
    echo "    - Session log: $log_file" >&2
    _record_pipeline_anomaly_task "$tasks_shipped" "$start_count" "$end_count" "zero_pipeline_delta" ""
    return 1
  fi
  return 0
}

# Append a TASKS.md entry describing the anomaly so it gets investigated in
# a future session. Uses an HTML-comment marker keyed by start time so we
# don't double-file if cleanup runs twice (e.g. graceful + EXIT trap).
_record_pipeline_anomaly_task() {
  local shipped=$1 start=$2 end=$3
  local reason="${4:-pipeline_verify_failed}"
  local details="${5:-}"
  local tasks_file="${repo}/TASKS.md"
  [[ -w "$tasks_file" ]] || return 0
  local marker_id
  marker_id="taskgrind-pipeline-anomaly-${start_epoch}"
  if grep -qF "$marker_id" "$tasks_file" 2>/dev/null; then
    return 0
  fi
  cat >> "$tasks_file" <<EOF

<!-- $marker_id — auto-filed by taskgrind _verify_pipeline_completion_rate -->

- [ ] Investigate pipeline-bypass anomaly from taskgrind session (auto-filed)
  - **ID**: $marker_id
  - **Tags**: anomaly, taskgrind, bosun-pipelines, auto-filed
  - **Details**: Taskgrind session ($skill skill, $session sessions) triggered
    pipeline verification failure reason=$reason after shipping $shipped
    task(s). Bosun completed/waiting-for-merge pipeline count moved start=$start end=$end.
    The Apr 28-29 incident shape: agent direct-committed code bypassing
    pipelines. Inspect the session log and the recent commits to find which
    task(s) shipped without going through bosun's pipeline machinery, then either:
      (a) confirm they were legitimate non-pipeline ships (e.g. doc-only
          updates, TASKS.md curation), and document what makes them
          legitimate so this rule can be tightened.
      (b) trace why the agent bypassed the pipeline — was hooks/pre-commit
          (Iron Rule 7) bypassed? was the pipeline-token check evaded?
          File a P0 bug for whatever was missed.
  - **Files**:
    - Session log: ${log_file:-(unknown)}
    - Bosun pipelines API: \${BOSUN_API_BASE:-http://localhost:9746}/api/v1/pipelines
  - **Acceptance**:
    - Each shipped task can be traced to either a bosun pipeline OR a
      documented "legitimate non-pipeline" category.
    - If a real bypass is found, file follow-up tasks against bosun's
      pre-commit / pre-push enforcement gates.
EOF
  if [[ -n "$details" ]]; then
    {
      echo "  - **Direct commits**:"
      printf '%s\n' "$details" | sed 's/^/    - /'
    } >> "$tasks_file"
  fi
}

slot_lock_file() {
  local slot="$1"
  echo "$_dvb_tmp/taskgrind-lock-${_lock_hash}-${slot}"
}

slot_lock_pid() {
  local lock_file="$1"
  [[ -f "$lock_file" ]] || return 1
  sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p' "$lock_file" 2>/dev/null | head -1
}

slot_lock_active() {
  local lock_file="$1"
  local lock_pid
  lock_pid=$(slot_lock_pid "$lock_file") || return 1
  [[ -n "$lock_pid" ]] || return 1
  kill -0 "$lock_pid" 2>/dev/null
}

preflight_check() {
  echo "Preflight checks for: $repo"
  echo ""
  local backend_available=1

  # 1. Backend binary — required to run sessions
  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    if resolve_test_backend_command; then
      preflight_pass "Backend binary (test mode: DVB_GRIND_CMD set)"
    else
      preflight_fail "$_test_backend_error"
      backend_available=0
    fi
  else
    resolve_backend_binary
    if [[ -x "$_backend_binary" ]]; then
      preflight_pass "Backend binary ($backend): $_backend_binary"
    else
      preflight_fail "$(backend_binary_error)"
      backend_available=0
    fi
  fi

  # 2. Model validation — fail fast before burning sessions on a bad model ID
  if [[ "$backend_available" -eq 1 && ( -z "${DVB_GRIND_CMD:-}" || -n "${DVB_VALIDATE_MODEL:-}" ) ]]; then
    dvb_spinner_start "Validating model..."
    if validate_model; then
      dvb_spinner_stop; preflight_pass "Model accepted by $backend: $model"
    else
      dvb_spinner_stop
      preflight_fail "Model rejected by $backend before starting: ${_model_validation_error:-unknown error}. $(backend_model_hint "$backend")"
    fi
  elif [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    preflight_pass "Model validation skipped in test mode"
  fi

  local skill_available=1

  # 3. Requested skill visible — fail before sessions silently ignore a missing skill
  if [[ -z "${DVB_GRIND_CMD:-}" || -n "${DVB_VALIDATE_SKILL:-}" ]]; then
    if _validate_skill_available; then
      preflight_pass "Skill visible to $backend: $skill ($_skill_validation_path)"
    else
      preflight_fail "$_skill_validation_error"
      skill_available=0
    fi
  else
    preflight_pass "Skill visibility skipped in test mode"
  fi

  # 4. Network connectivity — required for API calls
  dvb_spinner_start "Checking network..."
  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    # Test mode — use sentinel file
    if [[ -n "${DVB_NET_FILE:-}" ]] && [[ -f "$DVB_NET_FILE" ]]; then
      dvb_spinner_stop; preflight_pass "Network connectivity (test mode)"
    elif [[ -z "${DVB_NET_FILE:-}" ]]; then
      dvb_spinner_stop; preflight_pass "Network connectivity (test mode: no DVB_NET_FILE)"
    else
      dvb_spinner_stop; preflight_warn "Network down (test mode: DVB_NET_FILE missing)"
    fi
  elif check_network; then
    dvb_spinner_stop; preflight_pass "Network connectivity"
  else
    dvb_spinner_stop; preflight_fail "Network unreachable"
  fi

  # 5. Git state clean — not mid-rebase, not detached HEAD, not mid-merge
  local git_dir
  git_dir="$(git -C "$repo" rev-parse --absolute-git-dir 2>/dev/null)" || git_dir=""
  if [[ -z "$git_dir" ]]; then
    preflight_warn "Not a git repository: $repo"
  else
    local git_clean=1
    if [[ -d "$git_dir/rebase-merge" ]] || [[ -d "$git_dir/rebase-apply" ]]; then
      preflight_fail "Git rebase in progress — run 'git rebase --abort' or resolve"
      git_clean=0
    fi
    if [[ -f "$git_dir/MERGE_HEAD" ]]; then
      preflight_fail "Git merge in progress — resolve or abort"
      git_clean=0
    fi
    if [[ "$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)" == "HEAD" ]]; then
      preflight_warn "Detached HEAD — sessions may not sync properly"
      git_clean=0
    fi
    if [[ $git_clean -eq 1 ]]; then
      preflight_pass "Git state clean"
    fi
  fi

  # 6. Git remote reachable — required for between-session sync
  if [[ -n "$git_dir" ]] && [[ -n "$(git -C "$repo" remote 2>/dev/null)" ]]; then
    dvb_spinner_start "Checking git remote..."
    _preflight_check_remote_reachable "$repo" "Git remote unreachable (may affect between-session sync)"
  else
    preflight_warn "No git remote configured"
  fi

  # 7. Disk space — at least 1GB free on the repo partition
  local free_kb
  free_kb=$(df -Pk "$repo" | awk 'NR==2 { print $4 }' 2>/dev/null) || free_kb=0
  free_kb="${free_kb:-0}"
  if [[ "$free_kb" -gt 1048576 ]]; then
    preflight_pass "Disk space: $(( free_kb / 1048576 ))GB free"
  elif [[ "$free_kb" -gt 524288 ]]; then
    preflight_warn "Disk space low: $(( free_kb / 1024 ))MB free (< 1GB)"
  else
    preflight_fail "Disk space critical: $(( free_kb / 1024 ))MB free"
  fi

  # 8. TASKS.md exists — signal for work discovery
  if [[ -f "$repo/TASKS.md" ]]; then
    local task_count
    task_count=$(grep -c '^[[:space:]]*- \[ \]' "$repo/TASKS.md" 2>/dev/null) || true
    preflight_pass "TASKS.md found (${task_count:-0} open tasks)"
  else
    preflight_warn "TASKS.md not found — empty queue sweep will find work"
  fi

  # 9. network-watchdog available — network resilience during marathon
  if command -v network-watchdog >/dev/null 2>&1; then
    preflight_pass "network-watchdog available"
  else
    preflight_warn "network-watchdog not found — using curl fallback for network checks"
  fi

  # 10. Bosun server reachable — when the skill drives bosun pipelines, the
  # agent cannot do useful work without bosun. Skip otherwise. In test mode
  # the user's local bosun isn't typically running; use a warning rather
  # than a fail to keep the bats suite portable.
  if [[ "$skill_available" -eq 1 ]] && _skill_needs_bosun; then
    dvb_spinner_start "Checking bosun server..."
    if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
      dvb_spinner_stop; preflight_pass "Bosun server check skipped (test mode)"
      if _ensure_bosun_grind_session; then
        preflight_pass "Bosun grind session active (${BOSUN_GRIND_SESSION_ID})"
        # Heartbeats are normally a no-op in test mode; tests that need
        # to observe the loop set DVB_BOSUN_HEARTBEAT_TEST=1 to opt in.
        _start_bosun_heartbeat_loop
      else
        preflight_fail "$_bosun_grind_error"
      fi
    elif _check_bosun_health; then
      dvb_spinner_stop
      preflight_pass "Bosun server ready (${BOSUN_API_BASE:-http://localhost:9746})"
      if _ensure_bosun_grind_session; then
        preflight_pass "Bosun grind session active (${BOSUN_GRIND_SESSION_ID})"
        # Capture pipeline-completion baseline so cleanup can verify the
        # session's shipped count against bosun's pipeline-completion delta
        # (catches the Apr 28-29 incident shape: shipped tasks but zero
        # pipelines completed → agent bypassed pipelines).
        _capture_pipeline_baseline
        # Keep Bosun's lastHeartbeatAt advancing while the controller
        # runs — without this, Bosun's monitor marks long-running grind
        # sessions `disconnected` after ~5 minutes of silence (the
        # 2026-04-30 fleet-grind canary failure shape).
        _start_bosun_heartbeat_loop
      else
        preflight_fail "$_bosun_grind_error"
      fi
    else
      dvb_spinner_stop
      if [[ "$_bosun_health_status" == "unreachable" ]]; then
        preflight_fail "Bosun server unreachable — skill '$skill' depends on bosun pipelines. Start with 'orchestrator start' or set BOSUN_API_BASE. Detail: ${_bosun_health_detail}"
      else
        preflight_warn "Bosun server not ready (${_bosun_health_status}): ${_bosun_health_detail}. Sessions may pile up if pipelines can't launch."
      fi
    fi

    # 11. Iron Rule 7 pre-commit enforcement — guards against the May 2026
    # readiness-inspection shape where the target repo's core.hooksPath was
    # /dev/null (or pointed at a sibling dir) and silently disabled the
    # pipeline-only commit gate.
    if _check_bosun_pipeline_only_enforcement "$repo"; then
      if [[ "$_bosun_hook_enforcement_status" == "active" ]]; then
        preflight_pass "Iron Rule 7 pre-commit hook active in $repo"
      fi
    else
      preflight_fail "Iron Rule 7 pre-commit hook NOT enforced: ${_bosun_hook_enforcement_detail}"
    fi
  fi

  # Summary
  echo ""
  echo "  Results: ${_pf_pass} passed, ${_pf_warn} warnings, ${_pf_fail} failed"

  if [[ $_pf_fail -gt 0 ]]; then
    echo "  ✗ Preflight FAILED — fix the above errors before starting."
    return 1
  elif [[ $_pf_warn -gt 0 ]]; then
    echo "  ⚠ Preflight passed with warnings."
    return 0
  else
    echo "  ✓ Preflight passed — ready to grind."
    return 0
  fi
}

# Workspace-mode per-target preflight. Reuses the per-repo subset of the
# regular preflight (git state, remote reachability, disk space) but skips
# global checks that already ran for the control repo (backend binary, model
# validation, network connectivity, network-watchdog availability). Also
# treats a missing TASKS.md as benign — targets are not required to host
# their own queue, the control repo owns that.
preflight_check_target() {
  # Caller resets the per-target counters before invoking.

  # Git state clean — not mid-rebase, not detached HEAD, not mid-merge
  local git_dir
  git_dir="$(git -C "$repo" rev-parse --absolute-git-dir 2>/dev/null)" || git_dir=""
  if [[ -z "$git_dir" ]]; then
    preflight_warn "Not a git repository: $repo"
  else
    local git_clean=1
    if [[ -d "$git_dir/rebase-merge" ]] || [[ -d "$git_dir/rebase-apply" ]]; then
      preflight_fail "Git rebase in progress — run 'git rebase --abort' or resolve"
      git_clean=0
    fi
    if [[ -f "$git_dir/MERGE_HEAD" ]]; then
      preflight_fail "Git merge in progress — resolve or abort"
      git_clean=0
    fi
    if [[ "$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)" == "HEAD" ]]; then
      preflight_warn "Detached HEAD — sessions may not sync properly"
      git_clean=0
    fi
    if [[ $git_clean -eq 1 ]]; then
      preflight_pass "Git state clean"
    fi
  fi

  # Git remote reachable
  if [[ -n "$git_dir" ]] && [[ -n "$(git -C "$repo" remote 2>/dev/null)" ]]; then
    dvb_spinner_start "Checking git remote..."
    _preflight_check_remote_reachable "$repo" "Git remote unreachable (may affect target sync)"
  else
    preflight_warn "No git remote configured"
  fi

  # Disk space
  local free_kb
  free_kb=$(df -Pk "$repo" | awk 'NR==2 { print $4 }' 2>/dev/null) || free_kb=0
  free_kb="${free_kb:-0}"
  if [[ "$free_kb" -gt 1048576 ]]; then
    preflight_pass "Disk space: $(( free_kb / 1048576 ))GB free"
  elif [[ "$free_kb" -gt 524288 ]]; then
    preflight_warn "Disk space low: $(( free_kb / 1024 ))MB free (< 1GB)"
  else
    preflight_fail "Disk space critical: $(( free_kb / 1024 ))MB free"
  fi

  # Summary
  echo ""
  echo "  Results: ${_pf_pass} passed, ${_pf_warn} warnings, ${_pf_fail} failed"

  if [[ $_pf_fail -gt 0 ]]; then
    echo "  ✗ Target preflight FAILED — fix the above errors before starting."
    return 1
  elif [[ $_pf_warn -gt 0 ]]; then
    echo "  ⚠ Target preflight passed with warnings."
    return 0
  else
    echo "  ✓ Target preflight passed."
    return 0
  fi
}

# --preflight: run health checks and exit without launching
if [[ "$preflight_only" -eq 1 ]]; then
  echo "taskgrind --preflight"
  echo "  repo:     $repo"
  echo "  backend:  $backend"
  echo "  skill:    $skill"
  echo "  model:    $model"
  if [[ -n "$extra_prompt" ]]; then
    echo "  prompt:   $extra_prompt"
  fi
  if [[ "${#target_repos[@]}" -gt 0 ]]; then
    for _tg in ${target_repos[@]+"${target_repos[@]}"}; do
      echo "  target:   $_tg"
    done
    unset _tg
  fi
  # Report active instance slots
  _lock_hash=$(echo "$repo" | { shasum 2>/dev/null || sha1sum; } | cut -d' ' -f1)
  _active_slots=0
  for (( _slot=0; _slot < max_instances; _slot++ )); do
    _pf_lock=$(slot_lock_file "$_slot")
    if slot_lock_active "$_pf_lock"; then
      (( _active_slots++ )) || true
    fi
  done
  echo "  slots:    $_active_slots/$max_instances active"
  echo ""
  preflight_check
  _pf_status=$?
  # Workspace mode: re-run the standard preflight checks against each target
  # repo so missing remotes, mid-rebase trees, or absent paths show up
  # before the deadline starts. The control-repo result still drives the
  # overall exit code; targets contribute warnings or failures in addition.
  if [[ "${#target_repos[@]}" -gt 0 ]]; then
    for _tg in ${target_repos[@]+"${target_repos[@]}"}; do
      echo ""
      echo "Target repo preflight: $_tg"
      echo ""
      _saved_repo="$repo"
      repo="$_tg"
      _pf_pass=0; _pf_warn=0; _pf_fail=0
      preflight_check_target
      _tg_status=$?
      repo="$_saved_repo"
      if [[ "$_tg_status" -ne 0 ]]; then
        _pf_status=1
      fi
    done
    unset _tg _saved_repo _tg_status
  fi
  exit "$_pf_status"
fi

# ── Per-repo slot lock ────────────────────────────────────────────────
# Slot-based locking: up to max_instances grinds per repo directory.
# Each instance claims the lowest free slot (0, 1, …, max_instances-1).
# Slot 0 is the primary (owns git sync); slots ≥1 skip between-session sync.
# Uses flock(1) on Linux or perl flock(2) on macOS — lock auto-releases on exit/crash.
# Skip locking in test mode (DVB_GRIND_CMD set) to avoid fd conflicts with bats.
_dvb_slot=0
if [[ -z "${DVB_GRIND_CMD:-}" ]]; then
  _lock_hash=$(echo "$repo" | { shasum 2>/dev/null || sha1sum; } | cut -d' ' -f1)
  _lock_acquired=false
  for (( _slot=0; _slot < max_instances; _slot++ )); do
    _lock_file=$(slot_lock_file "$_slot")
    # Each slot gets its own fd: slot 0 → fd 9, slot 1 → fd 10, etc.
    _lock_fd=$(( 9 + _slot ))
    eval "exec ${_lock_fd}>\"$_lock_file\""
    _lock_ok=true
    if command -v flock >/dev/null 2>&1; then
      flock -n "$_lock_fd" 2>/dev/null || _lock_ok=false
    else
      perl -e "use Fcntl qw(:flock); open(my \$fh, \">&=\", $_lock_fd) or exit 1; flock(\$fh, LOCK_EX|LOCK_NB) or exit 1" 2>/dev/null || _lock_ok=false
    fi
    if [[ "$_lock_ok" == "true" ]]; then
      _dvb_slot=$_slot
      _lock_acquired=true
      echo "repo=$repo pid=$$ slot=$_dvb_slot started=$(date '+%Y-%m-%d %H:%M')" >&"$_lock_fd"
      break
    fi
  done
  if [[ "$_lock_acquired" == "false" ]]; then
    # All slots full — report which instances hold them
    echo "Error: all $max_instances instance slot(s) are in use for this repo" >&2
    echo "  repo: $repo" >&2
    for (( _slot=0; _slot < max_instances; _slot++ )); do
      _lock_file=$(slot_lock_file "$_slot")
      _lock_info=$(cat "$_lock_file" 2>/dev/null)
      if [[ -n "$_lock_info" ]]; then
        echo "  slot $_slot: $_lock_info" >&2
      fi
    done
    echo "  hint: set TG_MAX_INSTANCES=$((max_instances + 1)) to allow another instance" >&2
    exit 1
  fi

  # Clean up orphaned temp files from previous runs (older than 1 day).
  # Only runs in production mode (test mode skips locking entirely).
  # Retention policy: this sweep deliberately omits primary `taskgrind-*.log`
  # files. The `grind-log-analyze` skill consumes them to post-mortem
  # completed grinds, so they must outlive a single run. macOS rotates
  # $TMPDIR periodically; Linux/long-lived CI hosts should add a logrotate
  # or systemd-tmpfiles rule. See README.md "Log file retention" and
  # SECURITY.md for operator guidance.
  if command -v fd >/dev/null 2>&1; then
    fd --no-ignore --changed-before 1d \
      'taskgrind-(exec\.|lock-|ses-|att-|gsy-|.*\.(session\.out|git-sync|task-attempts))' "$_dvb_tmp" \
      --exec rm -f {} 2>/dev/null || true
  else
    find "$_dvb_tmp" -maxdepth 1 -type f -name 'taskgrind-exec.*' -mtime +1 -delete 2>/dev/null || true
    find "$_dvb_tmp" -maxdepth 1 -type f -name 'taskgrind-lock-*' -mtime +1 -delete 2>/dev/null || true
    find "$_dvb_tmp" -maxdepth 1 -type f \( -name 'taskgrind-ses-*' -o -name 'taskgrind-gsy-*' -o -name 'taskgrind-att-*' -o -name 'taskgrind-*.session.out' -o -name 'taskgrind-*.git-sync' -o -name 'taskgrind-*.task-attempts*' \) -mtime +1 -delete 2>/dev/null || true
  fi
fi
# Test mode: allow DVB_SLOT to override slot for testing multi-instance behavior
if [[ -n "${DVB_GRIND_CMD:-}" && -n "${DVB_SLOT:-}" ]]; then
  _dvb_slot="$DVB_SLOT"
fi

# --dry-run: print config and exit without running sessions
if [[ "$dry_run" -eq 1 ]]; then
  echo "taskgrind --dry-run"
  echo "  hours:    $hours"
  echo "  repo:     $repo"
  echo "  backend:  $backend"
  echo "  skill:    $skill"
  echo "  model:    $model"
  echo "  cooldown: ${cooldown}s"
  # Show a fully-expanded example path rather than literal $(date …) / $$ tokens
  # so operators can copy-paste the result into a supervisor config or tail
  # command. The launch-time PID and minute will differ, but the path shape
  # (tmpdir, repo basename, extension) is pinned by the constant prefix.
  echo "  log:      ${DVB_LOG:-$_dvb_tmp/taskgrind-$(date '+%Y-%m-%d-%H%M')-$(basename "$repo")-$$.log}"
  echo "  status:   ${DVB_STATUS_FILE:-disabled}"
  echo "  notify:   ${DVB_NOTIFY:-1}"
  echo "  max_session: ${max_session}s"
  echo "  sweep_max:   ${sweep_max_session}s"
  echo "  early_exit_on_stall: ${DVB_EARLY_EXIT_ON_STALL:-0}"
  if [[ "${DVB_NO_STALL_EXIT:-0}" == "1" ]]; then
    echo "  stall_exit_policy: advisory_only (TG_NO_STALL_EXIT=1)"
  elif [[ "${DVB_EARLY_EXIT_ON_STALL:-0}" == "1" ]] || [[ "${DVB_EXIT_ON_STALL:-0}" == "1" ]]; then
    echo "  stall_exit_policy: strict_first_trip (TG_EXIT_ON_STALL=1)"
  else
    echo "  stall_exit_policy: default_2x_consecutive"
  fi
  echo "  no_push:  $no_push"
  if [[ "$max_instances" -gt 1 ]]; then
    echo "  max_instances: $max_instances (slot=$_dvb_slot)"
  fi
  if [[ "${#target_repos[@]}" -gt 0 ]]; then
    echo "  workspace: control + ${#target_repos[@]} target(s)"
    for _tg in ${target_repos[@]+"${target_repos[@]}"}; do
      echo "  target:   $_tg"
    done
    unset _tg
  fi
  if [[ -n "$extra_prompt" ]]; then
    echo "  prompt:   $extra_prompt"
  fi
  echo ""
  echo "Prompt:"
  echo "  Run the $skill skill. Session 1, $((hours * 60)) minutes remaining, timeout ${max_session}s."
  if [[ "$no_push" == "1" ]]; then
    echo "  COMPLETION PROTOCOL: When you finish a task, you MUST remove its entire block (checkbox + all metadata lines) from TASKS.md and commit. This is how taskgrind tracks progress — if the task line stays in TASKS.md, it counts as zero work done, even if you committed code. NO-PUBLISH MODE: commit locally only. Do NOT push to any remote. Do NOT create pull requests. Do NOT merge pull requests. Do NOT use 'gh pr create', 'gh pr merge', 'git push', or any tool that publishes to origin. Remove the completed task block from TASKS.md and commit locally — that is the entire publish step. The operator will review and push manually after the grind exits."
  else
    echo "  COMPLETION PROTOCOL: When you finish a task, you MUST remove its entire block (checkbox + all metadata lines) from TASKS.md and commit. This is how taskgrind tracks progress — if the task line stays in TASKS.md, it counts as zero work done, even if you committed code. Do NOT merge pull requests, force-push branches, bypass pre-push hooks with --no-verify, or submit PRs without explicit operator approval in this session. If you committed directly to main, just remove the task. A session that commits code but doesn't remove the task from TASKS.md is a failed session."
  fi
  echo "  PUBLIC_WRITE_GATE: TASKS.md task metadata — including labels, tags, or green-list annotations — is task context only. It does NOT authorize any public write. Explicit current-session operator approval is required before: merging or creating pull requests, pushing to remote branches, opening issues, posting to Slack/Jira/email, publishing packages, or any action visible outside this local repo. For cross-repo or upstream work: prepare the branch and PR body locally, report 'Approval needed — draft body at <path>', and stop. Do NOT bypass pre-push hooks with --no-verify or submit without that approval."
  echo "  AUTONOMY: You are fully autonomous. Never skip a task claiming it requires manual steps, human intervention, or external service access. You have browser automation, MCP tools, CLI access, and can interact with any web service. If a task involves a UI portal, use your browser skills. If it needs an API, call it. If it needs Jira, use MCP. Do not leave tasks saying 'requires manual work' — figure it out and do it. EXCEPTION: any public write (PR creation/merge, remote push, external notification) requires explicit operator approval in this session, not just task metadata."
  _dvb_context_guard="$(fleet_context_guard)"
  if [[ -n "$_dvb_context_guard" ]]; then
    echo "  $_dvb_context_guard"
  fi
  if [[ "${#target_repos[@]}" -gt 0 ]]; then
    echo "  WORKSPACE: This grind has ${#target_repos[@]} target repo(s) in addition to the control repo ($repo): $_targets_joined. Tasks may require coordinated changes across them. Use 'cd <repo> && git ...' to commit changes in the right repo. Treat the control repo as the source of truth for TASKS.md."
  fi
  if [[ -n "$extra_prompt" ]]; then
    echo "  FOCUS: $extra_prompt"
    echo "  Pick tasks from TASKS.md that relate to this focus first."
  fi
  echo "  [Previous session context passed automatically]"
  echo "  Commit before timeout. Do not exhaust context."
  exit 0
fi

start_epoch=$(date +%s)
deadline="${DVB_DEADLINE:-$(( start_epoch + hours * 3600 ))}"
if [[ "$resume_loaded" -eq 1 ]]; then
  deadline="$state_deadline"
fi
if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
  # Behavioral tests often use very short future deadlines (for example +5s)
  # to keep runs fast while still expecting at least one session to launch.
  # Under parallel bats load, startup/preflight overhead can consume that
  # window before the loop begins, making invocation-log assertions flaky.
  # Keep past deadlines untouched (tests use them to skip the loop), but give
  # near-future test deadlines a small minimum window.
  #
  # The threshold matters for suite throughput: every test that hits the
  # deadline (empty-queue wait, blocked-queue wait, diminishing-returns exit)
  # waits up to this many seconds before exiting. 5s is enough margin for
  # parallel-load setup overhead while keeping deadline-bounded tests cheap.
  # Tests that legitimately need more wall-clock budget should use the
  # explicit `DVB_DEADLINE_OFFSET=N` knob below.
  _test_deadline_window=$(( deadline - start_epoch ))
  if [[ "$_test_deadline_window" -gt 0 && "$_test_deadline_window" -lt 5 ]]; then
    deadline=$(( start_epoch + 5 ))
  fi
fi
# `DVB_DEADLINE_OFFSET=N` sets the deadline to `start_epoch + N` AFTER any
# auto-extension above. This is the parallel-safe alternative to setting
# `DVB_DEADLINE=$(( $(date +%s) + N ))`: the latter measures N from when bats
# composes the env, the former measures N from when taskgrind itself reads
# the clock, so heavy parallel-setup latency cannot shrink the window.
# Test-only knob — production code never sets this var.
if [[ -n "${DVB_DEADLINE_OFFSET:-}" && "$DVB_DEADLINE_OFFSET" =~ ^[0-9]+$ ]]; then
  deadline=$(( start_epoch + DVB_DEADLINE_OFFSET ))
fi
end_time=$(date -v+"${hours}"H +%H:%M 2>/dev/null || date -d "+${hours} hours" +%H:%M 2>/dev/null || echo "??:??")
_repo_basename=$(basename "$repo")
log_file="${DVB_LOG:-$_dvb_tmp/taskgrind-$(date '+%Y-%m-%d-%H%M')-${_repo_basename}-$$.log}"
status_file="${DVB_STATUS_FILE:-}"

# Ensure log directory exists and set secure permissions
log_dir="$(dirname "$log_file")"
if [[ ! -d "$log_dir" ]]; then
  mkdir -p "$log_dir" 2>/dev/null || { echo "Error: cannot create log directory: $log_dir" >&2; exit 1; }
fi
if [[ -d "$log_file" ]]; then
  echo "Error: DVB_LOG points to a directory: $log_file" >&2; exit 1
fi
if [[ -n "$status_file" ]]; then
  status_dir="$(dirname "$status_file")"
  if [[ ! -d "$status_dir" ]]; then
    mkdir -p "$status_dir" 2>/dev/null || { echo "Error: cannot create status directory: $status_dir" >&2; exit 1; }
  fi
fi
if [[ -n "$status_file" ]] && [[ -d "$status_file" ]]; then
  echo "Error: DVB_STATUS_FILE points to a directory: $status_file" >&2; exit 1
fi

session=0
tasks_shipped=0
tasks_starting=0
# Cumulative tasks added during the run — sum of every
# `_tasks_added_during_session` (post-session block) plus every sweep's
# `tasks_found`. Used as the denominator for `ship_rate` so an inflated
# >100 % number cannot result from sweeps and concurrent injections
# adding work after the starting count was captured.
tasks_added_total=0
# Aggregate sweep accounting — every backlog-discovery sweep contributes
# its elapsed seconds (and a +1 to the session-shape count). Surfaced in
# the grind_done summary so post-mortems can see the sweep cost share
# without grepping every `sweep_done` line and adding by hand. The
# 2026-04-24 grind spent 1794 + 4954 = 6748 s on sweeps (18 % of the
# 10 h budget); without these counters, that share is invisible from
# the summary.
_sweep_count=0
_sweep_seconds=0
tasks_remaining_snapshot=0
sessions_zero_ship=0
_recent_shipped=()  # rolling window of per-session shipped counts
# Consecutive trips of the diminishing-returns detector. Reset to 0 on
# any session that ships >= 1 task; incremented every time the detector
# fires. The default exit policy bails when this counter reaches 2.
_consecutive_diminishing_returns=0
_dvb_finalizing=0
_dvb_skip_exit_final_sync=0
_dvb_shutting_down=0
# Per-repo memo of (head, ahead) pairs we have already tried to push during
# this process. Format: ";<repo>=<head>/<ahead>;..." (semicolon-delimited so a
# `case` glob can probe membership without splitting). Replaces the older
# single-pair head/ahead variables; workspace mode needs per-repo state so
# control- and target-repo pushes don't shadow each other.
_dvb_final_sync_memo=""
session_output=$(mktemp "$_dvb_tmp/taskgrind-ses-XXXXXX") || { echo "Error: cannot create temp file in $_dvb_tmp" >&2; exit 1; }
_task_attempts_file=$(mktemp "$_dvb_tmp/taskgrind-att-XXXXXX") || { echo "Error: cannot create temp file in $_dvb_tmp" >&2; exit 1; }
_git_out=""
: > "$_task_attempts_file" 2>/dev/null || true
last_session_summary=""
current_phase="startup"
terminal_reason=""
last_session_number=0
last_session_result="pending"
last_session_exit=""
last_session_shipped=0
last_session_duration=0
last_session_completed_at=""
_dvb_pid=0
_dvb_timeout_pid=0
_git_pid=0
_git_timer=0
consecutive_zero_ship=0

if [[ "$resume_loaded" -eq 1 ]]; then
  session="$state_session"
  tasks_shipped="$state_tasks_shipped"
  sessions_zero_ship="$state_sessions_zero_ship"
  consecutive_zero_ship="$state_consecutive_zero_ship"
fi

# format_duration provided by lib/constants.sh as dvb_format_duration
format_duration() { dvb_format_duration "$@"; }

# Safe log append — never crash the loop on disk-full or deleted log.
# Every line is PID-prefixed for defense-in-depth against interleaving.
log_write() { echo "[pid=$$] $*" >> "$log_file" 2>/dev/null || true; }

write_resume_state() {
  local state_dir state_tmp
  state_dir="$(dirname "$state_file")"
  mkdir -p "$state_dir" 2>/dev/null || return 0
  state_tmp=$(mktemp "${state_file}.tmp.XXXXXX") 2>/dev/null || return 0
  cat > "$state_tmp" <<EOF
version=$DVB_RESUME_STATE_VERSION
repo=$repo
status=${1:-running}
deadline=$deadline
session=$session
tasks_shipped=$tasks_shipped
sessions_zero_ship=$sessions_zero_ship
consecutive_zero_ship=$consecutive_zero_ship
backend=$backend
skill=$skill
model=$model
startup_model=$_startup_model
startup_prompt=$_cli_prompt
no_push=$no_push
targets=$_targets_joined
EOF
  mv -f "$state_tmp" "$state_file" 2>/dev/null || rm -f "$state_tmp"
}

json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

write_status_file() {
  [[ -n "$status_file" ]] || return 0

  local status_dir status_tmp now remaining_secs remaining_minutes terminal_reason_json targets_json
  status_dir="$(dirname "$status_file")"
  mkdir -p "$status_dir" 2>/dev/null || return 0
  status_tmp=$(mktemp "${status_file}.tmp.XXXXXX") 2>/dev/null || return 0
  now=$(date +%s)
  remaining_secs=$((deadline - now))
  [[ "$remaining_secs" -lt 0 ]] && remaining_secs=0
  remaining_minutes=$((remaining_secs / 60))
  if [[ -n "$terminal_reason" ]]; then
    terminal_reason_json="\"$(json_escape "$terminal_reason")\""
  else
    terminal_reason_json="null"
  fi
  # Build the targets JSON array. Empty array `[]` for single-repo runs so
  # supervisors can rely on the field always being present without a null
  # branch. The control repo is intentionally NOT included here — it is
  # already exposed via the top-level "repo" field.
  if [[ "${#target_repos[@]}" -gt 0 ]]; then
    local _tg_first=1 _tg
    targets_json="["
    for _tg in ${target_repos[@]+"${target_repos[@]}"}; do
      if [[ "$_tg_first" -eq 1 ]]; then
        _tg_first=0
      else
        targets_json+=", "
      fi
      targets_json+="\"$(json_escape "$_tg")\""
    done
    targets_json+="]"
  else
    targets_json="[]"
  fi

  cat > "$status_tmp" <<EOF
{
  "repo": "$(json_escape "$repo")",
  "pid": $$,
  "slot": $_dvb_slot,
  "backend": "$(json_escape "$backend")",
  "skill": "$(json_escape "$skill")",
  "model": "$(json_escape "$model")",
  "session": $session,
  "remaining_minutes": $remaining_minutes,
  "current_phase": "$(json_escape "$current_phase")",
  "terminal_reason": $terminal_reason_json,
  "targets": $targets_json,
  "updated_at": "$(date '+%Y-%m-%dT%H:%M:%S%z')",
  "last_session": {
    "number": $last_session_number,
    "result": "$(json_escape "$last_session_result")",
    "exit_code": ${last_session_exit:-null},
    "shipped": $last_session_shipped,
    "duration_seconds": $last_session_duration,
    "completed_at": "$(json_escape "$last_session_completed_at")"
  }
}
EOF

  mv -f "$status_tmp" "$status_file" 2>/dev/null || rm -f "$status_tmp"
}

set_phase() {
  current_phase="$1"
  write_resume_state "running"
  write_status_file
}

run_test_backend() {
  # Avoid process-substitution helpers in test mode. Parallel bats can tear down
  # its temp tree before those child tee processes fully exit, which makes the
  # full suite end with signal 15 after every test has already passed.
  "$@" > "$session_output" 2>&1 &
  _dvb_pid=$!
  wait "$_dvb_pid" 2>/dev/null || _test_backend_status=$?
  _test_backend_status=${_test_backend_status:-0}
  if [[ -s "$session_output" ]]; then
    cat "$session_output"
  fi
  _dvb_pid=0
  return "$_test_backend_status"
}

# Resolve the session runner command — injectable for testing
if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
  if ! resolve_test_backend_command; then
    echo "Error: $_test_backend_error" >&2
    exit 1
  fi
  devin_cmd=("${_resolved_test_backend_cmd[@]}")
else
  resolve_backend_binary
  if [[ ! -x "$_backend_binary" ]]; then
    echo "Error: $(backend_binary_error)" >&2
    exit 1
  fi
  devin_cmd=("$_backend_binary")
fi

# Prevent sleep for the entire grind loop, not just individual sessions.
# macOS: re-exec under caffeinate. Linux: re-exec under systemd-inhibit (if available).
# Skip in test mode.
if [[ -z "${DVB_GRIND_CMD:-}" && -z "${DVB_CAFFEINATED:-}" ]]; then
  export DVB_CAFFEINATED=1
  if [[ "$(uname)" == "Darwin" ]]; then
    # shellcheck disable=SC2086  # intentionally unquoted — flags must word-split for caffeinate
    exec caffeinate $DVB_CAFFEINATE_FLAGS "$0" ${_orig_args[@]+"${_orig_args[@]}"}
  elif command -v systemd-inhibit >/dev/null 2>&1 \
      && systemd-inhibit --what=idle:sleep --who=taskgrind --why="grind probe" true >/dev/null 2>&1; then
    exec systemd-inhibit --what=idle:sleep --who=taskgrind --why="grind in progress" "$0" ${_orig_args[@]+"${_orig_args[@]}"}
  fi
  # No sleep inhibitor available — continue without one
fi

# Boost to interactive scheduling tier — max CPU/IO priority for the grind
# and all child devin sessions (macOS taskpolicy throughput/latency flags).
# shellcheck source=../lib/fullpower.sh
source "$TASKGRIND_DIR/lib/fullpower.sh"
boost_priority "$$"

# ── Push-failure classifier ───────────────────────────────────────────
# Examines the captured push stderr and classifies the failure into a
# structured class so callers can pick a recovery strategy. Returns one
# of: `protected_branch` | `push_failed`. Branch-protection rejection
# (GH006 on github.intuit.com / GitHub.com, "protected branch hook
# declined" on Gitea/Forgejo, "Required status check" / "policy"
# violations) is structurally different from non-fast-forward — the
# remote will reject any direct push, period, and the recovery path is
# "open a PR" not "rebase + retry".
_classify_push_failure() {
  local _stderr="$1" _lower
  # Normalize to lowercase so we match both `Protected branch update failed`
  # (the GitHub Enterprise format) and `protected branch hook declined`
  # (Gitea / Forgejo / older Git client format) without listing every casing.
  _lower=$(printf '%s' "$_stderr" | tr '[:upper:]' '[:lower:]')
  case "$_lower" in
    *"gh006"*|*"protected branch hook declined"*|*"protected branch update failed"*|*"required status check"*)
      echo "protected_branch" ;;
    *)
      echo "push_failed" ;;
  esac
}

# ── Final sync — push local commits to origin before exiting ──────────
# Called on every exit path so committed work is never left unpublished.
# Operates on a single repo. The first arg (default: control repo) lets
# `final_sync_all` reuse this logic for every workspace target. The second
# arg is a workspace-mode label (e.g. "target=frontend" — no trailing space)
# that gets appended to log lines as a SUFFIX. The "verb at front, qualifier
# at end" shape preserves the literal markers (`final_sync push_ok`,
# `final_sync would_push`, etc.) so a single grep matches both control- and
# target-repo lines without regex acrobatics, and the marker-drift guard in
# tests/features.bats keeps working without per-marker regex updates.
final_sync() {
  local _fs_repo="${1:-$repo}"
  local _fs_label="${2:-}"
  local _fs_suffix=""
  [[ -n "$_fs_label" ]] && _fs_suffix=" $_fs_label"
  if ! type detect_default_branch >/dev/null 2>&1; then
    log_write "[$(date '+%H:%M')] final_sync skipped — helpers_not_loaded${_fs_suffix}"
    return 0
  fi
  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    return 0  # Test mode — skip real git operations
  fi
  if ! git -C "$_fs_repo" rev-parse --git-dir >/dev/null 2>&1; then
    return 0  # Not a git repo
  fi
  if [[ -z "$(git -C "$_fs_repo" remote 2>/dev/null)" ]]; then
    return 0  # No remote configured
  fi
  # Guard: don't push from detached HEAD — could push to unexpected ref
  local _current_branch
  _current_branch=$(git -C "$_fs_repo" symbolic-ref --short HEAD 2>/dev/null) || true
  if [[ -z "$_current_branch" ]]; then
    log_write "[$(date '+%H:%M')] final_sync skipped — detached HEAD${_fs_suffix}"
    return 0
  fi
  # Only push if there are local commits ahead of origin
  local _default_branch
  local _default_branch_source
  local _current_head
  read -r _default_branch _default_branch_source < <(detect_default_branch "$_fs_repo")
  _current_head=$(git -C "$_fs_repo" rev-parse HEAD 2>/dev/null) || _current_head=""
  local ahead
  ahead=$(git -C "$_fs_repo" rev-list --count "origin/$_default_branch..HEAD" 2>/dev/null) || ahead=0
  if [[ "$ahead" -eq 0 ]]; then
    log_write "[$(date '+%H:%M')] final_sync nothing_to_push${_fs_suffix}"
    return 0
  fi
  # Shutdown can re-enter via repeated signals or overlapping exit paths. Only
  # push a given local commit snapshot once per process. The memo is per-repo
  # so the control repo and each target each get their own dedup key — without
  # this, pushing the control repo would block every subsequent target push
  # whenever the (head, ahead) tuples accidentally collided.
  local _memo_key=";${_fs_repo}=${_current_head}/${ahead};"
  case "$_dvb_final_sync_memo" in
    *"$_memo_key"*)
      log_write "[$(date '+%H:%M')] final_sync skipped_duplicate commits=$ahead head=$_current_head${_fs_suffix}"
      return 0
      ;;
  esac
  _dvb_final_sync_memo="${_dvb_final_sync_memo}${_memo_key}"
  # No-publish mode: log the intent and stop. Operator pushes manually.
  if [[ "$no_push" == "1" ]]; then
    if [[ -n "$_fs_label" ]]; then
      echo "   🛑 No-publish mode (${_fs_label}): $ahead local commit(s) ready for review (head=$_current_head)."
    else
      echo "   🛑 No-publish mode: $ahead local commit(s) ready for review (head=$_current_head). Push manually after review."
    fi
    log_write "[$(date '+%H:%M')] final_sync would_push commits=$ahead head=$_current_head${_fs_suffix}"
    return 0
  fi
  if [[ -n "$_fs_label" ]]; then
    echo "   📤 Pushing $ahead local commit(s) from ${_fs_label} to origin..."
  else
    echo "   📤 Pushing $ahead local commit(s) to origin..."
  fi
  log_write "[$(date '+%H:%M')] final_sync pushing commits=$ahead${_fs_suffix}"
  local push_output push_first_line="" push_status=0 _is_nff=0
  push_output=$(git -C "$_fs_repo" push origin HEAD 2>&1) || push_status=$?
  if [[ "$push_status" -eq 0 ]]; then
    log_write "[$(date '+%H:%M')] final_sync push_ok${_fs_suffix}"
  else
    while IFS= read -r _push_line; do
      [[ -z "$_push_line" ]] && continue
      case "$_push_line" in
        *"[rejected]"*|*"non-fast-forward"*|*"fetch first"*)
          push_first_line="$_push_line"
          _is_nff=1
          break
          ;;
        *"failed to push"*|*"remote rejected"*|error:*)
          push_first_line="$_push_line"
          break
          ;;
      esac
      if [[ -z "$push_first_line" ]] && [[ "$_push_line" != To\ * ]]; then
        push_first_line="$_push_line"
      fi
    done <<< "$push_output"
    # Auto-rebase recovery for non-fast-forward rejections. Common cause: a concurrent
    # PR squash-merged the same content under a different SHA. `git pull --rebase`
    # canonicalizes onto origin and drops the equivalent commit; the retry push then
    # succeeds (or is a no-op). On real conflicts the rebase is aborted and the path
    # falls through to the existing push_failed flow.
    if [[ "$_is_nff" -eq 1 ]] && [[ -n "$_default_branch" ]]; then
      local rebase_status=0 retry_output retry_status=0
      log_write "[$(date '+%H:%M')] final_sync rebase_attempt branch=$_default_branch${_fs_suffix}"
      git -C "$_fs_repo" pull --rebase --autostash origin "$_default_branch" >/dev/null 2>&1 || rebase_status=$?
      if [[ "$rebase_status" -eq 0 ]]; then
        log_write "[$(date '+%H:%M')] final_sync rebase_recovered branch=$_default_branch${_fs_suffix}"
        retry_output=$(git -C "$_fs_repo" push origin HEAD 2>&1) || retry_status=$?
        if [[ "$retry_status" -eq 0 ]]; then
          log_write "[$(date '+%H:%M')] final_sync push_ok after_rebase=1${_fs_suffix}"
          return 0
        fi
        push_output="$retry_output"
        push_first_line=""
        while IFS= read -r _push_line; do
          [[ -z "$_push_line" ]] && continue
          if [[ -z "$push_first_line" ]] && [[ "$_push_line" != To\ * ]]; then
            push_first_line="$_push_line"
          fi
        done <<< "$retry_output"
      else
        if rebase_in_progress "$_fs_repo"; then
          git -C "$_fs_repo" rebase --abort >/dev/null 2>&1 || true
        fi
        log_write "[$(date '+%H:%M')] final_sync rebase_aborted reason=conflict${_fs_suffix}"
      fi
    fi
    # Classify the push failure. Protected-branch rejections (GH006 etc.)
    # have a structured recovery path: open a PR with the local commits.
    # Every other failure falls through to the existing manual-recovery flow.
    local _push_class
    _push_class=$(_classify_push_failure "$push_output")
    if [[ "$_push_class" == "protected_branch" ]]; then
      log_write "[$(date '+%H:%M')] final_sync push_protected_branch error=$push_first_line${_fs_suffix}"
      # Attempt the PR fallback when:
      # 1. `gh` is on PATH (no PR creation possible without it),
      # 2. Operator hasn't set --no-pr-fallback / TG_NO_PR_FALLBACK,
      # 3. Operator hasn't set --no-push / TG_NO_PUSH (no_push==1 means
      #    no remote writes at all, including feature branches).
      local _pr_fallback_eligible=1
      if ! command -v gh >/dev/null 2>&1; then
        _pr_fallback_eligible=0
        log_write "[$(date '+%H:%M')] final_sync push_protected_branch_no_gh${_fs_suffix}"
      fi
      if [[ "${no_pr_fallback:-0}" == "1" ]]; then
        _pr_fallback_eligible=0
        log_write "[$(date '+%H:%M')] final_sync push_protected_branch_pr_fallback_disabled${_fs_suffix}"
      fi
      if [[ "${no_push:-0}" == "1" ]]; then
        _pr_fallback_eligible=0
      fi
      if [[ "$_pr_fallback_eligible" -eq 1 ]]; then
        # Approval token gate (acceptance criterion b): TG_PUBLIC_WRITE_TOKEN must
        # be set to a non-empty value to authorize auto-PR creation. When absent,
        # the draft PR body is written to a temp file for operator review and the
        # run falls through to push_protected_branch_manual_recovery_needed.
        local _ship_branch
        _ship_branch="taskgrind-ship-$(date -u +%Y%m%d-%H%M%S)"
        # Build PR title + body regardless of whether we'll actually create the PR.
        # Body is needed for both the draft-file path and the live PR path.
        local _pr_title _pr_body _latest_subject _commit_log
        _latest_subject=$(git -C "$_fs_repo" log -1 --pretty='%s' 2>/dev/null || echo "taskgrind ship")
        if [[ "$ahead" -eq 1 ]]; then
          _pr_title="$_latest_subject"
        else
          _pr_title="taskgrind ship: $ahead commits ($_latest_subject)"
        fi
        _commit_log=$(git -C "$_fs_repo" log "origin/$_default_branch..HEAD" --pretty='- %s' 2>/dev/null || echo "")
        _pr_body=$(printf 'Why this is needed:\ntaskgrind final_sync attempted to push to %s but the direct push was rejected by branch protection (%s). This PR was auto-created to preserve the completed work for operator review and merge.\n\nCommits:\n%s\n\nLocal branch: %s\nTarget: %s\n\n---\n_🤖 Written by an agent, not Fyodor. Ping me if this looks off._' "$_default_branch" "$push_first_line" "$_commit_log" "$_ship_branch" "$_default_branch")
        if [[ -z "${DVB_PUBLIC_WRITE_TOKEN:-}" ]]; then
          # No approval token — write draft body to file and block PR creation.
          local _draft_body_file
          _draft_body_file=$(mktemp "$_dvb_tmp/taskgrind-pr-draft-XXXXXX.md" 2>/dev/null) || \
            _draft_body_file="$_dvb_tmp/taskgrind-pr-draft-$(date -u +%Y%m%d-%H%M%S).md"
          printf '%s\n' "$_pr_body" > "$_draft_body_file" 2>/dev/null || true
          echo "   🛑 PR creation blocked: TG_PUBLIC_WRITE_TOKEN not set."
          echo "      Approval needed — draft body at: $_draft_body_file"
          echo "      Set TG_PUBLIC_WRITE_TOKEN=<token> to authorize auto-PR for this run."
          log_write "[$(date '+%H:%M')] final_sync pr_blocked_approval_needed branch=$_ship_branch draft=$_draft_body_file${_fs_suffix}"
          # Fall through to manual-recovery path below.
        else
          # Token present — proceed with branch push + PR creation.
          local _ship_push_status=0 _ship_push_output _pr_url _pr_status=0 _pr_output
          log_write "[$(date '+%H:%M')] final_sync pr_fallback_attempt branch=$_ship_branch commits=$ahead${_fs_suffix}"
          _ship_push_output=$(git -C "$_fs_repo" push origin "HEAD:$_ship_branch" 2>&1) || _ship_push_status=$?
          if [[ "$_ship_push_status" -eq 0 ]]; then
            _pr_output=$(gh pr create --base "$_default_branch" --head "$_ship_branch" --title "$_pr_title" --body "$_pr_body" 2>&1) || _pr_status=$?
            if [[ "$_pr_status" -eq 0 ]]; then
              _pr_url=$(printf '%s\n' "$_pr_output" | grep -Eo 'https?://[^[:space:]]+' | head -1)
              echo "   ✅ Push to main blocked by branch protection — opened PR: ${_pr_url:-$_pr_output}"
              log_write "[$(date '+%H:%M')] final_sync pr_created url=${_pr_url:-unknown} commits=$ahead branch=$_ship_branch${_fs_suffix}"
              return 0
            else
              log_write "[$(date '+%H:%M')] final_sync pr_creation_failed branch=$_ship_branch error=$_pr_output${_fs_suffix}"
            fi
          else
            log_write "[$(date '+%H:%M')] final_sync pr_fallback_push_failed branch=$_ship_branch error=$_ship_push_output${_fs_suffix}"
          fi
          # PR fallback failed — fall through to manual-recovery messaging below.
        fi
      fi
      echo "   ⚠ Push failed (protected branch): $push_first_line — local commits preserved for manual recovery"
      log_write "[$(date '+%H:%M')] final_sync push_protected_branch_manual_recovery_needed commits=$ahead${_fs_suffix}"
    elif [[ -n "$push_first_line" ]]; then
      echo "   ⚠ Push failed: $push_first_line — local commits preserved for manual push"
      log_write "[$(date '+%H:%M')] final_sync push_failed error=$push_first_line${_fs_suffix}"
    else
      echo "   ⚠ Push failed — local commits preserved for manual push"
      log_write "[$(date '+%H:%M')] final_sync push_failed${_fs_suffix}"
    fi
    if [[ -n "$push_output" ]]; then
      while IFS= read -r _push_line; do
        log_write "[$(date '+%H:%M')] final_sync push_stderr $_push_line${_fs_suffix}"
      done <<< "$push_output"
    fi
  fi
}

# Workspace-aware wrapper: push the control repo first, then each target.
# Targets are best-effort — a failure on one does not stop the others, since
# `final_sync` already preserves local commits for manual recovery on failure.
final_sync_all() {
  final_sync "$repo"
  if [[ "${#target_repos[@]}" -gt 0 ]]; then
    local _t
    for _t in ${target_repos[@]+"${target_repos[@]}"}; do
      final_sync "$_t" "target=$(basename "$_t")"
    done
  fi
}

# ── Workspace per-target git sync ─────────────────────────────────────
# Slot 0 calls this between sessions for every target repo, after the
# control repo's full sync block has completed. Performs the same
# stash + checkout + fetch + rebase + stash-pop sequence the control
# block runs and skips the merged-branch / stale-branch cleanup steps
# because those are pure cosmetics that would slow the loop without
# helping the agent. Log lines use the same `git_sync <verb> [details]
# target=<name>` shape the control repo uses, with `target=<name>` as
# a TRAILING qualifier so a single `grep "git_sync ok"` matches both
# control- and target-repo lines without regex acrobatics. Honours
# `DVB_GIT_SYNC_TIMEOUT` per target so operators tune total sync cost
# with one knob instead of raising the slot count.
sync_target_repo() {
  local _ts_repo="$1"
  local _ts_label
  _ts_label="target=$(basename "$_ts_repo")"
  local _ts_default_branch _ts_default_source

  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    return 0  # Test mode — skip real git operations
  fi

  if ! git -C "$_ts_repo" rev-parse --git-dir >/dev/null 2>&1 \
       || [[ -z "$(git -C "$_ts_repo" remote 2>/dev/null)" ]]; then
    log_write "[$(date '+%H:%M')] git_sync skipped (no_remote_or_not_git) $_ts_label"
    return 0
  fi

  dvb_spinner_start "Syncing $_ts_label..."
  local _ts_out
  _ts_out=$(mktemp "$_dvb_tmp/taskgrind-tgsy-XXXXXX")
  read -r _ts_default_branch _ts_default_source < <(detect_default_branch "$_ts_repo")

  (
    local _dirty=0 _err
    echo "selected_branch branch=$_ts_default_branch source=$_ts_default_source"
    if ! git -C "$_ts_repo" diff --quiet 2>/dev/null || ! git -C "$_ts_repo" diff --cached --quiet 2>/dev/null; then
      if _err=$(git -C "$_ts_repo" stash --include-untracked -m "taskgrind: auto-stash before target sync" 2>&1); then
        _dirty=1
        echo "stashed"
      else
        echo "stash_failed: $_err"
      fi
    fi
    if ! _err=$(git -C "$_ts_repo" checkout "$_ts_default_branch" 2>&1); then
      echo "checkout_failed: $_err"
    fi
    if ! _err=$(git -C "$_ts_repo" fetch origin --prune 2>&1); then
      echo "fetch_failed: $_err"
    fi
    if ! _err=$(git -C "$_ts_repo" rebase "origin/$_ts_default_branch" 2>&1); then
      echo "rebase_failed: $_err"
    fi
    if rebase_in_progress "$_ts_repo"; then
      git -C "$_ts_repo" rebase --abort 2>/dev/null || true
      echo "rebase_aborted"
    fi
    if [[ "$_dirty" -eq 1 ]]; then
      if ! git -C "$_ts_repo" stash pop 2>/dev/null; then
        echo "stash_pop_failed"
      fi
    fi
  ) > "$_ts_out" 2>&1 &
  local _ts_pid=$!
  # Reuse the same timeout knob as the control repo so operators tuning sync
  # cost have one variable to adjust, not two.
  local _ts_sync_timeout="${DVB_GIT_SYNC_TIMEOUT:-$DVB_DEFAULT_GIT_SYNC_TIMEOUT}"
  (
    trap 'kill $! 2>/dev/null; exit 0' TERM
    sleep "$_ts_sync_timeout" &
    wait $! 2>/dev/null || exit 0
    kill "$_ts_pid" 2>/dev/null || true
  ) &
  local _ts_timer=$!
  # Track in the shared _git_pid / _git_timer slots so graceful_shutdown
  # can kill an in-flight target sync the same way it kills the control
  # one. Since target syncs run sequentially after the control sync, only
  # one is alive at any time.
  _git_pid=$_ts_pid
  _git_timer=$_ts_timer
  local _ts_status=0
  if ! wait "$_ts_pid" 2>/dev/null; then
    _ts_status=$?
  fi
  dvb_spinner_stop
  kill "$_ts_timer" 2>/dev/null; wait "$_ts_timer" 2>/dev/null || true
  _git_pid=0
  _git_timer=0

  if [[ "$_ts_status" -eq 0 ]]; then
    if grep -q 'fetch_failed' "$_ts_out" 2>/dev/null; then
      local _err
      _err=$(grep 'fetch_failed' "$_ts_out" | head -1 | tr -cd '[:print:]' | head -c 500)
      echo "   ⚠ git sync $_ts_label: $_err"
      log_write "[$(date '+%H:%M')] git_sync $_err $_ts_label"
    elif grep -q 'checkout_failed' "$_ts_out" 2>/dev/null; then
      local _err
      _err=$(grep 'checkout_failed' "$_ts_out" | head -1 | tr -cd '[:print:]' | head -c 500)
      echo "   ⚠ git sync $_ts_label: $_err"
      log_write "[$(date '+%H:%M')] git_sync $_err $_ts_label"
    elif grep -q 'stash_failed' "$_ts_out" 2>/dev/null; then
      local _err
      _err=$(grep 'stash_failed' "$_ts_out" | head -1 | tr -cd '[:print:]' | head -c 500)
      echo "   ⚠ git sync $_ts_label: $_err"
      log_write "[$(date '+%H:%M')] git_sync $_err $_ts_label"
    elif grep -q 'rebase_aborted' "$_ts_out" 2>/dev/null; then
      log_write "[$(date '+%H:%M')] git_sync rebase_aborted $_ts_label"
    elif grep -q 'rebase_failed' "$_ts_out" 2>/dev/null; then
      local _err
      _err=$(grep 'rebase_failed' "$_ts_out" | head -1 | tr -cd '[:print:]' | head -c 500)
      echo "   ⚠ git sync $_ts_label: $_err"
      log_write "[$(date '+%H:%M')] git_sync $_err $_ts_label"
    elif grep -q 'stash_pop_failed' "$_ts_out" 2>/dev/null; then
      echo "   ⚠ git sync $_ts_label stash pop failed — stash preserved for manual recovery"
      log_write "[$(date '+%H:%M')] git_sync stash_pop_failed (stash preserved) $_ts_label"
    elif grep -q 'stashed' "$_ts_out" 2>/dev/null; then
      log_write "[$(date '+%H:%M')] git_sync ok (stashed dirty tree) $_ts_label"
    else
      log_write "[$(date '+%H:%M')] git_sync ok $_ts_label"
    fi
  else
    # Timeout — recover any interrupted rebase so the next session has a
    # clean tree. Same pattern as the control-repo timeout branch.
    local _ts_git_dir
    _ts_git_dir="$(git -C "$_ts_repo" rev-parse --absolute-git-dir 2>/dev/null)" || _ts_git_dir=""
    if [[ -n "$_ts_git_dir" && ( -d "$_ts_git_dir/rebase-merge" || -d "$_ts_git_dir/rebase-apply" ) ]]; then
      git -C "$_ts_repo" rebase --abort 2>/dev/null || true
      log_write "[$(date '+%H:%M')] git_sync timeout_rebase_aborted $_ts_label"
    fi
    if [[ -n "$_ts_git_dir" && -f "$_ts_git_dir/MERGE_HEAD" ]]; then
      git -C "$_ts_repo" merge --abort 2>/dev/null || true
      log_write "[$(date '+%H:%M')] git_sync timeout_merge_aborted $_ts_label"
    fi
    local _sync_output
    _sync_output=$(tail -10 "$_ts_out" 2>/dev/null | tr -cd '[:print:]\n' | head -c 500)
    echo "   ⚠ git sync $_ts_label timed out: $_sync_output"
    log_write "[$(date '+%H:%M')] git_sync timeout $_ts_label"
  fi

  rm -f "$_ts_out"
}

# ── Graceful shutdown — let the current session finish before exiting ─
# On INT/TERM during a session, sends SIGINT (commit & exit), waits up to
# DVB_SHUTDOWN_GRACE (default 120s), then SIGTERM if still alive.
_shutdown_grace="${DVB_SHUTDOWN_GRACE:-$DVB_DEFAULT_SHUTDOWN_GRACE}"

graceful_shutdown() {
  local sig_exit="$1"
  if [[ ${_dvb_shutting_down:-0} -eq 1 ]]; then
    log_write "[$(date '+%H:%M')] graceful_shutdown duplicate_signal exit=$sig_exit ignored"
    return 0
  fi
  _dvb_shutting_down=1
  # Signal-driven exit means the grind didn't reach its natural end —
  # mark the Bosun grind session as `aborted` so the dashboard sees
  # the difference between a clean shutdown and a controller kill.
  _bosun_grind_done_reason="aborted"
  # If a session is running, give it time to commit and exit
  if [[ $_dvb_pid -gt 0 ]] && kill -0 "$_dvb_pid" 2>/dev/null; then
    echo ""
    echo "   ⏳ Waiting for session $session to finish (up to ${_shutdown_grace}s)..."
    log_write "[$(date '+%H:%M')] graceful_shutdown waiting pid=$_dvb_pid grace=${_shutdown_grace}s"
    # Send SIGINT — tells devin to wrap up and commit
    kill -INT "$_dvb_pid" 2>/dev/null || true
    # Wait with timeout
    local waited=0
    while [[ $waited -lt $_shutdown_grace ]] && kill -0 "$_dvb_pid" 2>/dev/null; do
      sleep 1 2>/dev/null || true
      waited=$((waited + 1))
    done
    if kill -0 "$_dvb_pid" 2>/dev/null; then
      echo "   ⏰ Session still running after ${_shutdown_grace}s — sending SIGTERM"
      log_write "[$(date '+%H:%M')] graceful_shutdown timeout — killing pid=$_dvb_pid"
      kill "$_dvb_pid" 2>/dev/null || true
      wait "$_dvb_pid" 2>/dev/null || true
    else
      echo "   ✓ Session finished gracefully."
      log_write "[$(date '+%H:%M')] graceful_shutdown session_finished after=${waited}s"
    fi
    # Kill the timeout watchdog if it's still running
    if [[ $_dvb_timeout_pid -gt 0 ]] && kill -0 "$_dvb_timeout_pid" 2>/dev/null; then
      kill "$_dvb_timeout_pid" 2>/dev/null || true
      wait "$_dvb_timeout_pid" 2>/dev/null || true
    fi
    # Kill the elapsed timer if it's still running
    if [[ ${_dvb_timer_pid:-0} -gt 0 ]] && kill -0 "$_dvb_timer_pid" 2>/dev/null; then
      kill "$_dvb_timer_pid" 2>/dev/null || true
      wait "$_dvb_timer_pid" 2>/dev/null || true
    fi
  fi
  clear_resume_state
  # Kill git sync processes if interrupted mid-sync
  if [[ $_git_pid -gt 0 ]] && kill -0 "$_git_pid" 2>/dev/null; then
    kill "$_git_pid" 2>/dev/null || true
    wait "$_git_pid" 2>/dev/null || true
  fi
  if [[ $_git_timer -gt 0 ]] && kill -0 "$_git_timer" 2>/dev/null; then
    kill "$_git_timer" 2>/dev/null || true
    wait "$_git_timer" 2>/dev/null || true
  fi
  # Hand off final sync to this signal path so the EXIT trap does not re-run it.
  _dvb_skip_exit_final_sync=1
  final_sync_all
  cleanup
  exit "$sig_exit"
}

handle_exit_trap() {
  exit_status=$?
  # Pipeline-verify failure or any non-zero exit means we did NOT
  # complete cleanly — Bosun should see the grind session as aborted
  # rather than completed. graceful_shutdown already set this for the
  # signal path; this covers normal exits that fail the verify gate.
  if [[ "$exit_status" -ne 0 || "${_pipeline_verify_failed:-0}" -eq 1 ]]; then
    _bosun_grind_done_reason="aborted"
  fi
  if [[ ${_dvb_skip_exit_final_sync:-0} -eq 0 ]]; then
    final_sync_all
  fi
  cleanup
  if [[ "$exit_status" -eq 0 && "${_pipeline_verify_failed:-0}" -eq 1 ]]; then
    exit 1
  fi
  exit "$exit_status"
}

# Clean up on exit — always shows duration, even on Ctrl+C
_dvb_cleaned=0
cleanup() {
  [[ $_dvb_cleaned -eq 1 ]] && return
  _dvb_cleaned=1
  _dvb_finalizing=1
  case "$current_phase" in
    queue_empty|all_tasks_blocked|deadline_expired|audit_focus_blocked)
      terminal_reason="$current_phase"
      ;;
    *)
      terminal_reason=""
      ;;
  esac
  if [[ "$current_phase" != "failed" ]]; then
    current_phase="complete"
  fi
  if [[ "$current_phase" == "complete" ]]; then
    clear_resume_state
  fi
  write_status_file
  dvb_spinner_stop
  local elapsed=$(( $(date +%s) - start_epoch ))
  local duration
  duration=$(format_duration "$elapsed")

  # Efficiency metrics
  local rate="0.0" avg_session="0s" ship_rate="0%"
  if [[ $session -gt 0 ]]; then
    avg_session=$(format_duration $(( elapsed / session )))
  fi
  if [[ $elapsed -gt 0 && $tasks_shipped -gt 0 ]]; then
    # rate = tasks_shipped / hours — use bc for decimal, fall back to integer
    rate=$(echo "scale=1; $tasks_shipped * 3600 / $elapsed" | bc 2>/dev/null || echo "$((tasks_shipped * 3600 / elapsed))")
  fi
  # Ship rate denominator = starting tasks + every task added during the
  # run (in-session injections plus sweep discoveries). The previous
  # formula divided shipped by `tasks_starting` only, which produced
  # nonsensical >100 % numbers whenever sweeps or concurrent agents
  # padded the queue mid-run (the 2026-04-24 grind logged
  # `ship_rate=253% (33/13)` despite ~36 real tasks ever existing).
  # Cap at 100 % defensively — the new denominator can still under-count
  # in pathological churn cases (a task added then shipped within a
  # single window that only saw the removal half of the diff).
  local _ship_rate_denom=$(( tasks_starting + tasks_added_total ))
  if [[ $_ship_rate_denom -gt 0 ]]; then
    ship_rate=$(echo "scale=0; $tasks_shipped * 100 / $_ship_rate_denom" | bc 2>/dev/null || echo "$((tasks_shipped * 100 / _ship_rate_denom))")
    if [[ "$ship_rate" -gt 100 ]] 2>/dev/null; then
      ship_rate=100
    fi
    ship_rate="${ship_rate}%"
  fi

  echo ""
  echo "──────────────────────────────────────────"
  echo "  Grind complete: $session sessions, ${tasks_shipped}+ tasks, ${duration}"
  echo "  Rate: ${rate}/h  Avg session: ${avg_session}  Zero-ship: ${sessions_zero_ship}"
  echo "  Ship rate: ${ship_rate} (${tasks_shipped}/${_ship_rate_denom}, started=${tasks_starting} added=${tasks_added_total})  Remaining: ${tasks_remaining_snapshot}"
  echo "  Sweeps: ${_sweep_count} (${_sweep_seconds}s of ${elapsed}s)"
  echo "  Log: $log_file"
  echo "──────────────────────────────────────────"
  local _done_line
  _done_line="[pid=$$] [$(date '+%H:%M')] grind_done sessions=$session shipped=$tasks_shipped remaining=$tasks_remaining_snapshot ship_rate=$ship_rate avg_session=$avg_session elapsed=${elapsed}s duration=$duration rate=${rate}/h sessions_zero_ship=$sessions_zero_ship tasks_starting=$tasks_starting tasks_added=$tasks_added_total sweeps=$_sweep_count sweep_seconds=$_sweep_seconds"
  if [[ -n "${extra_prompt:-}" ]]; then
    _done_line+=" prompt=$extra_prompt"
  fi
  echo "$_done_line" >> "$log_file" 2>/dev/null || true
  # Pipeline-rate cross-check: did this session ship tasks without bosun
  # seeing any pipeline completions? A bypass-shaped result marks the grind
  # failed after filing its diagnostic task.
  if ! _verify_pipeline_completion_rate; then
    current_phase="failed"
    terminal_reason="pipeline_verify_failed"
    write_status_file
    echo "  ✗ Pipeline-rate verification failed — Bosun-dependent work shipped without a pipeline delta." >&2
  fi
  # Desktop notification — on by default, DVB_NOTIFY=0 to disable.
  # macOS: osascript, Linux: notify-send.
  # Skip in test mode (`DVB_GRIND_CMD` set): each bats invocation reaches
  # cleanup() and would otherwise fire a real macOS Notification Center
  # alert, spamming the operator with hundreds of "taskgrind complete"
  # banners on every `make check`. Same pattern as the test-mode bypass
  # in final_sync().
  if [[ "${DVB_NOTIFY:-1}" != "0" && -z "${DVB_GRIND_CMD:-}" ]]; then
    _notify_msg="$session sessions, ${tasks_shipped}+ tasks shipped in $duration"
    if [[ "$(uname)" == "Darwin" ]]; then
      osascript -e 'on run argv' -e 'display notification (item 1 of argv) with title "taskgrind complete"' -e 'end run' -- "$_notify_msg" 2>/dev/null || true
    elif command -v notify-send >/dev/null 2>&1; then
      notify-send "taskgrind complete" "$_notify_msg" 2>/dev/null || true
    fi
  fi
  # Stop the Bosun heartbeat loop before deregistering — once the
  # session is `done`, further heartbeats would 410 noisily.
  _stop_bosun_heartbeat_loop
  # Mark our Bosun grind session done with the reason we recorded
  # (`completed` by default, `aborted` if a signal/error path
  # downgraded it). No-op for caller-provided sessions and sessions
  # we never registered. Pass the reason explicitly so shellcheck
  # sees the function's optional argument as exercised (SC2120).
  _finalize_bosun_grind_session "$_bosun_grind_done_reason"
  # Remove temp files
  [[ -n "${_DVB_SELF_COPY:-}" && -f "${_DVB_SELF_COPY}" ]] && rm -f "$_DVB_SELF_COPY"
  [[ -n "${_lock_file:-}" && -f "${_lock_file}" ]] && rm -f "$_lock_file"
  rm -f "$session_output"
  rm -f "$_task_attempts_file"
  rm -f "${_task_attempts_file}.new" 2>/dev/null || true
  if [[ -n "${_git_out:-}" ]]; then
    rm -f "$_git_out"
  fi
  # Kill orphaned git sync processes (interrupted mid-sync)
  if [[ ${_git_pid:-0} -gt 0 ]] && kill -0 "$_git_pid" 2>/dev/null; then
    kill "$_git_pid" 2>/dev/null || true
    wait "$_git_pid" 2>/dev/null || true
  fi
  if [[ ${_git_timer:-0} -gt 0 ]] && kill -0 "$_git_timer" 2>/dev/null; then
    kill "$_git_timer" 2>/dev/null || true
    wait "$_git_timer" 2>/dev/null || true
  fi
}
# INT/TERM → graceful shutdown (wait for session, push, then exit)
trap 'graceful_shutdown 130' INT
trap 'graceful_shutdown 143' TERM
trap 'handle_exit_trap' EXIT

echo "☕ taskgrind: ${hours}h (until ${end_time}) — backend=$backend, skill=$skill, model=$model, repo=$repo"
if [[ "$max_instances" -gt 1 ]]; then
  echo "   Instance slot: $_dvb_slot of $max_instances"
fi
if [[ "${#target_repos[@]}" -gt 0 ]]; then
  echo "   Workspace: control + ${#target_repos[@]} target(s)"
  for _tg in ${target_repos[@]+"${target_repos[@]}"}; do
    echo "     - $_tg"
  done
  unset _tg
fi
if [[ "$resume_loaded" -eq 1 ]]; then
  echo "   Resuming: session=$session shipped=$tasks_shipped zero-ship=$consecutive_zero_ship"
fi
echo "   Each session runs $skill. Git sync every ${sync_interval} sessions."
if [[ "$model" != "$_startup_model" ]]; then
  echo "   Live model: $model (from .taskgrind-model, startup=$_startup_model)"
fi
if [[ -n "$extra_prompt" ]]; then
  echo "   Focus: $extra_prompt"
fi
echo "   Log: $log_file"
if [[ -n "$status_file" ]]; then
  echo "   Status: $status_file"
fi
echo ""

# Create log file with secure permissions before writing any content
(umask 077 && : > "$log_file")
chmod 600 "$log_file" 2>/dev/null || true

{
  echo "# taskgrind started $(date '+%Y-%m-%d %H:%M')"
  echo -n "# hours=$hours backend=$backend skill=$skill model=$model repo=$repo slot=$_dvb_slot"
  if [[ -n "$extra_prompt" ]]; then
    echo -n " prompt=$extra_prompt"
  fi
  if [[ -n "$_targets_joined" ]]; then
    echo -n " targets=$_targets_joined"
  fi
  echo ""
  echo ""
} >> "$log_file"

# ── --from-prompt audit log ───────────────────────────────────────────
# When --from-prompt was used, record what the translator produced and
# where the user's explicit config beat the translation. Defer logging
# until log_file exists; the translation itself ran before log_file was
# initialized.
if [[ -n "$_from_prompt_text" ]]; then
  log_write "[$(date '+%H:%M')] from_prompt translated hours=$_fp_hours repo=$_fp_repo targets=$_fp_targets model=$_fp_model backend=$_fp_backend skill=$_fp_skill focus=$_fp_focus no_push=$_fp_no_push"
  # One override line per slot where the user's explicit value beat the
  # prompt's suggestion. Quiet when the prompt was either not consulted
  # for that slot or its suggestion matched the user's choice.
  if [[ "$_cli_hours_set" -eq 1 && -n "$_fp_hours" && "$_fp_hours" != "$hours" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=hours user=$hours prompt=$_fp_hours reason=cli_explicit"
  fi
  if [[ "$_cli_repo_set" -eq 1 && -n "$_fp_repo" && "$_fp_repo" != "$repo" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=repo user=$repo prompt=$_fp_repo reason=cli_explicit"
  fi
  if [[ "$_cli_target_repos_set" -eq 1 && -n "$_fp_targets" && "$_fp_targets" != "$_targets_joined" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=target_repos user=$_targets_joined prompt=$_fp_targets reason=cli_explicit"
  elif [[ "$_cli_target_repos_set" -eq 0 && -n "${DVB_TARGET_REPOS:-}" && -n "$_fp_targets" && "$_fp_targets" != "$_targets_joined" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=target_repos user=$_targets_joined prompt=$_fp_targets reason=env_set"
  fi
  if [[ -n "$_cli_model" && -n "$_fp_model" && "$_fp_model" != "$model" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=model user=$model prompt=$_fp_model reason=cli_explicit"
  elif [[ -z "$_cli_model" && -n "${DVB_MODEL:-}" && -n "$_fp_model" ]]; then
    # The env var won; only log if the prompt's suggestion was different.
    _fp_model_resolved="$(dvb_resolve_model_alias "$_fp_model")"
    if [[ "$_fp_model_resolved" != "$model" ]]; then
      log_write "[$(date '+%H:%M')] from_prompt override slot=model user=$model prompt=$_fp_model reason=env_set"
    fi
    unset _fp_model_resolved
  fi
  if [[ -n "$_cli_backend" && -n "$_fp_backend" && "$_fp_backend" != "$backend" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=backend user=$backend prompt=$_fp_backend reason=cli_explicit"
  elif [[ -z "$_cli_backend" && -n "${DVB_BACKEND:-}" && -n "$_fp_backend" && "$_fp_backend" != "$backend" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=backend user=$backend prompt=$_fp_backend reason=env_set"
  fi
  if [[ "$_cli_skill_set" -eq 1 && -n "$_fp_skill" && "$_fp_skill" != "$skill" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=skill user=$skill prompt=$_fp_skill reason=cli_explicit"
  elif [[ "$_cli_skill_set" -eq 0 && -n "${DVB_SKILL:-}" && -n "$_fp_skill" && "$_fp_skill" != "$skill" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=skill user=$skill prompt=$_fp_skill reason=env_set"
  fi
  if [[ -n "$_fp_focus" && "$_fp_focus" != "$extra_prompt" && -n "$extra_prompt" ]]; then
    if [[ -n "$_cli_prompt" && "$_cli_prompt" != "$_fp_focus" ]]; then
      log_write "[$(date '+%H:%M')] from_prompt override slot=focus user=$_cli_prompt prompt=$_fp_focus reason=cli_explicit"
    fi
  fi
  if [[ -n "$_cli_no_push" && -n "$_fp_no_push" && "$_fp_no_push" != "$no_push" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=no_push user=$no_push prompt=$_fp_no_push reason=cli_explicit"
  elif [[ -z "$_cli_no_push" && -n "${DVB_NO_PUSH:-}" && -n "$_fp_no_push" && "$_fp_no_push" != "$no_push" ]]; then
    log_write "[$(date '+%H:%M')] from_prompt override slot=no_push user=$no_push prompt=$_fp_no_push reason=env_set"
  fi
fi

# Export instance slot so child processes (devin sessions) can see it
export TG_INSTANCE_ID="$_dvb_slot"
# Workspace mode: export the target repo list so skills, hooks, and wrapper
# scripts can branch on it. `TG_TARGET_REPOS` is colon-separated like PATH;
# `TG_TARGET_REPO_COUNT` makes "are we in workspace mode?" a single-variable
# check. Both are unset on the empty-list path so single-repo runs do not
# inherit stale values from a parent shell environment.
if [[ "${#target_repos[@]}" -gt 0 ]]; then
  export TG_TARGET_REPOS="$_targets_joined"
  export TG_TARGET_REPO_COUNT="${#target_repos[@]}"
else
  unset TG_TARGET_REPOS TG_TARGET_REPO_COUNT
fi
write_resume_state "running"
write_status_file

if [[ "$preflight_only" -eq 0 && ( -z "${DVB_GRIND_CMD:-}" || -n "${DVB_VALIDATE_BACKEND_STARTUP:-}" ) ]]; then
  if ! run_backend_probe; then
    echo "Error: $_backend_probe_error" >&2
    log_write "[$(date '+%H:%M')] $_backend_probe_summary"
    set_phase "failed"
    exit 1
  fi
  log_write "[$(date '+%H:%M')] $_backend_probe_summary"
fi

# Run preflight checks before entering the main loop
if [[ "${DVB_SKIP_PREFLIGHT:-0}" != "1" ]]; then
  set_phase "preflight"
  if ! preflight_check; then
    log_write "[$(date '+%H:%M')] preflight_failed"
    set_phase "failed"
    exit 1
  fi
fi
echo ""

count_tasks() {
  local tasks_file="$1"
  if [[ -f "$tasks_file" ]]; then
    local count
    # grep -c exits 1 when no matches (printing "0"), so || echo "0" would
    # produce "0\n0". Use || true to swallow the exit code cleanly.
    count=$(grep -c '^[[:space:]]*- \[ \]' "$tasks_file" 2>/dev/null) || true
    echo "${count:-0}"
  else
    echo "0"
  fi
}

# Extract task IDs from TASKS.md — one ID per line, sorted for diffing.
extract_task_ids() {
  local tasks_file="$1"
  if [[ -f "$tasks_file" ]]; then
    grep '^\s*\*\*ID\*\*:' "$tasks_file" 2>/dev/null \
      | sed 's/.*\*\*ID\*\*:[[:space:]]*//' | awk '{print $1}' | sort || true
  fi
}

# Extract task IDs whose title line carries a `(@<agent-id>)` claim marker
# per the tasks.md spec. One ID per line, sorted for diffing. Used by the
# per-task attempt tracker so an agent that never claimed a task cannot
# rack up "attempts" merely by leaving it in the queue. Lines that match
# the open-task title shape `^[ \t]*- \[ \]` open a block; a `(@…)`
# substring on that title flags the block as claimed; the block's
# `**ID**:` line is emitted only when the block is claimed. Closed tasks
# `- [x]` are intentionally ignored — the tasks.md spec requires removing
# completed tasks rather than checking them off, so an `[x]` line is
# either malformed or already shipped and should not influence the
# attempt counter. A new title line resets the claim flag, so a claimed
# block followed by an unclaimed block emits only the first ID.
extract_claimed_task_ids() {
  local tasks_file="$1"
  [[ -f "$tasks_file" ]] || return 0
  awk '
    BEGIN { claimed = 0 }
    /^[[:space:]]*- \[ \]/ {
      claimed = ($0 ~ /\(@[^)]+\)/) ? 1 : 0
      next
    }
    /^[[:space:]]*- \[x\]/ {
      claimed = 0
      next
    }
    claimed && /\*\*ID\*\*:/ {
      sub(/.*\*\*ID\*\*:[[:space:]]*/, "")
      print $1
      claimed = 0
    }
  ' "$tasks_file" | sort
}

# Extract task signatures so before/after snapshots can detect local queue churn
# even when git history becomes non-linear mid-session.
extract_task_signatures() {
  local tasks_file="$1"
  [[ -f "$tasks_file" ]] || return 0
  awk '
    BEGIN {
      task_line = ""
      task_id = ""
    }
    function flush_task() {
      if (task_line != "") {
        print task_line "|||" task_id
      }
      task_line = ""
      task_id = ""
    }
    /^[[:space:]]*- \[ \]/ {
      flush_task()
      task_line = $0
      sub(/^[[:space:]]+/, "", task_line)
      next
    }
    /^[[:space:]]+\*\*ID\*\*:/ {
      task_id = $0
      sub(/.*\*\*ID\*\*:[[:space:]]*/, "", task_id)
      sub(/[[:space:]].*$/, "", task_id)
      next
    }
    END {
      flush_task()
    }
  ' "$tasks_file" | sort || true
}

# Detect whether a commit range removes and/or adds task checkboxes in one TASKS.md file.
# Output keys:
#   removed=0|1
#   added=0|1
extract_task_checkbox_changes() {
  local repo="$1"
  local before_ref="$2"
  local after_ref="$3"
  local tasks_path="$4"
  local commit
  local patch
  local removed=0
  local added=0

  while IFS= read -r commit; do
    [[ -z "$commit" ]] && continue
    patch=$(git -C "$repo" show --root --format= --unified=0 "$commit" -- "$tasks_path" 2>/dev/null || true)
    if [[ -n "$patch" ]]; then
      if printf '%s\n' "$patch" | grep -Eq '^-[[:space:]]*- \[ \]'; then
        removed=1
      fi
      if printf '%s\n' "$patch" | grep -Eq '^\+[[:space:]]*- \[ \]'; then
        added=1
      fi
    fi
  done < <(git -C "$repo" rev-list "${before_ref}..${after_ref}" 2>/dev/null || true)

  echo "removed=$removed"
  echo "added=$added"
}

prune_task_attempts_file() {
  local attempts_file="$1"
  local tasks_file="$2"
  local current_ids
  local pruned_attempts

  [[ -s "$attempts_file" ]] || return 0

  current_ids=$(extract_task_ids "$tasks_file")
  if [[ -z "$current_ids" ]]; then
    : > "$attempts_file" 2>/dev/null || true
    return 0
  fi

  pruned_attempts="${attempts_file}.pruned"
  if awk 'NR == FNR { keep[$1] = 1; next } ($1 in keep) { print }' \
    <(printf '%s\n' "$current_ids") "$attempts_file" > "$pruned_attempts" 2>/dev/null; then
    mv "$pruned_attempts" "$attempts_file" 2>/dev/null || rm -f "$pruned_attempts" 2>/dev/null || true
  else
    rm -f "$pruned_attempts" 2>/dev/null || true
  fi
}

# Print the first remaining task context as shell-safe assignments.
# Output keys:
#   task_id=<id>
#   blocker=<blocked-by value>
extract_first_task_context() {
  local tasks_file="$1"
  [[ -f "$tasks_file" ]] || return 0
  awk '
    BEGIN {
      in_task = 0
      task_index = 0
      task_id = ""
      blocker = ""
    }
    /^[[:space:]]*- \[ \]/ {
      task_index++
      if (task_index == 1) {
        in_task = 1
        next
      }
      exit
    }
    in_task && /\*\*ID\*\*:/ && task_id == "" {
      line = $0
      sub(/.*\*\*ID\*\*:[[:space:]]*/, "", line)
      split(line, parts, /[[:space:]]+/)
      task_id = parts[1]
      next
    }
    in_task && /\*\*Blocked by\*\*:/ && blocker == "" {
      line = $0
      sub(/.*\*\*Blocked by\*\*:[[:space:]]*/, "", line)
      blocker = line
      sub(/[[:space:]]+$/, "", blocker)
      next
    }
    END {
      if (task_id != "") {
        printf "task_id=%s\n", task_id
      }
      if (blocker != "") {
        printf "blocker=%s\n", blocker
      }
    }
  ' "$tasks_file" 2>/dev/null || true
}

is_audit_only_focus_request() {
  local skill_name="$1"
  local focus_prompt="$2"
  local combined

  combined=$(printf '%s %s\n' "$skill_name" "$focus_prompt" | tr '[:upper:]' '[:lower:]')
  [[ "$combined" =~ standing-audit-gap-loop|project-audit|full-sweep|(^|[[:space:]])sweep($|[[:space:]])|audit|analyze[[:space:]]+logs|update[[:space:]]+tasks|refresh[[:space:]]+tasks|queue[[:space:]]+refresh ]]
}

has_supported_audit_lane_task() {
  local tasks_file="$1"
  [[ -f "$tasks_file" ]] || return 1

  awk '
    function flush_task() {
      if (in_task && (task_text ~ /(audit|log|queue|tasks\.md|sweep|refresh)/ || task_text ~ /standing-loop/)) {
        found = 1
      }
    }
    /^[[:space:]]*- \[ \]/ {
      flush_task()
      in_task = 1
      task_text = tolower($0)
      next
    }
    in_task {
      task_text = task_text "\n" tolower($0)
    }
    END {
      flush_task()
      exit(found ? 0 : 1)
    }
  ' "$tasks_file" 2>/dev/null
}

detect_default_branch() {
  local repo_path="$1"
  local default_branch current_branch upstream_branch upstream_ref
  local source="fallback"

  if [[ -n "${DVB_DEFAULT_BRANCH:-}" ]]; then
    printf '%s %s\n' "$DVB_DEFAULT_BRANCH" "env_override"
    return 0
  fi

  default_branch=$(git -C "$repo_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@.*/@@') || true
  if [[ -n "$default_branch" ]]; then
    printf '%s %s\n' "$default_branch" "origin_head"
    return 0
  fi

  default_branch=$(git -C "$repo_path" ls-remote --symref origin HEAD 2>/dev/null \
    | awk '/^ref:/ { sub("refs/heads/", "", $2); print $2; exit }') || true
  if [[ -n "$default_branch" ]]; then
    printf '%s %s\n' "$default_branch" "ls_remote_head"
    return 0
  fi

  current_branch=$(git -C "$repo_path" symbolic-ref --short HEAD 2>/dev/null) || true
  upstream_ref=$(git -C "$repo_path" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null) || true
  upstream_branch="${upstream_ref#origin/}"
  if [[ -n "$upstream_branch" && "$upstream_branch" != "$upstream_ref" ]]; then
    printf '%s %s\n' "$upstream_branch" "upstream"
    return 0
  fi

  if [[ -n "$current_branch" ]] && git -C "$repo_path" show-ref --verify --quiet "refs/remotes/origin/$current_branch"; then
    printf '%s %s\n' "$current_branch" "current_branch"
    return 0
  fi

  if git -C "$repo_path" show-ref --verify --quiet refs/heads/main; then
    printf '%s %s\n' "main" "local_main"
    return 0
  fi

  if git -C "$repo_path" show-ref --verify --quiet refs/heads/master; then
    printf '%s %s\n' "master" "local_master"
    return 0
  fi

  if git -C "$repo_path" show-ref --verify --quiet refs/remotes/origin/main; then
    printf '%s %s\n' "main" "origin_main"
    return 0
  fi

  if git -C "$repo_path" show-ref --verify --quiet refs/remotes/origin/master; then
    printf '%s %s\n' "master" "origin_master"
    return 0
  fi

  default_branch="${current_branch:-main}"
  if [[ -n "$current_branch" ]]; then
    source="current_branch_fallback"
  else
    source="hardcoded_main"
  fi
  printf '%s %s\n' "$default_branch" "$source"
}

extract_rebase_conflict_paths() {
  local git_output_file="$1"
  [[ -f "$git_output_file" ]] || return 0
  awk '
    /CONFLICT .* in / {
      path = $0
      sub(/^.* in /, "", path)
      sub(/\r$/, "", path)
      if (!(path in seen)) {
        seen[path] = 1
        print path
      }
    }
  ' "$git_output_file" 2>/dev/null || true
}

classify_rebase_conflicts() {
  local paths="$1"
  local path
  local only_tasks=1
  local has_paths=0
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    has_paths=1
    case "$path" in
      TASKS.md|*/TASKS.md) ;;
      *) only_tasks=0 ;;
    esac
  done <<EOF
$paths
EOF

  if [[ $has_paths -eq 0 ]]; then
    printf 'unknown\n'
  elif [[ $only_tasks -eq 1 ]]; then
    printf 'queue_only\n'
  else
    printf 'repo\n'
  fi
}

format_conflict_paths_for_log() {
  local paths="$1"
  local joined=""
  local path
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    if [[ -n "$joined" ]]; then
      joined="${joined},${path}"
    else
      joined="$path"
    fi
  done <<EOF
$paths
EOF

  printf '%s\n' "${joined:-unknown}"
}

emit_rebase_conflict_logs() {
  local repo="$1"
  local scope="$2"
  local output_file="${3:-}"
  local conflict_paths=""
  local conflict_class=""
  local conflict_paths_log=""

  if [[ -n "$output_file" ]]; then
    conflict_paths="$(extract_rebase_conflict_paths "$output_file")"
  fi
  if [[ -z "$conflict_paths" ]]; then
    conflict_paths="$(git -C "$repo" diff --name-only --diff-filter=U 2>/dev/null || true)"
  fi

  conflict_class="$(classify_rebase_conflicts "$conflict_paths")"
  conflict_paths_log="$(format_conflict_paths_for_log "$conflict_paths")"

  if [[ "$conflict_class" != "unknown" ]]; then
    log_write "[$(date '+%H:%M')] ${scope} rebase_conflicts class=${conflict_class} paths=${conflict_paths_log}"
    log_write "[$(date '+%H:%M')] ${scope} rebase_aborted class=${conflict_class} paths=${conflict_paths_log}"
  else
    log_write "[$(date '+%H:%M')] ${scope} rebase_aborted"
  fi
}

rebase_in_progress() {
  local repo="$1"
  local git_dir
  git_dir="$(git -C "$repo" rev-parse --absolute-git-dir 2>/dev/null)" || git_dir=""
  [[ -n "$git_dir" && ( -d "$git_dir/rebase-merge" || -d "$git_dir/rebase-apply" ) ]]
}

auto_resolve_tasks_rebase_conflicts() {
  local repo="$1"
  local conflict_paths
  local conflict_class
  local path
  local continue_err

  while rebase_in_progress "$repo"; do
    conflict_paths="$(git -C "$repo" diff --name-only --diff-filter=U 2>/dev/null || true)"
    conflict_class="$(classify_rebase_conflicts "$conflict_paths")"
    if [[ "$conflict_class" != "queue_only" ]]; then
      return 1
    fi

    while IFS= read -r path; do
      [[ -n "$path" ]] || continue
      if ! git -C "$repo" checkout --theirs -- "$path" >/dev/null 2>&1; then
        return 1
      fi
      if ! git -C "$repo" add -- "$path" >/dev/null 2>&1; then
        return 1
      fi
    done <<EOF
$conflict_paths
EOF

    if ! continue_err=$(GIT_EDITOR=: git -C "$repo" rebase --continue 2>&1); then
      printf '%s\n' "$continue_err"
      return 1
    fi
  done

  return 0
}

# Check if all tasks in TASKS.md are blocked.
# Returns 0 (true) if every task has **Blocked by**: metadata, 1 otherwise.
# A task with **Blocked by**: is considered blocked regardless of whether
# the blocker ID still exists — external blockers (Jira, infra) are common.
all_tasks_blocked() {
  local tasks_file="$1"
  [[ -f "$tasks_file" ]] || return 1
  local total_tasks blocked_tasks
  total_tasks=$(grep -c '^[[:space:]]*- \[ \]' "$tasks_file" 2>/dev/null) || true
  total_tasks="${total_tasks:-0}"
  [[ "$total_tasks" -eq 0 ]] && return 1  # empty queue is not "all blocked"
  # Count tasks (not lines) that have at least one **Blocked by**: underneath.
  # A task starts at a checkbox line; metadata is indented below it.
  blocked_tasks=$(awk '
    /^[[:space:]]*- \[ \]/ { if (in_task && has_blocker) b++; in_task=1; has_blocker=0 }
    in_task && /\*\*Blocked by\*\*:/ { has_blocker=1 }
    END { if (in_task && has_blocker) b++; print b+0 }
  ' "$tasks_file")
  [[ "$blocked_tasks" -ge "$total_tasks" ]]
}

# ── Network resilience ─────────────────────────────────────────────
# Fast-failure threshold: sessions shorter than this trigger a network check.
# Defaults to 0 in test mode (disabled) so existing tests aren't affected.
if [[ -n "${DVB_MIN_SESSION:-}" ]]; then
  min_session_secs="$DVB_MIN_SESSION"
elif [[ -n "${DVB_GRIND_CMD:-}" ]]; then
  min_session_secs=0
else
  min_session_secs="$DVB_DEFAULT_MIN_SESSION"
fi
consecutive_fast=0
_productive_zero_ship=0
_sweep_done=0

wait_for_network() {
  local wait_start waited
  local interval="${DVB_NET_WAIT:-$DVB_DEFAULT_NET_WAIT}"
  local max_wait="${DVB_NET_MAX_WAIT:-$DVB_DEFAULT_NET_MAX_WAIT}"
  wait_start=$(date +%s)

  set_phase "waiting_for_network"
  echo "📡 Network down — pausing marathon. Deadline will extend."
  log_write "[$(date '+%H:%M')] network_down"

  while ! check_network; do
    waited=$(( $(date +%s) - wait_start ))
    if [[ $waited -gt $max_wait ]]; then
      echo "   Network down $(format_duration "$max_wait")+. Exiting."
      log_write "[$(date '+%H:%M')] network_timeout waited=${waited}s"
      return 1
    fi
    echo "   Waiting for network... $(format_duration "$waited") elapsed"
    dvb_countdown_sleep "$interval" "Network check"
  done

  waited=$(( $(date +%s) - wait_start ))
  echo "📡 Network back after $(format_duration "$waited"). Resuming."
  log_write "[$(date '+%H:%M')] network_restored waited=${waited}s"

  # Extend deadline by the time spent waiting — no minutes lost to outage
  deadline=$((deadline + waited))
  set_phase "network_restored"
  return 0
}

skip_session_loop_if_deadline_expired() {
  local now remaining_secs
  now=$(date +%s)
  remaining_secs=$((deadline - now))
  if [[ "$remaining_secs" -gt 0 ]]; then
    return 1
  fi

  echo "⏰ Deadline already expired — skipping session loop."
  log_write "[$(date '+%H:%M')] deadline_expired_before_session_loop deadline=$deadline now=$now"
  set_phase "deadline_expired"
  return 0
}

prepare_next_session_start() {
  local now remaining_secs
  now=$(date +%s)
  remaining_secs=$((deadline - now))
  if [[ "$remaining_secs" -le 0 ]]; then
    log_write "[$(date '+%H:%M')] deadline_expired_before_session_start deadline=$deadline now=$now"
    set_phase "deadline_expired"
    return 1
  fi

  session=$((session + 1))
  remaining_min=$(( remaining_secs / 60 ))
  [[ $remaining_min -lt 0 ]] && remaining_min=0
  remaining_h=$(( remaining_min / 60 ))
  remaining_m=$(( remaining_min % 60 ))
  return 0
}

if skip_session_loop_if_deadline_expired; then
  set_phase "complete"
fi

while [[ $(date +%s) -lt $deadline ]]; do
  tasks_before=$(count_tasks "$repo/TASKS.md")
  tasks_remaining_snapshot=$tasks_before
  _ids_before=$(extract_task_ids "$repo/TASKS.md")
  _claimed_ids_before=$(extract_claimed_task_ids "$repo/TASKS.md")
  _task_signatures_before=$(extract_task_signatures "$repo/TASKS.md")
  # Capture git HEAD before session — used to detect commits during session
  _git_head_before=$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)

  # Capture starting task count on first iteration (for ship rate)
  [[ $tasks_starting -eq 0 && $tasks_before -gt 0 ]] && tasks_starting=$tasks_before

  # Guard cd — repo dir could be deleted during a long marathon
  if ! cd "$repo" 2>/dev/null; then
    echo "   ❌ Repo directory missing: $repo — aborting."
    log_write "[$(date '+%H:%M')] repo_missing path=$repo"
    set_phase "failed"
    break
  fi

  # ── Git state recovery ──────────────────────────────────────────────
  # If the repo ended up in a broken git state (mid-rebase, mid-merge) from
  # a crashed session or interrupted sync, recover before launching the next
  # session. Without this, every subsequent session fails on git operations.
  if git -C "$repo" rev-parse --git-dir >/dev/null 2>&1; then
    _git_dir="$(git -C "$repo" rev-parse --absolute-git-dir 2>/dev/null)" || _git_dir=""
    if [[ -n "$_git_dir" && ( -d "$_git_dir/rebase-merge" || -d "$_git_dir/rebase-apply" ) ]]; then
      emit_rebase_conflict_logs "$repo" "pre_session_recovery"
      git -C "$repo" rebase --abort 2>/dev/null || true
    fi
    if [[ -n "$_git_dir" && -f "$_git_dir/MERGE_HEAD" ]]; then
      git -C "$repo" merge --abort 2>/dev/null || true
      log_write "[$(date '+%H:%M')] pre_session_recovery merge_aborted"
    fi
  fi

  # ── Empty queue handling ──────────────────────────────────────────
  # When the queue is empty, launch a sweep session to audit the repo
  # and populate TASKS.md. If the sweep finds nothing, wait and retry
  # once — another agent or user may add tasks externally.
  # _sweep_done resets when tasks are shipped, so a grind that clears
  # all tasks can sweep again for more work.
  if [[ "$tasks_before" -eq 0 ]]; then
    if [[ "${DVB_SKIP_SWEEP_ON_EMPTY:-0}" == "1" ]]; then
      echo "   ✓ Queue empty — skipping sweep in test mode."
      log_write "[$(date '+%H:%M')] queue_empty tasks=0 sweep=skipped_for_test"
      set_phase "queue_empty"
      break
    fi
    if [[ "$_sweep_done" -ge 2 ]]; then
      echo "   ✓ Queue still empty after sweep + wait — exiting."
      log_write "[$(date '+%H:%M')] queue_empty tasks=0 sweep=exhausted — exiting"
      set_phase "queue_empty"
      break
    fi
    if [[ "$_sweep_done" -eq 1 ]]; then
      # Sweep already ran once and found nothing — wait before giving up
      _empty_wait="${DVB_EMPTY_QUEUE_WAIT:-$DVB_DEFAULT_EMPTY_QUEUE_WAIT}"
      # Cap at remaining deadline so tests and short runs aren't stuck
      _remaining=$(( deadline - $(date +%s) ))
      [[ $_remaining -lt $_empty_wait ]] && _empty_wait=$_remaining
      [[ $_empty_wait -le 0 ]] && { _sweep_done=2; continue; }
      echo "   ⏸ Queue empty after sweep — waiting ${_empty_wait}s for external task injection..."
      log_write "[$(date '+%H:%M')] queue_empty tasks=0 sweep=done — waiting ${_empty_wait}s"
      set_phase "queue_empty_wait"
      dvb_countdown_sleep "$_empty_wait" "Waiting for tasks"
      deadline=$((deadline + _empty_wait))
      tasks_before=$(count_tasks "$repo/TASKS.md")
      if [[ "$tasks_before" -gt 0 ]]; then
        echo "   ✓ Tasks appeared ($tasks_before) — resuming."
        log_write "[$(date '+%H:%M')] tasks_appeared tasks=$tasks_before — resuming"
        set_phase "queue_refilled"
        _sweep_done=0
        continue
      fi
      _sweep_done=2  # mark exhausted — next iteration will exit
      continue
    fi
    _sweep_done=1
    if ! prepare_next_session_start; then
      break
    fi
    echo "🔍 Queue empty — running sweep to find work..."
    log_write "[$(date '+%H:%M')] queue_empty tasks=0 — launching sweep session"
    last_session_number=$session
    last_session_result="pending"
    last_session_exit=""
    last_session_shipped=0
    last_session_duration=0
    last_session_completed_at=""
    set_phase "running_sweep"

    _refresh_prompt
    _refresh_model
    sweep_prompt="Run the $skill skill."
    sweep_prompt+=" TASKS.md is empty. Audit this repository and populate TASKS.md with actionable tasks."
    sweep_prompt+=" Look at: open TODOs/FIXMEs in code, test coverage gaps, lint warnings, outdated dependencies, missing docs, README gaps."
    sweep_prompt+=" Write tasks following the tasks.md spec: checkbox format under P0-P3 priority headings, with **ID**, **Tags**, **Details**, **Files**, **Acceptance** metadata."
    sweep_prompt+=" Focus on concrete improvements, not busywork. Commit the updated TASKS.md before timeout."
    if [[ -n "$extra_prompt" ]]; then
      sweep_prompt+=" FOCUS: $extra_prompt"
    fi
    _dvb_context_guard="$(fleet_context_guard)"
    if [[ -n "$_dvb_context_guard" ]]; then
      sweep_prompt+=" $_dvb_context_guard"
    fi

    session_start=$(date +%s)
    session_exit=0
    build_session_args "$sweep_prompt"
    if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
      run_test_backend "${devin_cmd[@]}" "${_session_args[@]}" || session_exit=$?
    else
      "${devin_cmd[@]}" "${_session_args[@]}" \
        > >(tee -a "$session_output") \
        2> >(tee -a "$session_output" >> "$log_file" >&2) &
      _dvb_pid=$!
      (
        trap 'kill $! 2>/dev/null; exit 0' TERM
        # Sweep watchdog uses sweep_max_session, NOT max_session — a
        # productive-timeout-escalated grind cap must not lengthen the
        # backlog-discovery budget. Without this, mid-run sweeps could
        # inherit a 7200 s ceiling and burn ~14 % of a 10 h grind on
        # backlog discovery (observed 2026-04-24).
        remaining=$sweep_max_session
        while (( remaining > 0 )); do
          s=$(( remaining > 10 ? 10 : remaining ))
          sleep "$s" &
          wait $! 2>/dev/null || exit 0
          remaining=$((remaining - s))
          kill -0 "$_dvb_pid" 2>/dev/null || exit 0
        done
        kill -INT "$_dvb_pid" 2>/dev/null || true
        sleep 15 &
        wait $! 2>/dev/null || exit 0
        if kill -0 "$_dvb_pid" 2>/dev/null; then
          kill "$_dvb_pid" 2>/dev/null || true
        fi
      ) &
      _dvb_timeout_pid=$!
      wait "$_dvb_pid" 2>/dev/null || session_exit=$?
      sleep 0.1 2>/dev/null || true  # let tee flush
      kill "$_dvb_timeout_pid" 2>/dev/null || true
      wait "$_dvb_timeout_pid" 2>/dev/null || true
      _dvb_timeout_pid=0
    fi
    _dvb_pid=0
    session_elapsed=$(( $(date +%s) - session_start ))
    log_write "[$(date '+%H:%M')] sweep_done exit=$session_exit elapsed=${session_elapsed}s cap=${sweep_max_session}s"
    # Aggregate sweep accounting for the grind_done summary (see the
    # `_sweep_count` / `_sweep_seconds` declarations near the other
    # counters at the top of the script).
    _sweep_count=$((_sweep_count + 1))
    _sweep_seconds=$((_sweep_seconds + session_elapsed))
    last_session_exit="$session_exit"
    last_session_shipped=0
    last_session_duration="$session_elapsed"
    if [[ "$session_exit" -eq 0 ]]; then
      last_session_result="success"
    else
      last_session_result="failure"
    fi
    last_session_completed_at="$(date '+%Y-%m-%dT%H:%M:%S%z')"

    # Fast-failure recovery for sweep sessions — same logic as regular sessions.
    # Without this, a network drop during sweep permanently ends the marathon.
    if [[ $min_session_secs -gt 0 && $session_elapsed -lt $min_session_secs ]]; then
      if ! check_network; then
        wait_for_network || break
        _sweep_done=0  # allow retry — network caused the failure, not an empty repo
        session=$((session - 1))
        continue
      fi
    fi

    tasks_found=$(count_tasks "$repo/TASKS.md")
    if [[ "$tasks_found" -gt 0 ]]; then
      echo "   ✓ Sweep found $tasks_found tasks — continuing grind."
      log_write "[$(date '+%H:%M')] sweep_found tasks=$tasks_found"
      # Sweep additions feed the same `tasks_added_total` counter that
      # the post-session block uses, so `ship_rate` accounts for backlog
      # discovery as well as in-session injections.
      tasks_added_total=$((tasks_added_total + tasks_found))
      set_phase "queue_refilled"
    else
      echo "   ✓ Sweep found no tasks — waiting for external task injection."
      log_write "[$(date '+%H:%M')] sweep_empty tasks=0"
      set_phase "queue_empty_wait"
    fi
    # Sweep efficiency marker — surfaces tasks_per_min so post-mortems
    # can spot a degrading sweep without grepping every sweep_done line.
    # Computed with bc when available so the integer divide loses no
    # precision when sweeps complete in seconds; falls back to a
    # whole-minute approximation when bc is missing. Multiplied by 60
    # against elapsed seconds rather than dividing the tasks first to
    # avoid the 0-tasks-found degenerate case truncating to 0.0.
    if [[ "$session_elapsed" -gt 0 ]]; then
      _sweep_tasks_per_min=$(echo "scale=2; $tasks_found * 60 / $session_elapsed" | bc 2>/dev/null) \
        || _sweep_tasks_per_min=$(( tasks_found * 60 / session_elapsed ))
    else
      _sweep_tasks_per_min="0.00"
    fi
    log_write "[$(date '+%H:%M')] sweep_efficiency tasks=$tasks_found elapsed=${session_elapsed}s tasks_per_min=$_sweep_tasks_per_min"
    # Re-enter loop — next iteration will pick up the new tasks.
    # Sweeps claim a session slot only once they are actually about to start.
    continue
  fi

  # ── Blocked queue detection ─────────────────────────────────────────
  # When all remaining tasks have **Blocked by**: metadata, running more
  # sessions won't decrease the task count. Wait and re-check — external
  # events (CI, merges, other agents) can unblock tasks.
  if all_tasks_blocked "$repo/TASKS.md"; then
    _blocked_wait=600  # 10 minutes
    # Cap at remaining deadline so tests and short runs aren't stuck
    _remaining=$(( deadline - $(date +%s) ))
    [[ $_remaining -lt $_blocked_wait ]] && _blocked_wait=$_remaining
    if [[ $_blocked_wait -le 0 ]]; then
      echo "   ✓ All $tasks_before remaining tasks are blocked and deadline reached — exiting."
      log_write "[$(date '+%H:%M')] all_tasks_blocked tasks=$tasks_before deadline_reached — exiting"
      set_phase "all_tasks_blocked"
      break
    fi
    echo "   ⏸ All $tasks_before remaining tasks are blocked — waiting ${_blocked_wait}s for external unblock..."
    log_write "[$(date '+%H:%M')] all_tasks_blocked tasks=$tasks_before — waiting ${_blocked_wait}s"
    set_phase "blocked_wait"
    dvb_countdown_sleep "$_blocked_wait" "Blocked"
    # Extend deadline by wait time — dead time should not count against the marathon
    deadline=$((deadline + _blocked_wait))
    # Re-check after wait
    if all_tasks_blocked "$repo/TASKS.md"; then
      echo "   ✓ All tasks still blocked after wait — exiting."
      log_write "[$(date '+%H:%M')] all_tasks_blocked tasks=$tasks_before still_blocked — exiting"
      set_phase "all_tasks_blocked"
      break
    fi
    echo "   ✓ Tasks unblocked — resuming."
    log_write "[$(date '+%H:%M')] tasks_unblocked tasks=$(count_tasks "$repo/TASKS.md") — resuming"
    set_phase "queue_refilled"
    tasks_before=$(count_tasks "$repo/TASKS.md")
    tasks_remaining_snapshot=$tasks_before
    _ids_before=$(extract_task_ids "$repo/TASKS.md")
    _claimed_ids_before=$(extract_claimed_task_ids "$repo/TASKS.md")
  fi

  if is_audit_only_focus_request "$skill" "$extra_prompt" && ! has_supported_audit_lane_task "$repo/TASKS.md"; then
    _blocked_session=$((session + 1))
    _first_task_context=$(extract_first_task_context "$repo/TASKS.md")
    _first_task_id=$(printf '%s\n' "$_first_task_context" | awk -F= '$1 == "task_id" { print $2; exit }')
    _audit_guard_context=""
    if [[ -n "$_first_task_id" ]]; then
      _audit_guard_context=" task_id=$_first_task_id"
    fi
    log_write "[$(date '+%H:%M')] audit_focus_without_task session=$_blocked_session skill=$skill${_audit_guard_context} refusing_session=1"
    echo "   ⚠ Audit-only focus requested but TASKS.md has no matching discovery-lane task — refusing to run a queue-maintenance-only session."
    last_session_summary="session $_blocked_session refused audit-only focus without a discovery-lane task"
    last_session_result="blocked"
    last_session_exit=0
    last_session_shipped=0
    last_session_duration=0
    last_session_completed_at="$(date '+%Y-%m-%dT%H:%M:%S%z')"
    set_phase "audit_focus_blocked"
    break
  fi

  # ── Build the session prompt ──────────────────────────────────────
  if ! prepare_next_session_start; then
    break
  fi

  # Re-read prompt and model files for live updates between sessions
  _refresh_prompt
  _refresh_model

  echo "🔄 Session $session — ${remaining_h}h${remaining_m}m remaining — $tasks_before tasks queued — model=$model"
  log_write "[$(date '+%H:%M')] session=$session remaining=${remaining_min}m tasks=$tasks_before model=$model"
  log_write "[$(date '+%H:%M')] session_start session=$session remaining=${remaining_min}m tasks=$tasks_before backend=$backend model=$model"
  last_session_number=$session
  last_session_result="pending"
  last_session_exit=""
  last_session_shipped=0
  last_session_duration=0
  last_session_completed_at=""
  set_phase "running_session"

  if [[ "$model" != "$_startup_model" ]]; then
    if [[ -n "$_model_alias" ]]; then
      log_write "[$(date '+%H:%M')] live_model=$model (alias=$_model_alias, startup=$_startup_model)"
    else
      log_write "[$(date '+%H:%M')] live_model=$model (startup=$_startup_model)"
    fi
  fi

  # Thin prompt — the skill handles task selection and execution.
  prompt="Run the $skill skill."
  prompt+=" Session $session, ${remaining_min} minutes remaining, timeout ${max_session}s."

  # Task completion protocol — the agent MUST close the loop. In no-publish
  # mode the protocol forbids any push / PR action so the operator can
  # review locally before publishing. The dry-run mirror at the help block
  # above carries the same two-branch wording — keep them in sync.
  if [[ "$no_push" == "1" ]]; then
    prompt+=" COMPLETION PROTOCOL: When you finish a task, you MUST remove its entire block (checkbox + all metadata lines) from TASKS.md and commit. This is how taskgrind tracks progress — if the task line stays in TASKS.md, it counts as zero work done, even if you committed code. NO-PUBLISH MODE: commit locally only. Do NOT push to any remote. Do NOT create pull requests. Do NOT merge pull requests. Do NOT use 'gh pr create', 'gh pr merge', 'git push', or any tool that publishes to origin. Remove the completed task block from TASKS.md and commit locally — that is the entire publish step. The operator will review and push manually after the grind exits."
  else
    prompt+=" COMPLETION PROTOCOL: When you finish a task, you MUST remove its entire block (checkbox + all metadata lines) from TASKS.md and commit. This is how taskgrind tracks progress — if the task line stays in TASKS.md, it counts as zero work done, even if you committed code. Do NOT merge pull requests, force-push branches, bypass pre-push hooks with --no-verify, or submit PRs without explicit operator approval in this session. If you committed directly to main, just remove the task. A session that commits code but doesn't remove the task from TASKS.md is a failed session."
  fi

  # Public-write gate — explicit in every session prompt (acceptance: a, d).
  # TASKS.md metadata is task context only, never operator approval for writes.
  # Mirrors the dry-run block above — keep both in sync.
  prompt+=" PUBLIC_WRITE_GATE: TASKS.md task metadata — including labels, tags, or green-list annotations — is task context only. It does NOT authorize any public write. Explicit current-session operator approval is required before: merging or creating pull requests, pushing to remote branches, opening issues, posting to Slack/Jira/email, publishing packages, or any action visible outside this local repo. For cross-repo or upstream work: prepare the branch and PR body locally, report 'Approval needed — draft body at <path>', and stop. Do NOT bypass pre-push hooks with --no-verify or submit without that approval."

  # Autonomy — the agent must not defer to humans, with public-write exception.
  prompt+=" AUTONOMY: You are fully autonomous. Never skip a task claiming it requires manual steps, human intervention, or external service access. You have browser automation, MCP tools, CLI access, and can interact with any web service. If a task involves a UI portal, use your browser skills. If it needs an API, call it. If it needs Jira, use MCP. Do not leave tasks saying 'requires manual work' — figure it out and do it. EXCEPTION: any public write (PR creation/merge, remote push, external notification) requires explicit operator approval in this session, not just task metadata."

  _dvb_context_guard="$(fleet_context_guard)"
  if [[ -n "$_dvb_context_guard" ]]; then
    prompt+=" $_dvb_context_guard"
  fi

  # Multi-instance conflict avoidance — slots ≥1 must coordinate with slot 0
  if [[ $_dvb_slot -ge 1 ]]; then
    prompt+=" MULTI-INSTANCE: You are instance $_dvb_slot of $max_instances running on this repo. Instance 0 handles code changes and git sync. Avoid modifying the same files as instance 0. Before committing, run 'git pull --rebase' to absorb concurrent commits. Prefer TASKS.md-only changes, auditing, or non-overlapping work."
  fi

  # Workspace mode — additional target repos the agent can edit and commit in
  if [[ "${#target_repos[@]}" -gt 0 ]]; then
    prompt+=" WORKSPACE: This grind has ${#target_repos[@]} target repo(s) in addition to the control repo ($repo): $_targets_joined. Tasks may require coordinated changes across these repos. The control repo is the source of truth for TASKS.md — keep TASKS.md edits there. Use 'cd <repo> && git ...' to commit changes in the right target repo, since taskgrind tracks each repo separately. Slot 0 syncs and pushes every target on the normal interval, so do not run extra fetch/push loops yourself."
  fi

  # Extra focus prompt — user-provided priority for every session
  if [[ -n "$extra_prompt" ]]; then
    prompt+=" FOCUS: $extra_prompt"
    prompt+=" Pick tasks from TASKS.md that relate to this focus first. Only work on unrelated tasks if no matching tasks remain."
  fi

  # Prior session context — tell the agent what just happened
  if [[ -n "$last_session_summary" ]]; then
    prompt+=" Previous session: $last_session_summary."
  fi

  # Stall warning — nudge the agent to try different approaches
  if [[ $consecutive_zero_ship -ge $self_investigate_zero_ship_streak ]]; then
    prompt+=" WARNING: Previous $consecutive_zero_ship sessions shipped nothing — tasks count in TASKS.md did not decrease. You MUST remove completed task blocks from TASKS.md for work to count. If previous sessions created PRs, merge them and remove those tasks first. Then decompose the next unclaimed unblocked task into 2-4 sub-tasks and implement the first one."
  fi

  # Productive zero-ship escalation — the agent committed code but forgot
  # to remove the completed task from TASKS.md. This fires earlier (2+ zero-ship)
  # and is more forceful than the general stall warning.
  if [[ $consecutive_zero_ship -ge 2 && "$_productive_zero_ship" -eq 1 ]]; then
    prompt+=" URGENT: You committed code in the previous session but did NOT remove the completed task from TASKS.md. Taskgrind tracks progress by task removal — your work counts as ZERO until the task block is removed. BEFORE doing ANY other work: (1) check git log for what you completed, (2) find the matching task in TASKS.md, (3) remove its entire block (checkbox + all metadata lines), (4) commit the TASKS.md change. Only then proceed to the next task."
  fi

  # Skip list — tasks attempted 3+ times without shipping
  prune_task_attempts_file "$_task_attempts_file" "$repo/TASKS.md"
  _skip_ids=""
  if [[ -s "$_task_attempts_file" ]]; then
    _skip_ids=$(awk '$2 >= 3 { printf "%s ", $1 }' "$_task_attempts_file" 2>/dev/null)
    if [[ -n "$_skip_ids" ]]; then
      prompt+=" SKIP these stuck tasks (attempted 3+ times): ${_skip_ids% }. Work on other tasks instead."
    fi
  fi

  prompt+=" Commit before timeout. Do not exhaust context."

  session_start=$(date +%s)
  session_exit=0
  build_session_args "$prompt"
  if [[ -n "${DVB_GRIND_CMD:-}" ]]; then
    # Test mode stays foreground for deterministic output capture without tee.
    run_test_backend "${devin_cmd[@]}" "${_session_args[@]}" || session_exit=$?
  else
    # Production: background with timeout watchdog as safety valve.
    # The backend's -p exits on its own, but the timeout catches infinite tool
    # loops or API outages. Uses sleep &; wait so SIGTERM interrupts
    # the watchdog immediately (no orphaned sleep processes).
    # Capture stdout to session_output for post-mortem diagnostics.
    "${devin_cmd[@]}" "${_session_args[@]}" \
      > >(tee -a "$session_output") \
      2> >(tee -a "$session_output" >> "$log_file" >&2) &
    _dvb_pid=$!
    (
      trap 'kill $! 2>/dev/null; exit 0' TERM
      remaining=$max_session
      while (( remaining > 0 )); do
        s=$(( remaining > 10 ? 10 : remaining ))
        sleep "$s" &
        wait $! 2>/dev/null || exit 0
        remaining=$((remaining - s))
        kill -0 "$_dvb_pid" 2>/dev/null || exit 0
      done
      echo "   ⏰ Session $session hit ${max_session}s timeout — sending SIGINT for graceful shutdown"
      log_write "[$(date '+%H:%M')] session_timeout session=$session max=${max_session}s"
      kill -INT "$_dvb_pid" 2>/dev/null || true
      # Grace period: let devin commit before force-killing
      _grace="${DVB_SESSION_GRACE:-$DVB_DEFAULT_SESSION_GRACE}"
      sleep "$_grace" &
      wait $! 2>/dev/null || exit 0
      if kill -0 "$_dvb_pid" 2>/dev/null; then
        echo "   ⏰ Session $session still alive after ${_grace}s grace — sending SIGTERM"
        kill "$_dvb_pid" 2>/dev/null || true
      fi
    ) &
    _dvb_timeout_pid=$!
    # Background elapsed timer — updates the terminal with session duration
    _dvb_timer_pid=0
    if [[ $_dvb_is_tty -eq 1 ]]; then
      (
        trap 'exit 0' TERM INT
        while kill -0 "$_dvb_pid" 2>/dev/null; do
          dvb_print_elapsed "$session_start" "Session $session"
          sleep 5 &
          wait $! 2>/dev/null || exit 0
        done
      ) &
      _dvb_timer_pid=$!
    fi
    wait "$_dvb_pid" 2>/dev/null || session_exit=$?
    # Brief pause for process substitution (tee) to flush before we truncate session_output
    sleep 0.1 2>/dev/null || true  # let tee flush
    # Stop elapsed timer and timeout watchdog
    if [[ $_dvb_timer_pid -gt 0 ]]; then
      kill "$_dvb_timer_pid" 2>/dev/null || true
      wait "$_dvb_timer_pid" 2>/dev/null || true
    fi
    if [[ $_dvb_is_tty -eq 1 ]]; then
      printf '\r\033[K'
    fi
    kill "$_dvb_timeout_pid" 2>/dev/null || true
    wait "$_dvb_timeout_pid" 2>/dev/null || true
    _dvb_timeout_pid=0
  fi
  _dvb_pid=0
  session_elapsed=$(( $(date +%s) - session_start ))

  # ── Fast-failure detection ────────────────────────────────────────
  # If session lasted less than min_session_secs, something is wrong.
  # Check network first; if down, pause and extend deadline.
  # If network is up but sessions keep failing, back off then bail out.
  if [[ $min_session_secs -gt 0 && $session_elapsed -lt $min_session_secs ]]; then
    consecutive_fast=$((consecutive_fast + 1))

    # Capture session output tail to log for post-mortem
    if [[ -s "$session_output" ]]; then
      {
        echo "--- session $session output (last 20 lines) ---"
        tail -20 "$session_output"
        echo "--- end session output ---"
      } >> "$log_file" 2>/dev/null || true
    fi

    if ! check_network; then
      wait_for_network || { set_phase "failed"; break; }
      session=$((session - 1))
      continue
    fi

    # Max consecutive fast failures — bail out with diagnostics
    if [[ $consecutive_fast -ge $max_fast ]]; then
      echo "   ❌ ${consecutive_fast} consecutive fast failures (exit=$session_exit, network OK). Giving up."
      if [[ -s "$session_output" ]]; then
        echo "   Last session output (tail):"
        tail -5 "$session_output" | sed 's/^/      /'
      fi
      log_write "[$(date '+%H:%M')] bail_out consecutive=$consecutive_fast exit=$session_exit backend=$backend"
      set_phase "failed"
      break
    fi

    # Network is up but session still crashed fast — back off
    if [[ $consecutive_fast -ge 3 ]]; then
      backoff_base="${DVB_BACKOFF_BASE:-$DVB_DEFAULT_BACKOFF_BASE}"
      backoff=$(( consecutive_fast * backoff_base ))
      backoff_max="${DVB_BACKOFF_MAX:-$DVB_DEFAULT_BACKOFF_MAX}"
      [[ $backoff -gt $backoff_max ]] && backoff=$backoff_max
      echo "   ⚠ ${consecutive_fast} fast failures (exit=$session_exit, network OK). Backing off ${backoff}s..."
      log_write "[$(date '+%H:%M')] fast_fail consecutive=$consecutive_fast backoff=${backoff}s exit=$session_exit backend=$backend"
      dvb_countdown_sleep "$backoff" "Backoff"
      # Extend deadline by backoff duration — dead time should not count
      # against the marathon, same pattern as wait_for_network()
      deadline=$((deadline + backoff))
    fi
  else
    consecutive_fast=0
  fi

  # The session can delete or move the repo mid-run. Treat that as an abort,
  # not as an empty queue, so follow-up logic does not misclassify it as shipped.
  if ! cd "$repo" 2>/dev/null; then
    echo "   ❌ Repo directory missing: $repo — aborting."
    log_write "[$(date '+%H:%M')] repo_missing path=$repo"
    set_phase "failed"
    break
  fi

  tasks_after=$(count_tasks "$repo/TASKS.md")
  tasks_remaining_snapshot=$tasks_after
  _ids_after=$(extract_task_ids "$repo/TASKS.md")
  _task_signatures_after=$(extract_task_signatures "$repo/TASKS.md")

  # Tasks shipped = IDs that existed BEFORE the session and are now gone.
  # This is more accurate than count_tasks diff because it correctly handles
  # sessions that add new tasks AND remove old ones (e.g., scout-while-you-work).
  # Fallback: when TASKS.md has no **ID**: metadata, use the old count-based approach.
  session_shipped=0
  if [[ -n "$_ids_before" ]]; then
    # ID-based: IDs removed = present in _ids_before but absent from _ids_after
    _ids_removed=$(comm -23 <(echo "$_ids_before") <(echo "$_ids_after") | wc -l)
    _ids_removed=$(( _ids_removed + 0 ))  # trim whitespace from wc
    session_shipped=$_ids_removed
    tasks_shipped=$((tasks_shipped + session_shipped))
  elif [[ "$tasks_before" -gt "$tasks_after" ]]; then
    # Count-based fallback (no IDs in TASKS.md)
    session_shipped=$((tasks_before - tasks_after))
    tasks_shipped=$((tasks_shipped + session_shipped))
  fi

  _tasks_added_during_session=0
  _local_task_signatures_removed=0
  _local_task_signatures_added=0

  # Log when new tasks were injected during the session (ID-based detection).
  # Both the ID-based and the count-based fallback feed `tasks_added_total`
  # so the `ship_rate` denominator covers every task the run actually had
  # to work on, not just the starting count.
  if [[ -n "$_ids_after" && -n "${_ids_before:-}" ]]; then
    _ids_added=$(comm -13 <(echo "$_ids_before") <(echo "$_ids_after") | wc -l)
    _ids_added=$(( _ids_added + 0 ))
    if [[ $_ids_added -gt 0 ]]; then
      _tasks_added_during_session=$_ids_added
      log_write "[$(date '+%H:%M')] tasks_added=$_ids_added (ids added during session)"
    fi
  elif [[ "$tasks_after" -gt "$tasks_before" ]]; then
    # Count-based fallback for task addition detection
    _tasks_added=$(( tasks_after - tasks_before ))
    _tasks_added_during_session=$_tasks_added
    log_write "[$(date '+%H:%M')] tasks_added=$_tasks_added (external injection: ${tasks_before}→${tasks_after})"
  fi
  if [[ "$_tasks_added_during_session" -gt 0 ]]; then
    tasks_added_total=$((tasks_added_total + _tasks_added_during_session))
  fi

  if [[ -n "${_task_signatures_before:-}" ]]; then
    _local_task_signatures_removed=$(comm -23 <(printf '%s\n' "$_task_signatures_before") <(printf '%s\n' "$_task_signatures_after") | wc -l)
    _local_task_signatures_removed=$(( _local_task_signatures_removed + 0 ))
  fi
  if [[ -n "${_task_signatures_after:-}" ]]; then
    _local_task_signatures_added=$(comm -13 <(printf '%s\n' "$_task_signatures_before") <(printf '%s\n' "$_task_signatures_after") | wc -l)
    _local_task_signatures_added=$(( _local_task_signatures_added + 0 ))
  fi

  # Auto-increase timeout after productive sessions that were killed by the watchdog.
  # Gives the next session more runway. Capped at 7200s (2h).
  if [[ "$session_elapsed" -ge "$max_session" && "$session_shipped" -gt 0 ]]; then
    _old_max=$max_session
    if [[ "$max_session" -lt 7200 ]]; then
      max_session=$((max_session + 1800))
      [[ "$max_session" -gt 7200 ]] && max_session=7200
      echo "   ⚠ Productive session hit timeout (shipped $session_shipped, timeout ${_old_max}s). Auto-increasing to ${max_session}s."
      log_write "[$(date '+%H:%M')] productive_timeout session=$session shipped=$session_shipped timeout=${_old_max}s new_timeout=${max_session}s"
    else
      echo "   ⚠ Productive session hit timeout (shipped $session_shipped, timeout ${_old_max}s). Already at max ${max_session}s."
      log_write "[$(date '+%H:%M')] productive_timeout session=$session shipped=$session_shipped timeout=${_old_max}s (at cap)"
    fi
  fi

  # ── Per-task attempt tracking ──────────────────────────────────────
  # Track how many times each task ID was *claimed* (via the
  # `(@<agent-id>)` marker the next-task skill writes onto the title
  # line) but didn't ship in the session that claimed it. Tasks with
  # 3+ such claimed-but-unshipped attempts get added to the skip list
  # in the next prompt. Unclaimed tasks never increment — sitting
  # unread in the queue does not count as an attempt, which used to
  # punish low-priority tasks the agent had only ever skimmed.
  # If a task carried a claim marker before the session and the marker
  # is gone afterwards (the agent or another worker un-claimed it), the
  # counter resets and `task_attempts_reset` is logged so post-mortems
  # can see the cycle. _ids_after was already computed above for
  # shipped tracking; _claimed_ids_after recomputes the claimed subset.
  _claimed_ids_after=$(extract_claimed_task_ids "$repo/TASKS.md")
  # Reset on claim-drop: any ID in claimed_before but not in
  # claimed_after has been un-claimed mid-session — drop its prior
  # count so a future re-claim starts the cycle from zero.
  if [[ -n "${_claimed_ids_before:-}" ]]; then
    _claim_lost=$(comm -23 <(echo "${_claimed_ids_before:-}") <(echo "${_claimed_ids_after:-}") 2>/dev/null)
    if [[ -n "$_claim_lost" ]]; then
      while IFS= read -r _lost_id; do
        [[ -z "$_lost_id" ]] && continue
        if grep -q "^${_lost_id} " "$_task_attempts_file" 2>/dev/null; then
          log_write "[$(date '+%H:%M')] task_attempts_reset id=$_lost_id reason=claim_dropped"
        fi
      done <<< "$_claim_lost"
    fi
  fi
  if [[ -n "$_claimed_ids_after" ]]; then
    _new_attempts="${_task_attempts_file}.new"
    while IFS= read -r _tid; do
      [[ -z "$_tid" ]] && continue
      _prev_count=$(awk -v id="$_tid" '$1 == id { print $2 }' "$_task_attempts_file" 2>/dev/null)
      _prev_count="${_prev_count:-0}"
      echo "$_tid $((_prev_count + 1))" >> "$_new_attempts"
    done <<< "$_claimed_ids_after"
    if ! mv "$_new_attempts" "$_task_attempts_file" 2>/dev/null; then
      log_write "[$(date '+%H:%M')] attempt_write_failed: could not update task attempts file"
      rm -f "$_new_attempts" 2>/dev/null || true
    fi
    # Log any newly skipped tasks (just crossed the threshold)
    _newly_skipped=$(awk '$2 == 3 { printf "%s ", $1 }' "$_task_attempts_file" 2>/dev/null)
    if [[ -n "$_newly_skipped" ]]; then
      log_write "[$(date '+%H:%M')] task_skip_threshold ids=${_newly_skipped% }"
    fi
  else
    : > "$_task_attempts_file" 2>/dev/null || true
  fi

  # ── Productive zero-ship detection ────────────────────────────────
  # Detect sessions where the agent committed code but didn't remove
  # completed tasks from TASKS.md. This is the #1 failure mode.
  _productive_zero_ship=0
  _productive_zero_ship_reason=""
  _productive_zero_ship_stall_exempt=0
  _inferred_shipped=0
  if [[ "$session_shipped" -eq 0 && -n "$_git_head_before" ]]; then
    _git_head_after=$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)
    if [[ -n "$_git_head_after" && "$_git_head_before" != "$_git_head_after" ]]; then
      _productive_zero_ship=1
      _new_commits=$(git -C "$repo" rev-list --count "${_git_head_before}..${_git_head_after}" 2>/dev/null || echo "?")
      _touched_task_files=$(
        git -C "$repo" rev-list "${_git_head_before}..${_git_head_after}" 2>/dev/null |
          while IFS= read -r _commit; do
            git -C "$repo" diff-tree --root --no-commit-id --name-only -r "$_commit" 2>/dev/null
          done | grep 'TASKS\.md$' || true
      )
      _local_task_checkbox_changes=$(extract_task_checkbox_changes "$repo" "$_git_head_before" "$_git_head_after" "TASKS.md")
      _local_task_removed=$(printf '%s\n' "$_local_task_checkbox_changes" | awk -F= '$1 == "removed" { print $2; exit }')
      _local_task_added=$(printf '%s\n' "$_local_task_checkbox_changes" | awk -F= '$1 == "added" { print $2; exit }')
      _nonlocal_removed_task_file=""
      if [[ -n "$_touched_task_files" ]]; then
        while IFS= read -r _task_file; do
          [[ -z "$_task_file" || "$_task_file" == "TASKS.md" ]] && continue
          if printf '%s\n' "$(extract_task_checkbox_changes "$repo" "$_git_head_before" "$_git_head_after" "$_task_file")" \
            | grep -q '^removed=1$'; then
            _nonlocal_removed_task_file="$_task_file"
            break
          fi
        done <<< "$_touched_task_files"
      fi
      if [[ "$_tasks_added_during_session" -gt 0 ]]; then
        _productive_zero_ship_reason="queue_delta_offset"
        _productive_zero_ship_stall_exempt=1
        log_write "[$(date '+%H:%M')] productive_zero_ship session=$session commits=$_new_commits reason=$_productive_zero_ship_reason tasks_added=$_tasks_added_during_session (committed code but concurrent task additions kept the queue flat)"
      elif [[ -n "$_nonlocal_removed_task_file" ]]; then
        _productive_zero_ship_reason="nonlocal_task_removed"
        _productive_zero_ship_stall_exempt=1
        log_write "[$(date '+%H:%M')] productive_zero_ship session=$session commits=$_new_commits reason=$_productive_zero_ship_reason task_file=$_nonlocal_removed_task_file (committed code and removed a task outside the active queue, so local TASKS.md stayed flat)"
      elif [[ "${_local_task_removed:-0}" -eq 1 && "${_local_task_added:-0}" -eq 1 ]] \
        || [[ "$_local_task_signatures_removed" -gt 0 && "$_local_task_signatures_added" -gt 0 ]]; then
        _productive_zero_ship_reason="local_task_churn"
        _productive_zero_ship_stall_exempt=1
        log_write "[$(date '+%H:%M')] productive_zero_ship session=$session commits=$_new_commits reason=$_productive_zero_ship_reason (committed code but temporary task churn restored the original queue)"
      elif [[ "${_local_task_removed:-0}" -eq 1 ]] || [[ "$_local_task_signatures_removed" -gt 0 ]]; then
        _productive_zero_ship_reason="local_task_removed"
        _productive_zero_ship_stall_exempt=1
        log_write "[$(date '+%H:%M')] productive_zero_ship session=$session commits=$_new_commits reason=$_productive_zero_ship_reason (committed code and removed a local task, but the queue-delta accounting stayed flat)"
      elif echo "$_touched_task_files" | grep -q '^TASKS\.md$'; then
        _productive_zero_ship_reason="local_task_churn"
        _productive_zero_ship_stall_exempt=1
        log_write "[$(date '+%H:%M')] productive_zero_ship session=$session commits=$_new_commits reason=$_productive_zero_ship_reason (committed code but temporary task churn restored the original queue)"
      else
        _productive_zero_ship_reason="no_local_task_removed"
        _first_task_context=$(extract_first_task_context "$repo/TASKS.md")
        _first_task_id=$(printf '%s\n' "$_first_task_context" | awk -F= '$1 == "task_id" { print $2; exit }')
        _first_task_blocker=$(printf '%s\n' "$_first_task_context" | awk -F= '$1 == "blocker" { sub(/^[^=]*=/, "", $0); print $0; exit }')
        _productive_zero_ship_context=""
        if [[ -n "$_first_task_id" ]]; then
          _productive_zero_ship_context+=" task_id=$_first_task_id"
        fi
        if [[ -n "$_first_task_blocker" ]]; then
          _productive_zero_ship_context+=" blocker=$_first_task_blocker"
        fi
        log_write "[$(date '+%H:%M')] productive_zero_ship session=$session commits=$_new_commits reason=$_productive_zero_ship_reason${_productive_zero_ship_context} (committed code but task count unchanged)"
      fi

      # Some productive zero-ship sessions did remove a completed task, but
      # queue churn, successor rollover, or non-local queue edits hid it from
      # the raw before/after count. Count those as shipped work.
      if [[ -n "$_nonlocal_removed_task_file" ]]; then
        _inferred_shipped=1
      elif [[ "$_local_task_signatures_removed" -gt 0 ]] \
        || [[ "${_local_task_removed:-0}" -eq 1 && "${_local_task_added:-0}" -eq 0 ]]; then
        _inferred_shipped=1
      fi

      if [[ "$_inferred_shipped" -gt 0 ]]; then
        session_shipped=$((session_shipped + _inferred_shipped))
        tasks_shipped=$((tasks_shipped + _inferred_shipped))
        _productive_zero_ship_stall_exempt=0
        log_write "[$(date '+%H:%M')] shipped_inferred session=$session count=$_inferred_shipped reason=$_productive_zero_ship_reason (counted shipped work from task-removal evidence despite flat queue delta)"
      fi
    fi
  fi

  # Build per-session summary for the next session's prompt
  last_session_summary="session $session shipped $session_shipped tasks (exit=$session_exit, $(format_duration "$session_elapsed")), queue now $tasks_after"
  if [[ "$session_shipped" -eq 0 ]]; then
    last_session_summary+=". NOTE: task count did not decrease — did previous session forget to remove the completed task from TASKS.md or merge the PR?"
  fi

  last_session_exit="$session_exit"
  last_session_shipped="$session_shipped"
  last_session_duration="$session_elapsed"
  if [[ "$session_exit" -eq 0 ]]; then
    last_session_result="success"
  else
    last_session_result="failure"
  fi
  last_session_completed_at="$(date '+%Y-%m-%dT%H:%M:%S%z')"
  set_phase "session_complete"

  # ── Zero-ship stall detection ──────────────────────────────────────
  # Detect sessions that run full duration but accomplish nothing.
  # Separate from consecutive_fast which catches crashes.
  if [[ "$session_shipped" -eq 0 ]]; then
    if [[ "$_productive_zero_ship_stall_exempt" -eq 1 ]]; then
      consecutive_zero_ship=0
      log_write "[$(date '+%H:%M')] zero_ship_stall_ignored session=$session reason=$_productive_zero_ship_reason"
    else
      consecutive_zero_ship=$((consecutive_zero_ship + 1))
      sessions_zero_ship=$((sessions_zero_ship + 1))
    fi

    # Capture session output tail for diagnostics — helps the user (and the
    # next session's stall warning) understand what happened.
    if [[ -s "$session_output" ]]; then
      {
        echo "--- session $session output (zero-ship, last 20 lines) ---"
        tail -20 "$session_output"
        echo "--- end session output ---"
      } >> "$log_file" 2>/dev/null || true
    fi

    if [[ "$_productive_zero_ship_stall_exempt" -eq 1 ]]; then
      :
    elif [[ $consecutive_zero_ship -ge $max_zero_ship ]]; then
      echo "   ❌ ${consecutive_zero_ship} consecutive zero-ship sessions. Marathon is stalled — exiting."
      log_write "[$(date '+%H:%M')] stall_bail consecutive_zero_ship=$consecutive_zero_ship"
      set_phase "failed"
      break
    elif [[ $consecutive_zero_ship -ge $self_investigate_zero_ship_streak ]]; then
      echo "   ⚠ ${consecutive_zero_ship} consecutive zero-ship sessions — adding stall warning to next prompt."
      log_write "[$(date '+%H:%M')] stall_warning consecutive_zero_ship=$consecutive_zero_ship"
    fi
  else
    consecutive_zero_ship=0
    # Allow another sweep if the queue empties after productive sessions.
    # Without this, a grind that clears all tasks can never find new work.
    _sweep_done=0
  fi

  # ── Diminishing returns detection ──────────────────────────────────
  # Track shipped counts in a rolling window. When the window total
  # drops below 2 (and we have a full window), the detector fires.
  #
  # Exit policy is three-tier:
  #   1. TG_NO_STALL_EXIT=1 → log advisory only, never auto-exit. Useful
  #      for audit/discovery lanes that legitimately have low ship rates.
  #   2. (default) → exit on the SECOND consecutive trip with
  #      `diminishing_returns_exit consecutive=N reason=default-2x`.
  #      One trip might be a slow patch in a long marathon; two
  #      consecutive trips means the queue is dead. Exiting after the
  #      second trip protects the budget without over-reacting to a
  #      single bad window.
  #   3. TG_EXIT_ON_STALL=1 (or TG_EARLY_EXIT_ON_STALL=1, kept as a
  #      backward-compat alias) → exit on the FIRST trip with the
  #      historical `early_exit_stall` log line.
  #
  # The consecutive counter resets to zero whenever a session ships >= 1
  # task, so a single productive session unwinds prior trips and the
  # default-2x clock starts over.
  if [[ "$session_shipped" -ge 1 ]]; then
    _consecutive_diminishing_returns=0
  fi
  _recent_shipped+=("$session_shipped")
  _window=5
  if [[ ${#_recent_shipped[@]} -ge $_window ]]; then
    _window_total=0
    for _ws in "${_recent_shipped[@]: -$_window}"; do
      _window_total=$((_window_total + _ws))
    done
    if [[ $_window_total -lt 2 && $session -ge $_window ]]; then
      _consecutive_diminishing_returns=$((_consecutive_diminishing_returns + 1))
      echo "   ⚠ Low throughput: ${_window_total} tasks shipped in last ${_window} sessions (consecutive_trips=${_consecutive_diminishing_returns})."
      log_write "[$(date '+%H:%M')] diminishing_returns window=$_window shipped=$_window_total consecutive=$_consecutive_diminishing_returns"
      if [[ "${DVB_NO_STALL_EXIT:-0}" == "1" ]]; then
        : # Advisory only — operator opted out of any auto-exit.
      elif [[ "${DVB_EARLY_EXIT_ON_STALL:-0}" == "1" ]] || [[ "${DVB_EXIT_ON_STALL:-0}" == "1" ]]; then
        echo "   ⚠ TG_EARLY_EXIT_ON_STALL=1 — exiting early to save time budget."
        log_write "[$(date '+%H:%M')] early_exit_stall"
        set_phase "failed"
        break
      elif [[ "$_consecutive_diminishing_returns" -ge 2 ]]; then
        echo "   ⚠ Diminishing returns detector tripped ${_consecutive_diminishing_returns} sessions in a row — exiting to save time budget. Set TG_NO_STALL_EXIT=1 to disable."
        log_write "[$(date '+%H:%M')] diminishing_returns_exit consecutive=$_consecutive_diminishing_returns reason=default-2x"
        set_phase "failed"
        break
      fi
    fi
  fi

  # Guard: skip session-end log if cleanup already ran (Ctrl-C race)
  if [[ $_dvb_finalizing -eq 0 ]]; then
    log_write "[$(date '+%H:%M')] session=$session ended exit=$session_exit duration=${session_elapsed}s tasks_after=$tasks_after shipped=$session_shipped"
    log_write "[$(date '+%H:%M')] session_end session=$session exit=$session_exit duration=${session_elapsed}s tasks_after=$tasks_after shipped=$session_shipped backend=$backend"
  fi

  # Mid-flight backend rotation: if the just-finished session output contains
  # rate-limit / quota / throttle patterns, advance to the next backend in the
  # rotation list before the next session launches. No-op otherwise. Must run
  # BEFORE we truncate $session_output below.
  _maybe_rotate_backend "$session_output" "rate_limit" || true

  # Self-investigation: detect "things are off" patterns that don't show up
  # in the session output (zero-ship streaks, persistent crashes) and act —
  # typically by rotating to the next backend if a rotation list is available.
  # Logs every detection for external observability.
  _maybe_self_investigate

  # Truncate session output to prevent unbounded growth across sessions
  : > "$session_output" 2>/dev/null || true

  # Check deadline before cooldown
  if [[ $(date +%s) -ge $deadline ]]; then
    break
  fi

  set_phase "cooldown"
  echo "   Session $session ended (exit=$session_exit, $(format_duration "$session_elapsed")). Cooling down ${cooldown}s..."
  dvb_countdown_sleep "$cooldown" "Cooldown"

  # Sync to default branch between sessions — but only every N sessions to reduce overhead.
  # sync_interval=0 means every session (backward compat). Default: every 5 sessions.
  # Slot ≥1 instances skip git sync entirely (slot 0 owns it).
  if [[ $_dvb_slot -ge 1 ]]; then
    set_phase "git_sync_skipped"
    log_write "[$(date '+%H:%M')] git_sync skipped (slot=$_dvb_slot, only slot 0 syncs)"
  elif [[ "$sync_interval" -eq 0 ]] || [[ $((session % sync_interval)) -eq 0 ]]; then
    set_phase "git_sync"
    if git -C "$repo" rev-parse --git-dir >/dev/null 2>&1 \
       && [[ -n "$(git -C "$repo" remote 2>/dev/null)" ]]; then
      dvb_spinner_start "Syncing git..."
      [[ -n "${_git_out:-}" ]] && rm -f "$_git_out"
      _git_out=$(mktemp "$_dvb_tmp/taskgrind-gsy-XXXXXX")
      _git_sync_timeout="${DVB_GIT_SYNC_TIMEOUT:-$DVB_DEFAULT_GIT_SYNC_TIMEOUT}"
      # Detect sync base branch — don't hardcode "main"; repos may use master/develop/etc.
      read -r _default_branch _default_branch_source < <(detect_default_branch "$repo")
      (
        echo "git_sync selected_branch branch=$_default_branch source=$_default_branch_source"
        # Handle dirty working tree — stash uncommitted changes before switching
        _dirty=0
        if ! git -C "$repo" diff --quiet 2>/dev/null || ! git -C "$repo" diff --cached --quiet 2>/dev/null; then
          if _err=$(git -C "$repo" stash --include-untracked -m "taskgrind: auto-stash before sync" 2>&1); then
            _dirty=1
            echo "git_sync stashed"
          else
            echo "git_sync stash_failed: $_err"
          fi
        fi
        if ! _err=$(git -C "$repo" checkout "$_default_branch" 2>&1); then
          echo "git_sync checkout_failed: $_err"
        fi
        if ! _err=$(git -C "$repo" fetch origin --prune 2>&1); then
          echo "git_sync fetch_failed: $_err"
        fi
        if ! _err=$(git -C "$repo" rebase "origin/$_default_branch" 2>&1); then
          _rebase_conflict_paths="$(git -C "$repo" diff --name-only --diff-filter=U 2>/dev/null || true)"
          _rebase_conflict_class="$(classify_rebase_conflicts "$_rebase_conflict_paths")"
          _rebase_conflict_paths_log="$(format_conflict_paths_for_log "$_rebase_conflict_paths")"
          if [[ "$_rebase_conflict_class" == "queue_only" ]]; then
            if _resolve_err=$(auto_resolve_tasks_rebase_conflicts "$repo" 2>&1); then
              echo "git_sync rebase_autoresolved class=$_rebase_conflict_class paths=$_rebase_conflict_paths_log strategy=local_theirs"
            else
              echo "git_sync rebase_failed: $_err"
              [[ -n "$_resolve_err" ]] && printf '%s\n' "$_resolve_err"
            fi
          else
            echo "git_sync rebase_failed: $_err"
          fi
        fi
        # Abort broken rebase — a conflicted rebase leaves the repo in a
        # "rebase in progress" state that breaks every subsequent session.
        if rebase_in_progress "$repo"; then
          git -C "$repo" rebase --abort 2>/dev/null || true
          echo "git_sync rebase_aborted"
        fi
        # Restore stashed changes after sync
        if [[ $_dirty -eq 1 ]]; then
          if ! git -C "$repo" stash pop 2>/dev/null; then
            echo "git_sync stash_pop_failed"
          fi
        fi
      ) > "$_git_out" 2>&1 &
      _git_pid=$!
      (
        trap 'kill $! 2>/dev/null; exit 0' TERM
        sleep "$_git_sync_timeout" &
        wait $! 2>/dev/null || exit 0
        kill "$_git_pid" 2>/dev/null || true
      ) &
      _git_timer=$!
      if wait "$_git_pid" 2>/dev/null; then
        dvb_spinner_stop
        _rebase_conflict_paths="$(extract_rebase_conflict_paths "$_git_out")"
        _rebase_conflict_class="$(classify_rebase_conflicts "$_rebase_conflict_paths")"
        _rebase_conflict_paths_log="$(format_conflict_paths_for_log "$_rebase_conflict_paths")"
        _selected_branch_log="$(grep 'git_sync selected_branch ' "$_git_out" 2>/dev/null | head -1 | tr -cd '[:print:]' | head -c 200)"
        if [[ -n "$_selected_branch_log" ]]; then
          log_write "[$(date '+%H:%M')] $_selected_branch_log"
        fi
        if grep -q 'stash_failed' "$_git_out" 2>/dev/null; then
          _git_fail=$(grep 'stash_failed' "$_git_out" 2>/dev/null | head -1 | sed 's/^git_sync stash_failed: //' | tr -cd '[:print:]' | head -c 500)
          echo "   ⚠ git stash failed: $_git_fail"
          log_write "[$(date '+%H:%M')] git_sync stash_failed: $_git_fail"
        elif grep -q 'stash_pop_failed' "$_git_out" 2>/dev/null; then
          echo "   ⚠ git stash pop failed — stash preserved for manual recovery"
          log_write "[$(date '+%H:%M')] git_sync stash_pop_failed (stash preserved)"
        elif grep -q 'fetch_failed' "$_git_out" 2>/dev/null; then
          _git_fail=$(grep 'fetch_failed' "$_git_out" 2>/dev/null | head -1 | tr -cd '[:print:]' | head -c 500)
          echo "   ⚠ git sync: $_git_fail"
          log_write "[$(date '+%H:%M')] $_git_fail"
        elif grep -q 'checkout_failed' "$_git_out" 2>/dev/null; then
          _git_fail=$(grep 'checkout_failed' "$_git_out" 2>/dev/null | head -1 | tr -cd '[:print:]' | head -c 500)
          echo "   ⚠ git sync: $_git_fail"
          log_write "[$(date '+%H:%M')] $_git_fail"
        elif grep -q 'stash_failed' "$_git_out" 2>/dev/null; then
          _git_fail=$(grep 'stash_failed' "$_git_out" 2>/dev/null | head -1 | tr -cd '[:print:]' | head -c 500)
          echo "   ⚠ git sync: $_git_fail"
          log_write "[$(date '+%H:%M')] $_git_fail"
        elif grep -q 'rebase_autoresolved' "$_git_out" 2>/dev/null; then
          _git_resolved=$(grep 'rebase_autoresolved' "$_git_out" 2>/dev/null | head -1 | tr -cd '[:print:]' | head -c 500)
          log_write "[$(date '+%H:%M')] $_git_resolved"
          log_write "[$(date '+%H:%M')] git_sync ok (auto-resolved TASKS.md rebase conflict)"
        elif grep -q 'rebase_aborted' "$_git_out" 2>/dev/null; then
          if grep -q 'rebase_failed' "$_git_out" 2>/dev/null; then
            _git_fail=$(awk '
              /rebase_failed:/ { capture=1 }
              capture { print }
            ' "$_git_out" 2>/dev/null | tr -cd '[:print:]\n' | tr '\n' ' ' | head -c 500)
            echo "   ⚠ git sync: $_git_fail"
            log_write "[$(date '+%H:%M')] $_git_fail"
          fi
          emit_rebase_conflict_logs "$repo" "git_sync" "$_git_out"
        elif grep -q 'rebase_failed' "$_git_out" 2>/dev/null; then
          _git_fail=$(awk '
            /rebase_failed:/ { capture=1 }
            capture { print }
          ' "$_git_out" 2>/dev/null | tr -cd '[:print:]\n' | tr '\n' ' ' | head -c 500)
          echo "   ⚠ git sync: $_git_fail"
          log_write "[$(date '+%H:%M')] $_git_fail"
          if [[ "$_rebase_conflict_class" != "unknown" ]]; then
            log_write "[$(date '+%H:%M')] git_sync rebase_conflicts class=$_rebase_conflict_class paths=$_rebase_conflict_paths_log"
          fi
        elif grep -q 'git_sync stashed' "$_git_out" 2>/dev/null; then
          log_write "[$(date '+%H:%M')] git_sync ok (stashed dirty tree)"
        else
          log_write "[$(date '+%H:%M')] git_sync ok"
        fi
      else
        dvb_spinner_stop
        # Timeout or failure — repo may be in unknown state (mid-rebase, mid-stash).
        # Recover: abort any in-progress rebase/merge so the next session starts clean.
        _git_dir="$(git -C "$repo" rev-parse --absolute-git-dir 2>/dev/null)" || _git_dir=""
        if [[ -n "$_git_dir" && ( -d "$_git_dir/rebase-merge" || -d "$_git_dir/rebase-apply" ) ]]; then
          git -C "$repo" rebase --abort 2>/dev/null || true
          log_write "[$(date '+%H:%M')] git_sync timeout_rebase_aborted"
        fi
        if [[ -n "$_git_dir" && -f "$_git_dir/MERGE_HEAD" ]]; then
          git -C "$repo" merge --abort 2>/dev/null || true
          log_write "[$(date '+%H:%M')] git_sync timeout_merge_aborted"
        fi
        sync_output=$(tail -10 "$_git_out" 2>/dev/null | tr -cd '[:print:]\n' | head -c 500)
        echo "   ⚠ git sync failed: $sync_output"
        log_write "[$(date '+%H:%M')] git_sync failed: $sync_output"
      fi
      kill "$_git_timer" 2>/dev/null; wait "$_git_timer" 2>/dev/null || true
      rm -f "$_git_out"

      # Clean up merged branches — safe, only deletes branches already in default branch
      git -C "$repo" branch --merged "$_default_branch" 2>/dev/null \
        | grep -v '^\*' | grep -vx "[[:space:]]*$_default_branch" \
        | xargs -I{} git -C "$repo" branch -d {} 2>/dev/null || true

      # Clean up stale local branches whose remote tracking branch is gone.
      # After `fetch --prune`, these show as [origin/xxx: gone] in `git branch -vv`.
      _stale_count=0
      while IFS= read -r _branch; do
        [[ -z "$_branch" ]] && continue
        _branch="$(echo "$_branch" | xargs)"  # trim whitespace
        if git -C "$repo" branch -D "$_branch" 2>/dev/null; then
          (( _stale_count += 1 ))
        fi
      done < <(git -C "$repo" branch -vv 2>/dev/null | grep ': gone]' | awk '{print $1}' | grep -v '^\*')
      if [[ "$_stale_count" -gt 0 ]]; then
        log_write "[$(date '+%H:%M')] branch_cleanup pruned=$_stale_count stale branches"
      fi
      log_write "[$(date '+%H:%M')] branch_cleanup done"
    fi  # end: if git remote exists

    # Workspace mode: after the control repo's sync completes, run the same
    # fetch+rebase pass against every target so the agent does not start the
    # next session on stale code. Already gated on slot 0 (this branch) and
    # the sync interval (the elif above), so no additional gating needed.
    if [[ "${#target_repos[@]}" -gt 0 ]]; then
      for _ts in ${target_repos[@]+"${target_repos[@]}"}; do
        sync_target_repo "$_ts"
      done
      unset _ts
    fi
  else
    log_write "[$(date '+%H:%M')] git_sync skipped (interval=$sync_interval, session=$session)"
  fi # sync_interval
done
